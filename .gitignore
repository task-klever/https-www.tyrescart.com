## Magento 2 .gitignore

# Ignore everything by default
/*

# Track these directories
!/app/
/app/*
!/app/code/
!/app/design/
!/app/etc/
/app/etc/env.php

!/bin/
!/lib/
!/dev/
!/setup/

# Track root config files
!/.gitignore
!/.htaccess
!/.htaccess.sample
!/.editorconfig
!/.php-cs-fixer.dist.php
!/.user.ini
!/composer.json
!/composer.lock
!/CHANGELOG.md
!/COPYING.txt
!/LICENSE.txt
!/LICENSE_AFL.txt
!/SECURITY.md
!/nginx.conf.sample
!/grunt-config.json.sample
!/Gruntfile.js.sample
!/package.json.sample
!/auth.json.sample
!/cronLaunch.php
!/magento-upgrade.md
!/magento-upgrade-249.md
!/README.md

# Track pub essentials only
!/pub/
/pub/*
!/pub/.htaccess
!/pub/.user.ini
!/pub/index.php
!/pub/cron.php
!/pub/get.php
!/pub/health_check.php
!/pub/static.php
!/pub/errors/

# Always ignore
*.bak.*
*.bkp*
*.sql
*.log
.DS_Store
/auth.json
/.claude/
deploy-frontend.sh

# Magento generated (never commit)
/vendor/
/generated/
/var/
/pub/static/
/pub/media/
/node_modules/
