## Magento 2 .gitignore

# Ignore everything by default
/*

# Track custom code
!/app/
/app/*
!/app/code/
!/app/design/
!/app/etc/
/app/etc/env.php

# Track Magento core directories
!/bin/
!/lib/
!/dev/
!/setup/
!/phpserver/

# Track root files
!/.gitignore
!/.htaccess
!/composer.json
!/composer.lock
!/README.md

# Track pub/index.php only
!/pub/
/pub/*
!/pub/index.php

# Never track
/vendor/
/generated/
/var/
/pub/static/
/pub/media/
/node_modules/
*.bak.*
*.bkp*
*.sql
*.log
.DS_Store
/auth.json
/.claude/
deploy-frontend.sh
