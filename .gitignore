## Magento 2 .gitignore

# Ignore everything by default
/*

# Track custom code
!/app/
/app/*
!/app/code/
!/app/design/
!/app/etc/
/app/etc/env.php

# Track Magento core directories
!/bin/
!/lib/
!/dev/
!/setup/
!/phpserver/

# Track root files
!/.gitignore
!/.htaccess
!/.htaccess.sample
!/.editorconfig
!/.php-cs-fixer.dist.php
!/.user.ini
!/composer.json
!/composer.lock
!/README.md
!/CHANGELOG.md
!/COPYING.txt
!/LICENSE.txt
!/LICENSE_AFL.txt
!/SECURITY.md
!/nginx.conf.sample
!/grunt-config.json.sample
!/Gruntfile.js.sample
!/package.json.sample
!/auth.json.sample
!/cronLaunch.php
!/magento-upgrade.md
!/magento-upgrade-249.md

# Track pub/index.php only
!/pub/
/pub/*
!/pub/index.php

# Never track
/vendor/
/generated/
/var/
/pub/static/
/pub/media/
/node_modules/
*.bak.*
*.bkp*
*.sql
*.log
.DS_Store
/auth.json
/.claude/
deploy-frontend.sh
