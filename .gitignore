## Magento 2 .gitignore — Track custom code only

# Ignore everything by default
/*

# Track these directories
!/app/
/app/*
!/app/code/
!/app/design/
!/app/etc/
/app/etc/env.php

# Track root config files
!/.gitignore
!/.htaccess
!/.htaccess.sample
!/.editorconfig
!/.php-cs-fixer.dist.php
!/.user.ini
!/composer.json
!/composer.lock
!/CHANGELOG.md
!/COPYING.txt
!/LICENSE.txt
!/LICENSE_AFL.txt
!/SECURITY.md
!/nginx.conf.sample
!/grunt-config.json.sample
!/Gruntfile.js.sample
!/package.json.sample
!/auth.json.sample
!/deploy-frontend.sh
!/cronLaunch.php
!/magento-upgrade.md
!/magento-upgrade-249.md
!/README.md

# Track bin
!/bin/

# Track pub essentials only
!/pub/
/pub/*
!/pub/.htaccess
!/pub/.user.ini
!/pub/index.php
!/pub/cron.php
!/pub/get.php
!/pub/health_check.php
!/pub/static.php
!/pub/errors/

# Always ignore
*.bak.*
*.bkp*
*.sql
*.log
*.png
*.jpg
/auth.json
/.claude/
.DS_Store
