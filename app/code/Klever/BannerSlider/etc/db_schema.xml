<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="mageplaza_bannerslider_banner" resource="default" engine="innodb">
        <column xsi:type="varchar" name="image_mobile" nullable="true" length="255" comment="Mobile Banner Image"/>
        <column xsi:type="varchar" name="url_key" nullable="true" length="255" comment="URL Key Slug"/>
        <column xsi:type="varchar" name="meta_title" nullable="true" length="255" comment="Meta Title"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta Description"/>
        <column xsi:type="text" name="page_content" nullable="true" comment="Page Content for Detail Page"/>
        <column xsi:type="date" name="display_from" nullable="true" comment="Display From Date"/>
        <column xsi:type="date" name="display_to" nullable="true" comment="Display To Date"/>
        <index referenceId="MAGEPLAZA_BANNERSLIDER_BANNER_URL_KEY" indexType="btree">
            <column name="url_key"/>
        </index>
    </table>
</schema>
