<?php
/**
 * Top Picks by Brand Segment — Alpine.js + AJAX
 * Shows on tyres category page (page 1 only, no layered nav filters)
 */

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$scopeConfig = $objectManager->get(\Magento\Framework\App\Config\ScopeConfigInterface::class);
$enabled = $scopeConfig->isSetFlag('klever_brandsegment/general/enabled');
if (!$enabled) { return; }

// Skip non-tyre pages
$registry = $objectManager->get(\Magento\Framework\Registry::class);
$currentCategory = $registry->registry('current_category');
if ($currentCategory) {
    $urlKey = $currentCategory->getUrlKey();
    if (in_array($urlKey, ['car-battery', 'motorcycle-tyres', 'rims-wheels', 'car-wheels'])) { return; }
    // Hide on brand pages (/tyres/brand/pirelli etc.)
    $categoryPath = $currentCategory->getUrlPath();
    if ($categoryPath && strpos($categoryPath, 'tyres/brand/') !== false) { return; }
}

// Hide on page 2+
$currentPage = (int)($_GET['p'] ?? 1);
if ($currentPage > 1) { return; }

// Hide when layered nav filters are applied (brand, price, year, etc.)
// Allow: width, height, rim, width_rear, height_rear, rim_rear, and toolbar params
$allowedParams = ['width', 'height', 'rim', 'width_rear', 'height_rear', 'rim_rear',
    'p', 'product_list_order', 'product_list_dir', 'product_list_mode', 'product_list_limit',
    'q', 'is_ajax', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content',
    'gclid', 'fbclid', 'msclkid', '_'];
$hasFilterParams = false;
foreach ($_GET as $paramKey => $paramValue) {
    if (!in_array($paramKey, $allowedParams) && $paramValue !== '' && $paramValue !== null) {
        $hasFilterParams = true;
        break;
    }
}
if ($hasFilterParams) { return; }

// Detect size from URL
$searchWidth = $_GET['width'] ?? null;
$searchHeight = $_GET['height'] ?? null;
$searchRim = $_GET['rim'] ?? null;
$currentUri = $_SERVER['REQUEST_URI'] ?? '';

// Only show when a size search is active (via params or /tyres/size/ URL)
$hasSizeFromUrl = preg_match('#/tyres/size/#i', $currentUri);
if (!$searchWidth && !$hasSizeFromUrl) { return; }
$currentUri = $_SERVER['REQUEST_URI'] ?? '';

// Parse /tyres/size/185-70-r14 format
if (!$searchWidth && preg_match('#/tyres/size/(\d+)-(\d+)-r(\d+)#i', $currentUri, $m)) {
    $searchWidth = $m[1];
    $searchHeight = $m[2];
    $searchRim = $m[3];
}

$limit = (int)$scopeConfig->getValue('klever_brandsegment/general/products_per_segment') ?: 3;
$baseUrl = $block->getBaseUrl();
?>

