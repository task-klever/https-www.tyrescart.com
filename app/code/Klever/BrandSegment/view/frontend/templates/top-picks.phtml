<script>
function topPicksSegment() {
    return {
        segments: [],
        expanded: { top_premium: false, top_quality: false, top_budget: false },
        segmentStyles: {
            top_premium: { bg: 'bg-gradient-to-r from-[#1a1a2e] to-[#16213e]' },
            top_quality: { bg: 'bg-gradient-to-r from-[#00843D] to-[#00a64d]' },
            top_budget:  { bg: 'bg-gradient-to-r from-[#f39c12] to-[#e67e22]' }
        },
        segmentLabels: {
            top_premium: '<?= $escaper->escapeJs(__('Top Premium')) ?>',
            top_quality: '<?= $escaper->escapeJs(__('Top Quality')) ?>',
            top_budget:  '<?= $escaper->escapeJs(__('Top Budget')) ?>'
        },
        async loadPicks() {
            try {
                const params = new URLSearchParams({
                    width: '<?= $escaper->escapeJs($searchWidth ?? '') ?>',
                    height: '<?= $escaper->escapeJs($searchHeight ?? '') ?>',
                    rim: '<?= $escaper->escapeJs($searchRim ?? '') ?>',
                    limit: <?= (int)$limit ?>
                });

                const response = await fetch('<?= $escaper->escapeJs($baseUrl) ?>brandsegment/ajax/toppicks?' + params.toString(), {
                    method: 'GET',
                    credentials: 'include'
                });

                const data = await response.json();
                if (data && data.segments) {
                    this.segments = data.segments;
                }
            } catch (e) {
                console.error('TopPicks error:', e);
            }
        }
    };
}

function topPicksChangePrice(selectEl, regularPrice, finalPrice, isOffer, discountAmt, discountQty, productId) {
    var qty = parseInt(selectEl.value);
    var formatter = new Intl.NumberFormat('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    var price;
    if (isOffer === 'No') {
        price = qty * finalPrice;
    } else {
        var da = parseFloat(discountAmt) || 0;
        var dq = parseInt(discountQty) || 0;
        if (qty >= dq && dq > 0) {
            price = qty * finalPrice;
            var discount = (da / 100) * finalPrice * dq * Math.floor(qty / dq);
            price = price - discount;
        } else {
            price = qty * finalPrice;
        }
    }
    var setBox = document.getElementById('tp-set-' + productId);
    if (setBox) {
        var setOfEl = setBox.querySelector('.tp-set-of');
        var setOfPriceEl = setBox.querySelector('.tp-set-of-price');
        if (setOfEl) setOfEl.textContent = '<?= $escaper->escapeJs(__('Set of')) ?> ' + qty + ' :';
        if (setOfPriceEl) setOfPriceEl.textContent = formatter.format(price);
    }
    var btnEl = document.getElementById('tp-btn-price-' + productId);
    if (btnEl) btnEl.textContent = Math.round(price).toLocaleString();
}

function topPicksAddToCart(productId) {
    var qtySelect = document.getElementById('tp-qty-' + productId);
    var qty = qtySelect ? parseInt(qtySelect.value) : 4;
    var addUrl = BASE_URL + 'checkout/cart/add/uenc/' + btoa(window.location.href);
    var formKey = typeof hyva !== 'undefined' ? hyva.getFormKey() : '';
    var body = 'form_key=' + formKey + '&product=' + productId + '&qty=' + qty;

    fetch(addUrl, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: body,
        credentials: 'include'
    })
    .then(function(r) { return r.text(); })
    .then(function() {
        window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
        setTimeout(function() {
            window.dispatchEvent(new CustomEvent('toggle-cart', { detail: { isOpen: true } }));
        }, 500);
    })
    .catch(function() { alert('<?= $escaper->escapeJs(__('Error adding to cart. Please try again.')) ?>'); });
}
</script>
