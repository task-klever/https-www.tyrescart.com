<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="klever" translate="label" sortOrder="500">
            <label>Klever</label>
        </tab>
        <section id="klever_vehicle" translate="label" sortOrder="100"
                 showInDefault="1" showInWebsite="1" showInStore="1"
                 type="text">
            <label>Vehicle Tyres Guide</label>
            <tab>klever</tab>
            <resource>Klever_VehicleTyresGuide::config</resource>
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1"
                   type="text">
                <label>General</label>
                <field id="version" translate="label" type="label" sortOrder="1"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Module Version</label>
                    <frontend_model>Klever\VehicleTyresGuide\Block\Adminhtml\System\Config\Version</frontend_model>
                </field>
                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="default_region" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default Region</label>
                    <comment>
                        Region code to filter results automatically per website.
                        Examples: ae (UAE), sa (Saudi Arabia), gb (UK), us (USA).
                        Leave empty to return all regions.
                    </comment>
                </field>
                <field id="cache_ttl" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache TTL (seconds)</label>
                    <comment>
                        How long GraphQL responses are cached. Default: 86400 (24 hours).
                        Vehicle fitment data changes infrequently — high values are safe.
                        Set to 0 to disable caching.
                    </comment>
                    <validate>validate-digits</validate>
                </field>
            </group>
        </section>
    </system>
</config>
