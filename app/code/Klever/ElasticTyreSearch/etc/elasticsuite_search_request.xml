<?xml version="1.0"?>
<requests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="urn:magento:module:Smile_ElasticsuiteCore:etc/elasticsuite_search_request.xsd">

    <!-- Product fulltext search -->
    <request name="klever_product_search"
             label="Klever Product Search"
             index="catalog_product"
             track_total_hits="0"
             fulltext="true">
        <filters>
            <filter name="stockFilter">Smile\ElasticsuiteCatalog\Model\Product\Search\Request\Container\Filter\Stock</filter>
            <filter name="visibleInSearch">Smile\ElasticsuiteCatalog\Model\Product\Search\Request\Container\Filter\VisibleInSearch</filter>
        </filters>
    </request>

    <!-- Brand search -->
    <request name="klever_brand_search"
             label="Klever Brand Search"
             index="klever_brand"
             track_total_hits="0"
             fulltext="true"/>

    <!-- Blog search -->
    <request name="klever_blog_search"
             label="Klever Blog Search"
             index="klever_blog"
             track_total_hits="0"
             fulltext="true"/>

    <!-- Vehicle search -->
    <request name="klever_vehicle_search"
             label="Klever Vehicle Search"
             index="klever_vehicle"
             track_total_hits="0"
             fulltext="true"/>

    <!-- CMS page search -->
    <request name="klever_cms_search"
             label="Klever CMS Search"
             index="klever_cms"
             track_total_hits="0"
             fulltext="true"/>

</requests>
