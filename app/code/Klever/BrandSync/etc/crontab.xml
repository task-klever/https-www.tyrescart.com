<?xml version="1.0"?>
<!-- Cron is disabled by default. Enable via Admin: Stores > Config > Klever > Brand Sync > Enable Cron -->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="klever_brand_sync" instance="Klever\BrandSync\Cron\SyncBrands" method="execute">
            <schedule>0 3 * * *</schedule>
        </job>
    </group>
</config>
