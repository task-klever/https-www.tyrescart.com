<?php
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$scopeConfig = $objectManager->get('Magento\Framework\App\Config\ScopeConfigInterface');
$nofitmentInstallerId = $scopeConfig->getValue('ecomteck_storelocator/installer/no_fitment_installer');
$mobileVanInstallerId = $scopeConfig->getValue('ecomteck_storelocator/installer/mobile_van_installer');

// Load all active stores (non mobile-van, non no-fitment)
$outletStores = $objectManager->create('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
    ->addFieldToFilter('status', ['eq' => '1'])
    ->addFieldToFilter('stores_id', ['neq' => $nofitmentInstallerId])
    ->addFieldToFilter('ismobilevan', ['neq' => '1']);
$outletStores->getSelect()->order('installer_sort_order ASC');

// Load mobile van stores
$mobileVanStores = $objectManager->create('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
    ->addFieldToFilter('status', ['eq' => '1'])
    ->addFieldToFilter('ismobilevan', ['eq' => '1']);
$mobileVanStores->getSelect()->order('installer_sort_order ASC');

// Collect opening hours and scheduling data for all stores
$allStoreOpeningHours = [];
$storeSkipDays = [];
$storeCutoffTime = [];
$storeSkipHours = [];
$storeGoogleMaps = [];

$storeCollectionAll = $objectManager->create('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection');
$storeCollectionAll->addFieldToFilter('status', ['eq' => '1']);

$timezone = $objectManager->get('Magento\Framework\Stdlib\DateTime\TimezoneInterface');
$storeTimezone = $timezone->getConfigTimezone();

$mediaUrl = $objectManager->get('Magento\Store\Model\StoreManagerInterface')->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);
$gmapApiKey = $scopeConfig->getValue('ecomteck_storelocator/map/api_key');

foreach ($storeCollectionAll as $store) {
    $sid = $store->getStoresId();
    $allStoreOpeningHours[$sid] = $store->getOpeningHoursFormated();
    $storeSkipDays[$sid] = $store->getSkipDays() ? (int)$store->getSkipDays() : 0;
    $storeCutoffTime[$sid] = $store->getCutoffTime() ?: '';
    $storeSkipHours[$sid] = $store->getSkipHours() ? (int)$store->getSkipHours() : 0;
    $storeGoogleMaps[$sid] = $store->getGoogleMap() ?: '';
}

// Build unique cities + JSON arrays for Alpine.js
$uniqueCities = [];
$outletStoresJson = [];
foreach ($outletStores as $installer) {
    if ($installer->getCommingSoon()) continue;
    $city = trim($installer->getCity());
    if ($city && !in_array($city, $uniqueCities)) {
        $uniqueCities[] = $city;
    }
    $storeImage = $installer->getImage();
    $imageUrl = ($storeImage) ? $mediaUrl . 'ecomteck_storelocator/stores/image/' . $storeImage : '';
    $outletStoresJson[] = [
        'id'        => (string)$installer->getStoresId(),
        'name'      => $installer->getName(),
        'city'      => $city,
        'address'   => $installer->getAddress(),
        'lat'       => (float)$installer->getLatitude(),
        'lng'       => (float)$installer->getLongitude(),
        'phone'     => $installer->getPhone() ?: '',
        'image'     => $imageUrl,
        'openOne'   => $installer->getOpeningHoursOne() ?: '',
        'openTwo'   => $installer->getOpeningHoursTwo() ?: '',
        'hasMap'    => !empty($installer->getGoogleMap()),
        'shippingAmount' => (float)$installer->getShippingAmount(),
        'distance'  => null,
    ];
}

$mobileVanStoresJson = [];
foreach ($mobileVanStores as $installer) {
    if ($installer->getCommingSoon()) continue;
    $city = trim($installer->getCity());
    if ($city && !in_array($city, $uniqueCities)) {
        $uniqueCities[] = $city;
    }
    $storeImage = $installer->getImage();
    $imageUrl = ($storeImage) ? $mediaUrl . 'ecomteck_storelocator/stores/image/' . $storeImage : '';
    $mobileVanStoresJson[] = [
        'id'        => (string)$installer->getStoresId(),
        'name'      => $installer->getName(),
        'city'      => $city,
        'address'   => $installer->getAddress(),
        'lat'       => (float)$installer->getLatitude(),
        'lng'       => (float)$installer->getLongitude(),
        'phone'     => $installer->getPhone() ?: '',
        'image'     => $imageUrl,
        'openOne'   => $installer->getOpeningHoursOne() ?: '',
        'openTwo'   => $installer->getOpeningHoursTwo() ?: '',
        'hasMap'    => !empty($installer->getGoogleMap()),
        'shippingAmount' => (float)$installer->getShippingAmount(),
        'distance'  => null,
    ];
}
sort($uniqueCities);
?>


