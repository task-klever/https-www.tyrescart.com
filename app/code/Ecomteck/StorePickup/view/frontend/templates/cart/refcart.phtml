<script>
var refcartStoreGoogleMaps = <?php echo json_encode($storeGoogleMaps); ?>;

// Map modal handlers (keep for "See on Map" button)
window.addEventListener('open-map-modal', function(e) {
    var storeId = e.detail.storeId;
    var mapContent = document.getElementById('refcart-map-content');
    mapContent.innerHTML = '<div class="flex flex-col items-center justify-center h-full gap-4"><div class="w-12 h-12 border-4 border-gray-200 border-t-[#00843d] rounded-full animate-spin"></div><p class="text-sm text-gray-500">Loading map...</p></div>';
    document.getElementById('refcart-map-sidebar').classList.remove('translate-y-full');
    document.getElementById('refcart-map-overlay').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    setTimeout(function() {
        if (storeId && refcartStoreGoogleMaps[storeId]) {
            mapContent.innerHTML = refcartStoreGoogleMaps[storeId];
        } else {
            mapContent.innerHTML = '<p style="padding:16px;"><?php echo __("Map not available for this store") ?></p>';
        }
    }, 2000);
});

function closeRefcartMapModal() {
    document.getElementById('refcart-map-sidebar').classList.add('translate-y-full');
    document.getElementById('refcart-map-overlay').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
}

function refcartLocatorApp() {
    return {
        outletStores: <?php echo json_encode($outletStoresJson) ?>,
        mobileVanStores: <?php echo json_encode($mobileVanStoresJson) ?>,
        activeMode: 'normal',
        activeStore: null,
        filterCity: 'all',
        dateError: false,
        timeError: false,
        pickupError: false,
        searchQuery: '',
        showClear: false,
        searchLat: null,
        searchLng: null,
        map: null,
        markers: [],
        infoWindow: null,
        autocomplete: null,
        mobileVanSelectedStore: null,

        get filteredStores() {
            var self = this;
            var source = this.activeMode === 'mobile_van' ? this.mobileVanStores : this.outletStores;
            var filtered = source.slice();
            if (this.filterCity !== 'all') {
                filtered = filtered.filter(function(s) { return s.city === self.filterCity; });
            }
            if (this.searchLat !== null) {
                filtered = filtered.sort(function(a, b) {
                    return (a.distance || 99999) - (b.distance || 99999);
                });
            }
            return filtered;
        },

        switchMode(mode) {
            this.activeMode = mode;
            this.activeStore = null;
            this.filterCity = 'all';
            this.mobileVanSelectedStore = null;
            if (mode === 'normal') {
                var self = this;
                this.$nextTick(function() { self.renderMarkers(); });
            }
        },

        selectMobileVanCity(storeId) {
            var self = this;

            // Reset if empty
            if (!storeId) {
                this.mobileVanSelectedStore = null;
                this.activeStore = null;
                // Reset city dropdown
                var citySelect = document.querySelector('.mobilevan-city-select');
                if (citySelect) citySelect.value = '';
                return;
            }

            // Find the store by ID
            var store = this.mobileVanStores.find(function(s) { return s.id === storeId; });
            if (!store) return;

            this.mobileVanSelectedStore = store;
            this.activeStore = store.id;

            // Scroll to the mobile van card top after selection
            this.$nextTick(function() {
                var card = document.querySelector('.mobilevan-booking-card');
                if (card) {
                    card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });

            // Save selected installer to quote via AJAX
            var params = {
                pickup_store: store.id,
                pickup_type: 'mobile_van',
                form_key: typeof hyva !== 'undefined' ? hyva.getFormKey() : '',
                uenc: btoa(window.location.href)
            };
            fetch(BASE_URL + 'storelocator/ajax/setinstaller', {
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: new URLSearchParams(params),
                method: 'POST',
                mode: 'cors',
                credentials: 'include'
            });

            // After Alpine renders, populate dates and init autocomplete
            this.$nextTick(function() {
                setTimeout(function() {
                    var sel = document.querySelector('.mobilevan-booking-card .refcart-selection');
                    if (sel) {
                        // Populate date dropdown
                        var dateSelect = sel.querySelector('.refcart-date-select');
                        if (dateSelect) {
                            self.populateDates(dateSelect, store.id);
                        }
                        // Reset time
                        var timeSelect = sel.querySelector('.refcart-time-select');
                        if (timeSelect) {
                            timeSelect.innerHTML = '<option value=""><?php echo __("Select Time Slot") ?></option>';
                        }
                        // Init pickup location autocomplete with city geofencing
                        self.initPickupAutocomplete(store);
                    }
                }, 150);
            });
        },

        toggleStore(store) {
            this.dateError = false;
            this.timeError = false;
            this.pickupError = false;
            this.activeStore = (this.activeStore === store.id) ? null : store.id;
            if (this.activeStore && this.activeMode === 'normal') {
                this.panToStore(store);
            }
            // Save selected installer to quote via AJAX + populate date/time
            if (this.activeStore) {
                var self = this;
                var mode = this.activeMode === 'mobile_van' ? 'mobile_van' : 'normal';
                var params = {
                    pickup_store: store.id,
                    pickup_type: mode,
                    form_key: typeof hyva !== 'undefined' ? hyva.getFormKey() : '',
                    uenc: btoa(window.location.href)
                };
                fetch(BASE_URL + 'storelocator/ajax/setinstaller', {
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: new URLSearchParams(params),
                    method: 'POST',
                    mode: 'cors',
                    credentials: 'include'
                });

                // After Alpine renders the expanded panel, populate dates and init autocomplete
                this.$nextTick(function() {
                    var sel = document.querySelector('.refcart-selection[data-store-id="' + store.id + '"]');
                    if (sel) {
                        // Populate date dropdown using refcart-installer.js's generateDateOptions if available
                        var dateSelect = sel.querySelector('.refcart-date-select');
                        if (dateSelect && typeof generateDateOptions === 'function') {
                            dateSelect.innerHTML = generateDateOptions(store.id);
                        } else if (dateSelect) {
                            // Fallback: read from store-opening-hours-data
                            self.populateDates(dateSelect, store.id);
                        }
                        // Reset time
                        var timeSelect = sel.querySelector('.refcart-time-select');
                        if (timeSelect) {
                            timeSelect.innerHTML = '<option value=""><?php echo __("Select Time Slot") ?></option>';
                        }
                    }
                    // Init pickup location autocomplete for mobile van
                    if (self.activeMode === 'mobile_van') {
                        self.initPickupAutocomplete(store);
                    }
                });
            }
        },

        populateDates(dateSelect, storeId) {
            // Read scheduling data from the hidden div
            var dataEl = document.getElementById('store-opening-hours-data');
            if (!dataEl) return;
            var allHours = JSON.parse(dataEl.getAttribute('data-opening-hours') || '{}');
            var skipDays = JSON.parse(dataEl.getAttribute('data-skip-days') || '{}');
            var cutoffTime = JSON.parse(dataEl.getAttribute('data-cutoff-time') || '{}');
            var skipHours = JSON.parse(dataEl.getAttribute('data-skip-hours') || '{}');
            var tz = dataEl.getAttribute('data-store-timezone') || 'Asia/Dubai';

            var now = new Date(new Date().toLocaleString('en-US', { timeZone: tz }));
            var skip = skipDays[storeId] || 0;
            var startDate = new Date(now);
            startDate.setHours(0,0,0,0);
            startDate.setDate(startDate.getDate() + skip);

            var weekdays = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
            var monthNames = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
            var options = '<option value=""><?php echo __("Select a Date") ?></option>';
            var collected = 0;

            for (var i = 0; i < 45 && collected < 15; i++) {
                var date = new Date(startDate);
                date.setDate(startDate.getDate() + i);
                var dayName = weekdays[date.getDay()];
                var dateVal = (date.getMonth()+1) + '/' + date.getDate() + '/' + date.getFullYear();

                if (allHours[storeId] && allHours[storeId][dayName] && allHours[storeId][dayName].length > 0) {
                    var displayText = date.getDate().toString().padStart(2,'0') + '-' + monthNames[date.getMonth()] + '-' + date.getFullYear() + ' (' + dayName + ')';
                    options += '<option value="' + dateVal + '">' + displayText + '</option>';
                    collected++;
                }
            }
            if (collected === 0) {
                options += '<option value="" disabled><?php echo __("No available dates") ?></option>';
            }
            dateSelect.innerHTML = options;
        },

        initPickupAutocomplete(store) {
            var input = document.querySelector('.mobilevan-booking-card .refcart-pickup-location');
            if (!input) return;

            // Clear previous value when switching city
            input.value = '';

            var storeCity = store.city || '';

            // If autocomplete already initialized on this input, just update bounds for new city
            if (input._autocompleteInit && input._autocomplete) {
                if (storeCity) {
                    var geocoder = new google.maps.Geocoder();
                    geocoder.geocode({ address: storeCity + ', UAE' }, function(results, status) {
                        if (status === 'OK' && results[0] && results[0].geometry) {
                            var bounds = results[0].geometry.viewport || results[0].geometry.bounds;
                            if (bounds) {
                                input._autocomplete.setBounds(bounds);
                                input._autocomplete.setOptions({ strictBounds: true });
                            }
                        }
                    });
                }
                return;
            }

            input._autocompleteInit = true;

            var autocomplete = new google.maps.places.Autocomplete(input, {
                componentRestrictions: { country: 'ae' }
            });
            input._autocomplete = autocomplete;

            // Restrict to store's city bounds
            if (storeCity) {
                var geocoder = new google.maps.Geocoder();
                geocoder.geocode({ address: storeCity + ', UAE' }, function(results, status) {
                    if (status === 'OK' && results[0] && results[0].geometry) {
                        var bounds = results[0].geometry.viewport || results[0].geometry.bounds;
                        if (bounds) {
                            autocomplete.setBounds(bounds);
                            autocomplete.setOptions({ strictBounds: true });
                        }
                    }
                });
            }

            autocomplete.addListener('place_changed', function() {
                var errorEl = input.closest('.refcart-selection');
                if (errorEl) {
                    var errMsg = errorEl.querySelector('.refcart-pickup-error');
                    if (errMsg) errMsg.classList.add('hidden');
                }
            });
        },

        initComponent() {
            var self = this;
            var tryInit = function() {
                if (typeof google === 'undefined' || !google.maps) {
                    setTimeout(tryInit, 300);
                    return;
                }
                self.initMap();
                self.initAutocomplete();
            };
            tryInit();
        },

        initMap() {
            var mapEl = document.getElementById('refcart-map');
            if (!mapEl) return;
            this.map = new google.maps.Map(mapEl, {
                center: { lat: 24.4539, lng: 54.3773 },
                zoom: 7,
                mapTypeControl: true,
                streetViewControl: false,
                fullscreenControl: true,
            });
            this.infoWindow = new google.maps.InfoWindow();
            this.renderMarkers();
        },

        initAutocomplete() {
            var self = this;
            var input = document.getElementById('refcart-search-input');
            if (!input) return;
            this.autocomplete = new google.maps.places.Autocomplete(input, {
                componentRestrictions: { country: 'ae' }
            });
            this.autocomplete.addListener('place_changed', function() {
                var place = self.autocomplete.getPlace();
                if (place && place.geometry) {
                    self.searchLat = place.geometry.location.lat();
                    self.searchLng = place.geometry.location.lng();
                    self.showClear = true;
                    self.searchQuery = input.value;
                    self._doDistanceCalc();
                }
            });
        },

        renderMarkers() {
            var self = this;
            this.markers.forEach(function(m) { m.setMap(null); });
            this.markers = [];
            if (!this.map || this.activeMode !== 'normal') return;

            var bounds = new google.maps.LatLngBounds();
            this.filteredStores.forEach(function(store) {
                if (!store.lat || !store.lng) return;
                var marker = new google.maps.Marker({
                    position: { lat: store.lat, lng: store.lng },
                    map: self.map,
                    title: store.name,
                });
                marker.storeId = store.id;
                marker.addListener('click', function() {
                    self.infoWindow.setContent(
                        '<div style="max-width:220px"><strong style="color:#003320">' + store.name + '</strong><br><span style="font-size:12px;color:#666">' + store.address + '</span></div>'
                    );
                    self.infoWindow.open(self.map, marker);
                    self.activeStore = store.id;
                });
                self.markers.push(marker);
                bounds.extend(marker.getPosition());
            });

            if (this.markers.length > 0) {
                this.map.fitBounds(bounds);
                if (this.markers.length === 1) this.map.setZoom(14);
            }
        },

        panToStore(store) {
            if (!this.map || !store.lat || !store.lng) return;
            this.map.panTo({ lat: store.lat, lng: store.lng });
            this.map.setZoom(14);
            var self = this;
            var marker = this.markers.find(function(m) { return m.storeId === store.id; });
            if (marker) {
                this.infoWindow.setContent(
                    '<div style="max-width:220px"><strong style="color:#003320">' + store.name + '</strong><br><span style="font-size:12px;color:#666">' + store.address + '</span></div>'
                );
                this.infoWindow.open(this.map, marker);
            }
        },

        performSearch() {
            var self = this;
            var inputVal = document.getElementById('refcart-search-input').value.trim();

            if (this.searchLat !== null && this.searchLng !== null) {
                this._doDistanceCalc();
                return;
            }

            if (!inputVal) return;
            var geocoder = new google.maps.Geocoder();
            geocoder.geocode({ address: inputVal + ', UAE' }, function(results, status) {
                if (status === 'OK' && results[0] && results[0].geometry) {
                    self.searchLat = results[0].geometry.location.lat();
                    self.searchLng = results[0].geometry.location.lng();
                    self.showClear = true;
                    self._doDistanceCalc();
                }
            });
        },

        _doDistanceCalc() {
            var self = this;
            var origin = new google.maps.LatLng(this.searchLat, this.searchLng);

            // Create new arrays to trigger Alpine reactivity
            this.outletStores = this.outletStores.map(function(store) {
                var s = Object.assign({}, store);
                if (!s.lat || !s.lng) { s.distance = null; return s; }
                var dest = new google.maps.LatLng(s.lat, s.lng);
                s.distance = parseFloat(
                    (google.maps.geometry.spherical.computeDistanceBetween(origin, dest) / 1000).toFixed(2)
                );
                return s;
            });
            this.mobileVanStores = this.mobileVanStores.map(function(store) {
                var s = Object.assign({}, store);
                if (!s.lat || !s.lng) { s.distance = null; return s; }
                var dest = new google.maps.LatLng(s.lat, s.lng);
                s.distance = parseFloat(
                    (google.maps.geometry.spherical.computeDistanceBetween(origin, dest) / 1000).toFixed(2)
                );
                return s;
            });

            this.renderMarkers();
            if (this.map) {
                this.map.panTo({ lat: this.searchLat, lng: this.searchLng });
                this.map.setZoom(10);
            }
        },

        useMyLocation() {
            if (!navigator.geolocation) { alert('Geolocation is not supported.'); return; }
            var self = this;
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    self.searchLat = pos.coords.latitude;
                    self.searchLng = pos.coords.longitude;
                    var geocoder = new google.maps.Geocoder();
                    geocoder.geocode({ location: { lat: self.searchLat, lng: self.searchLng } }, function(results, status) {
                        if (status === 'OK' && results[0]) {
                            self.searchQuery = results[0].formatted_address;
                            document.getElementById('refcart-search-input').value = self.searchQuery;
                        }
                        self.performSearch();
                    });
                },
                function() { alert('Could not get your location. Please enable location access.'); }
            );
        },

        clearSearch() {
            this.searchQuery = '';
            this.showClear = false;
            this.searchLat = null;
            this.searchLng = null;
            document.getElementById('refcart-search-input').value = '';
            this.outletStores = this.outletStores.map(function(s) { return Object.assign({}, s, { distance: null }); });
            this.mobileVanStores = this.mobileVanStores.map(function(s) { return Object.assign({}, s, { distance: null }); });
            this.renderMarkers();
        },

        doValidateCheckout() { /* moved to global scope */ }
    };
}

document.addEventListener('click', function(e) {
    var btn = e.target.closest('.refcart-validate-checkout');
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();

    var sel = btn.closest('.refcart-selection');
    if (!sel) return;

    var valid = true;

    var errStyle = 'color:#ef4444; font-size:12px; margin-top:4px; display:block;';

    // Remove any previous error messages
    sel.querySelectorAll('.field-error-msg').forEach(function(el) { el.remove(); });

    // Fitting Location (mobile van)
    var pickupEl = sel.querySelector('.refcart-pickup-location');
    if (pickupEl && !pickupEl.value.trim()) {
        var err = document.createElement('div');
        err.className = 'field-error-msg';
        err.setAttribute('style', errStyle);
        err.textContent = 'This is a required field.';
        pickupEl.parentNode.appendChild(err);
        valid = false;
    }

    // Pickup Date
    var dateEl = sel.querySelector('.refcart-date-select');
    if (!dateEl || !dateEl.value) {
        var err = document.createElement('div');
        err.className = 'field-error-msg';
        err.setAttribute('style', errStyle);
        err.textContent = 'This is a required field.';
        dateEl.parentNode.appendChild(err);
        valid = false;
    }

    // Pickup Time
    var timeEl = sel.querySelector('.refcart-time-select');
    if (!timeEl || !timeEl.value) {
        var err = document.createElement('div');
        err.className = 'field-error-msg';
        err.setAttribute('style', errStyle);
        err.textContent = 'This is a required field.';
        timeEl.parentNode.appendChild(err);
        valid = false;
    }

    if (valid) {
        // Save all fields (including pickup_location) before redirecting to checkout
        var storeId = btn.getAttribute('data-store-id') || (sel.getAttribute('data-store-id') || '');
        var mode = 'normal';
        var modeBtn = document.querySelector('.refcart-page button.bg-theme-blue');
        if (modeBtn) {
            var text = modeBtn.textContent.trim();
            if (text.indexOf('Mobile Van') !== -1) mode = 'mobile_van';
        }
        var saveParams = {
            pickup_store: storeId,
            pickup_type: mode,
            pickup_date: dateEl ? dateEl.value : '',
            pickup_time: timeEl ? timeEl.value : '',
            form_key: typeof hyva !== 'undefined' ? hyva.getFormKey() : '',
            uenc: btoa(window.location.href)
        };
        if (pickupEl && pickupEl.value.trim()) {
            saveParams.pickup_location = pickupEl.value.trim();
        }
        fetch(BASE_URL + 'storelocator/ajax/setinstaller', {
            headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: new URLSearchParams(saveParams),
            method: 'POST',
            mode: 'cors',
            credentials: 'include'
        }).then(function() {
            window.location.href = BASE_URL + 'checkout?_=' + Date.now();
        }).catch(function() {
            window.location.href = BASE_URL + 'checkout?_=' + Date.now();
        });
    } else {
        // Scroll first visible error into view
        var firstErr = sel.querySelector('.refcart-pickup-error, .refcart-date-error, .refcart-time-error');
        if (firstErr && firstErr.style.display === 'block') {
            firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    }
}, true);
</script>

