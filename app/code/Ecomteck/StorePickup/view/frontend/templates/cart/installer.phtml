<script>
    var storeGoogleMaps = {};
    var storeCities = {};

    function openInstallerMapModal() {
        var select = document.getElementById('installer-locations');
        var storeId = select.value;
        var mapContent = document.getElementById('installer-map-content');

        if (storeId && storeGoogleMaps[storeId]) {
            mapContent.innerHTML = storeGoogleMaps[storeId];
        } else {
            mapContent.innerHTML = '<p><?php echo __("Map not available for this store") ?></p>';
        }

        document.getElementById('installer-map-sidebar').classList.remove('translate-x-full');
        document.getElementById('installer-map-overlay').classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
    }

    function closeInstallerMapModal() {
        document.getElementById('installer-map-sidebar').classList.add('translate-x-full');
        document.getElementById('installer-map-overlay').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
    }
</script>

