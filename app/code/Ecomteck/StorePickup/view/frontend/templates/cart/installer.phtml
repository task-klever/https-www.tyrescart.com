<?php
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$nofitmentInstallerId = $objectManager->get('Magento\Framework\App\Config\ScopeConfigInterface')->getValue('ecomteck_storelocator/installer/mobile_van_installer');
$mobileVanfittingInstallerId = $objectManager->get('Magento\Framework\App\Config\ScopeConfigInterface')->getValue('ecomteck_storelocator/installer/no_fitment_installer');
$installerList = [];
$installerList = $objectManager->get('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
        ->addFieldToFilter('status', ['eq' => '1'])
        ->addFieldToFilter('stores_id', ['neq' => $nofitmentInstallerId])
        ->addFieldToFilter('stores_id', ['neq' => $mobileVanfittingInstallerId]);
$installerList->getSelect()->order('installer_sort_order DESC');

$allStoreOpeningHours = [];
$storeSkipDays = [];
$storeCutoffTime = [];
$storeSkipHours = [];

$storeCollectionFactory = $objectManager->get('Ecomteck\StoreLocator\Model\ResourceModel\Stores\CollectionFactory');
$storeCollection = $storeCollectionFactory->create();
$storeCollection->addActiveFilter();

$timezone = $objectManager->get('Magento\Framework\Stdlib\DateTime\TimezoneInterface');
$storeTimezone = $timezone->getConfigTimezone();

foreach ($storeCollection as $key => $store) {
    $opening_hours = $store->getOpeningHoursFormated();
    $allStoreOpeningHours[$store->getStoresId()] = $opening_hours;
    $storeSkipDays[$store->getStoresId()] = $store->getSkipDays() ? (int)$store->getSkipDays() : 0;
    $storeCutoffTime[$store->getStoresId()] = $store->getCutoffTime() ?: '';
    $storeSkipHours[$store->getStoresId()] = $store->getSkipHours() ? (int)$store->getSkipHours() : 0;
}



