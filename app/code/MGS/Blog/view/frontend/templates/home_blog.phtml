                              </span>
                           </div>
                        </div>
                        <div class="blog-blog-info p-4">
                              <h6 class="mb-2 text-sm">
                                 <a href="<?php echo $this->getBaseUrl() .'blog/'.$post['url_key']; ?>" class="text-ellipsis line-clamp-2 text-black hover:text-theme-blue transition ease-out font-bold uppercase"><?php echo $postTitle; ?></a>
                              </h6>
                              <div class="flex items-center gap-2 my-2 [html[lang='ar']_&]:flex-row-reverse">
                                 <div class="h-[2px] w-6 rounded-full bg-theme-blue"></div>
