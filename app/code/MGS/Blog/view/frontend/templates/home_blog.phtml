               <?php
                  $storeOverrides = $block->getPostByStore($currentStoreId, $post['post_id']);
                  $postTitle = isset($storeOverrides['title']) ? $storeOverrides['title']['value'] : $post['title'];
                  $postShortContent = isset($storeOverrides['short_content']) ? $storeOverrides['short_content']['value'] : $post['short_content'];
               ?>
               <div class="swiper-slide">
                  <div class="flex items-end justify-center shrink-0 w-full js_slide">
                     <div class="slide w-full overflow-hidden border bg-[#f5f5f5] border-[#e1e1e1] rounded-[10px]">
                        <div class="blog-image relative">
                           <div class="img_wrp w-full pb-full h-0 z-0 bg-gray-200 pb-[56%]">
                              <figure class="absolute inset-0 ">
                                 <picture>
                                    <source srcset="<?php echo $mediaUrl . 'mgs_blog/'.$post['thumbnail']; ?>" loading="lazy" alt="social image" title="Blog Image" type="image/jpg">
                                    <source srcset="<?php echo $mediaUrl . 'mgs_blog/'.$post['thumbnail']; ?>" loading="lazy" alt="Blog Image" title="Blog Image" type="image/jpg">
                                    <img class="w-full h-full object-cover object-top overflow-hidden" src="<?php echo $mediaUrl . 'mgs_blog/'.$post['thumbnail']; ?>" alt="<?php echo $post['title']; ?>" loading="lazy">
                                 </picture>
                              </figure>
                           </div>
                           <div class="absolute top-2 left-2 z-10">
                              <span class="inline-block bg-white/90 backdrop-blur-sm text-[#222] text-xs font-semibold px-3 py-1.5 rounded-lg shadow-sm">
