<script>
   document.addEventListener('DOMContentLoaded', function () {
    const marquee = document.getElementById('vehicle-marquee3');
    // Duplicate content for infinite scroll effect
    marquee.innerHTML += marquee.innerHTML;
    let scrollAmount = 0;
    const speed = 1;
    let reqId;
    function loop() {
      scrollAmount += speed;
      if (scrollAmount >= marquee.scrollWidth / 2) {
        scrollAmount = 0; // Reset when half is scrolled (1 set worth)
      }
      marquee.style.transform = `translateX(-${scrollAmount}px)`;
      reqId = requestAnimationFrame(loop);
    }
    marquee.addEventListener('mouseenter', () => cancelAnimationFrame(reqId));
    marquee.addEventListener('mouseleave', () => loop());
    loop();
   });


   document.addEventListener('DOMContentLoaded', function () {
    const marquee = document.getElementById('vehicle-marquee4');
    // Duplicate content for seamless scroll
    marquee.innerHTML += marquee.innerHTML;
    const halfWidth = marquee.scrollWidth / 2;
    let scrollAmount = -halfWidth; // 👈 Start from left of second half
    const speed = 1;
    let reqId;
    function loop() {
      scrollAmount += speed; // 👈 Move right
      if (scrollAmount >= 0) {
        scrollAmount = -halfWidth; // 👈 Reset to start from left again
      }
      marquee.style.transform = `translateX(${scrollAmount}px)`;
      reqId = requestAnimationFrame(loop);
    }
    marquee.addEventListener('mouseenter', () => cancelAnimationFrame(reqId));
    marquee.addEventListener('mouseleave', () => loop());
    loop(); // Start loop
   });
   
</script> 
<style>
   #vehicle-marquee3 {
   transition: transform 0s linear;
   white-space: nowrap;
   }
   #vehicle-marquee4 {
   transition: transform 0s linear;
   white-space: nowrap;
   }
</style>