<?php
/** @var \Magento\Framework\View\Element\Template $block */
$brandDataHelper = $this->helper('MGS\Brand\Helper\Data');
$brandCollection = $block->getCollection();
$baseUrl = $block->getBaseUrl();
$mediaUrl = $brandDataHelper->getBaseMediaUrl();
$brandRoute = $brandDataHelper->getBrandRoute();
$brandsData = [];
$availableLetters = [];
$urlKeys = [];
foreach ($brandCollection as $brand) {
    $name = trim($brand->getName());
    if (!$name) {
        continue; 
    }
    $urlKey = $brand->getUrlKey();
    if (!$urlKey) {
        $urlKey = strtolower(preg_replace('/[^a-z0-9]+/', '-', $name));
        $urlKey = trim($urlKey, '-');
    }
    $originalUrlKey = $urlKey;
    $i = 1;
    while (in_array($urlKey, $urlKeys)) {
        $urlKey = $originalUrlKey . '-' . $i;
        $i++;
    }
    $urlKeys[] = $urlKey;
    $firstLetter = strtoupper(substr($name, 0, 1));
    if (!in_array($firstLetter, $availableLetters)) {
        $availableLetters[] = $firstLetter;
    }
    $brandsData[] = [
        'name' => $name,
        'urlKey' => $urlKey,
        'image' => $brand->getImage() ? $mediaUrl . $brand->getImage() : '',
        'firstLetter' => $firstLetter,
        'category' => $brand->getBrandCategory(),
    ];
}
sort($availableLetters);
?>
<div x-data="brandFilter()" class="section section-padding all-brands-section">
   <?php if (!empty($brandsData)): ?>
