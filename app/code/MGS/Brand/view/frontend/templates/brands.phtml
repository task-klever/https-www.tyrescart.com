                  :class="activeCategory === 'Battery' ? 'text-white' : 'text-white'"
              >
                  <?php echo __('Battery') ?>
              </button>
          </div>
      </div>
   <div class="keyword-filter">
      <div class="relative alphabet-filter mt-3.5 md:mt-6 mb-0 md:mb-3">
         <div class="flex gap-1 md:gap-2 overflow-x-auto scrollbar-hide pb-2 md:flex-wrap md:justify-center md:overflow-visible md:pb-0" style="scrollbar-width: none; -ms-overflow-style: none;">
            <button 
