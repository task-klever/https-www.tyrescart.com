         <h3><?php echo __('All') ?> <span class="text-theme-blue"><?php echo __('Brands') ?></span></h3>
      </div>
      <div class="flex justify-center items-center mt-4">
          <div class="relative flex w-[13rem] md:w-[16rem] h-12 bg-black rounded-full shadow-lg">
