<script>
function brandFilter() {
    return {
        searchTerm: '',
        activeLetter: 'all',
        activeCategory: 'Tyres', // default tab
        availableLetters: <?= json_encode($availableLetters ?: []) ?>,
        brands: <?= json_encode($brandsData ?: []) ?>,
        get filtered() {
            if (!this.brands || !Array.isArray(this.brands)) {
                return [];
            }
            return this.brands.filter(brand => {
                // FIXED: Check if brand.category exists and matches the active category
                const matchesCategory = this.activeCategory === 'all' || 
                                      (brand.category && brand.category === this.activeCategory);
                const matchesSearch = this.searchTerm === '' ||
                    brand.name.toLowerCase().includes(this.searchTerm.toLowerCase());
                const matchesLetter = this.activeLetter === 'all' ||
                    brand.firstLetter === this.activeLetter;
                return matchesCategory && matchesSearch && matchesLetter;
            });
        },
        centerActiveButton(event) {
            setTimeout(() => {
                const button = event.target.closest('button');
                const buttonContainer = button.closest('.overflow-x-auto');
                if (!buttonContainer || !button) return;
                const buttonRect = button.getBoundingClientRect();
                const containerRect = buttonContainer.getBoundingClientRect();
                const scrollLeft = buttonContainer.scrollLeft;
                const buttonCenter = buttonRect.left - containerRect.left + (buttonRect.width / 2) + scrollLeft;
                const containerCenter = containerRect.width / 2;
                const scrollTo = buttonCenter - containerCenter;
                buttonContainer.scrollTo({ left: Math.max(0, scrollTo), behavior: 'smooth' });
            }, 50);
        }
    }
}
</script>
