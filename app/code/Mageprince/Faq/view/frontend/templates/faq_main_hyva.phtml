        <script>
            function mageprinceFaq(config) {
                return {
                    ajaxUrl: config.ajaxUrl,
                    loading: false,
                    pageType: config.pageType,
                    pageTypeScroll: config.pageTypeScroll,
                    selectGroup(groupId, targetSelector) {
                        if (this.pageType === this.pageTypeScroll) {
                            this.scrollTo(targetSelector);
                            return;
                        }

                        this.loading = true;
                        const formKey = window.hyva && typeof window.hyva.getFormKey === 'function'
                            ? window.hyva.getFormKey()
                            : (window.FORM_KEY || '');
                        const body = new URLSearchParams({groupId: groupId, hyva: '1'});
                        if (formKey) {
                            body.append('form_key', formKey);
                        }

                        fetch(this.ajaxUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: body
                        })
                            .then((response) => response.json())
                            .then((response) => {
                                this.$refs.content.innerHTML = response.faq || '';
                                this.$nextTick(() => {
                                    if (window.Alpine) Alpine.initTree(this.$refs.content);
                                    this.scrollTo(targetSelector);
                                });
                            })
                            .finally(() => {
                                this.loading = false;
                            });
                    },
                    scrollTo(targetSelector) {
                        const target = document.querySelector(targetSelector);
                        if (target) {
                            target.scrollIntoView({behavior: 'smooth', block: 'start'});
                        }
                    }
                };
            }
        </script>
