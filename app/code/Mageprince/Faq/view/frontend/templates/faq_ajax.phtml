<?php
/** @var $block \Mageprince\Faq\Block\Index\Index */
$faqCollection = $block->getFaqCollection($block->getGroupId());
$group = $block->getGroupById($block->getGroupId());
?>
<div id="group<?= $block->escapeHtmlAttr($group->getFaqGroupId()); ?>" x-data="{ openFaq: null }">
    <?php if ($block->isShowGroupTitle()): ?>
        <div class="faq-title mb-5 pb-3 border-b">
            <h3 class="text-xl md:text-2xl block-title"><?= $block->escapeHtml(__($group->getGroupName())); ?></h3>
        </div>
    <?php endif; ?>
    <div class="rounded-[10px] shadow-custom-blue bg-gradient-to-br from-[#e0fff6]/60 via-white to-[#d1f7ec]/60 px-3 md:px-8 lg:px-10 py-1.5 md:py-4 lg:py-5 w-full border border-color">
        <div class="divide-y divide-theme-blue/30">
            <?php if ($faqCollection->getSize()): ?>
                <?php foreach ($faqCollection as $faq): ?>
                    <div class="py-2 md:py-4">
                        <button
                            type="button"
                            @click="openFaq = openFaq === <?= (int)$faq->getFaqId() ?> ? null : <?= (int)$faq->getFaqId() ?>"
                            :aria-expanded="openFaq === <?= (int)$faq->getFaqId() ?> ? 'true' : 'false'"
                            class="flex w-full items-center justify-between cursor-pointer font-medium text-base md:text-lg text-black transition text-left"
                            :class="{ 'text-theme-blue': openFaq === <?= (int)$faq->getFaqId() ?> }"
                        >
                            <span><?= $block->escapeHtml(__($faq->getTitle())); ?></span>
                            <span class="ml-2 flex-shrink-0 transition-transform duration-300" :class="{ 'rotate-180': openFaq === <?= (int)$faq->getFaqId() ?> }">
                                <svg class="w-5 h-5 text-theme-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </span>
                        </button>
                        <div
                            x-ref="faq<?= (int)$faq->getFaqId() ?>"
                            class="overflow-hidden transition-all duration-300 ease-in-out"
                            :style="openFaq === <?= (int)$faq->getFaqId() ?> ? `max-height: ${$refs['faq<?= (int)$faq->getFaqId() ?>'].scrollHeight}px` : 'max-height: 0px'"
                        >
                            <div class="mt-3 text-theme-dark/80 text-base pl-1 pb-1">
                                <?= /* @noEscape */ $block->filterOutputHtml($faq->getContent()); ?>
                            </div>
                        </div>
                    </div>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>
    </div>
</div>
