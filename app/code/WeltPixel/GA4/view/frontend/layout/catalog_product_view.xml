<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block
                ifconfig="weltpixel_ga4/serverside_measurement/enable"
                class="Magento\Catalog\Block\Product\View"
                name="weltpixel-ga4-server-view_item"
                template="WeltPixel_GA4::serverside/product/view.phtml"
            />
            <!-- Meta Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_meta_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Product\View"
                name="weltpixel_ga4_metapixel_view_content"
                template="WeltPixel_GA4::metapixel/view_content.phtml"
            />
            <!-- Meta Pixel Tracking -->
            <!-- Reddit Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_reddit_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Product\View"
                name="weltpixel_ga4_redditpixel_view_content"
                template="WeltPixel_GA4::redditpixel/view_content.phtml"
            />
            <!-- Reddit Pixel Tracking -->
            <!-- Tiktok Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_tiktok_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Product\View"
                name="weltpixel_ga4_tiktokpixel_view_content"
                template="WeltPixel_GA4::tiktokpixel/view_content.phtml"
            />
            <!-- Tiktok Pixel Tracking -->
        </referenceContainer>
    </body>
</page>
