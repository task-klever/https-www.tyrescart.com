<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block
                ifconfig="weltpixel_ga4/serverside_measurement/enable"
                class="Magento\Framework\View\Element\Template"
                name="weltpixel-ga4-server-search"
                template="WeltPixel_GA4::serverside/search.phtml"
            />
            <!-- Meta Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_meta_pixel/general_tracking/enable"
                class="WeltPixel\GA4\Block\MetaPixel\Common"
                name="weltpixel_ga4_metapixel_search"
                template="WeltPixel_GA4::metapixel/search.phtml"
            />
            <!-- Meta Pixel Tracking -->
            <!-- Reddit Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_reddit_pixel/general_tracking/enable"
                class="WeltPixel\GA4\Block\RedditPixel\Common"
                name="weltpixel_ga4_redditpixel_search"
                template="WeltPixel_GA4::redditpixel/search.phtml"
            />
            <!-- Reddit Pixel Tracking -->
            <!-- Tiktok Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_tiktok_pixel/general_tracking/enable"
                class="WeltPixel\GA4\Block\TiktokPixel\Common"
                name="weltpixel_ga4_tiktokpixel_search"
                template="WeltPixel_GA4::tiktokpixel/search.phtml"
            />
            <!-- Tiktok Pixel Tracking -->
        </referenceContainer>
    </body>
</page>
