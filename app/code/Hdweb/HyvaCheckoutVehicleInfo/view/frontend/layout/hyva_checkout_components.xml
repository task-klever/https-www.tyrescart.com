<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <referenceBlock name="hyva.checkout.components">
            <container name="checkout.vehicle-details.section" htmlTag="section" htmlId="vehicle-details">
                <block name="checkout.vehicle-details.title" template="Hyva_Checkout::section/title.phtml" before="-">
                    <action method="setTitle">
                        <argument name="title" translate="true" xsi:type="string">Vehicle Information</argument>
                    </action>
                </block>
                <block class="Hdweb\HyvaCheckoutVehicleInfo\Block\CheckoutVehicleInfo" name="checkout.vehicle-information" template="Hdweb_HyvaCheckoutVehicleInfo::checkout/vehicle-information.phtml">
                </block>
            </container>
        </referenceBlock>
    </body>
</page>
