<script type="text/javascript">
    function confirmDeletePo() {
        require(['Magento_Ui/js/modal/confirm'], function(confirm) {
            confirm({
                title: 'Delete Purchase Order',
                content: 'Are you sure you want to delete this Purchase Order?',
                actions: {
                    confirm: function() {
                        var form = document.getElementById('po_edit_form');
                        var input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'submit';
                        input.value = 'delete';
                        form.appendChild(input);
                        HTMLFormElement.prototype.submit.call(form);
                    },
                    cancel: function() {}
                }
            });
        });
    }
