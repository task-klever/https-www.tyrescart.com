<!-- Fallback JS if Alpine isn't loaded -->
<script>
document.addEventListener('DOMContentLoaded', function () {
  if (typeof Alpine === 'undefined') {
    // hide all contents initially
    document.querySelectorAll('.accordion-content-fallback').forEach(function(c){ c.style.display = 'none'; });

    document.querySelectorAll('.js-accordion-title').forEach(function(btn){
      btn.addEventListener('click', function () {
        // next sibling is the content div
        var content = btn.nextElementSibling;
        if (!content) return;
        var isOpen = content.style.display === 'block';
        // close others
        document.querySelectorAll('.accordion-content-fallback').forEach(function(cc){ cc.style.display = 'none'; });
        document.querySelectorAll('.js-accordion-title').forEach(function(b){ b.setAttribute('aria-expanded','false'); });
        if (!isOpen) {
          content.style.display = 'block';
          btn.setAttribute('aria-expanded','true');
        } else {
          content.style.display = 'none';
          btn.setAttribute('aria-expanded','false');
        }
      });
    });
  }
});
</script>
