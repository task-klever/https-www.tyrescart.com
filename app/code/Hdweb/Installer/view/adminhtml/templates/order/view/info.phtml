<!-- Delivery edit: store hours data + JS for date/time population -->
<script>
var deliveryStoreHours = <?php echo json_encode($deliveryStoreHours) ?>;
var deliveryStoreSkipDays = <?php echo json_encode($deliveryStoreSkipDays) ?>;
var deliveryStoreCutoffTime = <?php echo json_encode($deliveryStoreCutoffTime) ?>;
var deliveryStoreSkipHours = <?php echo json_encode($deliveryStoreSkipHours) ?>;
var deliveryTimezone = '<?php echo $deliveryTimezone ?>';

(function() {
    function getNow() {
        var nowStr = new Date().toLocaleString('en-US', { timeZone: deliveryTimezone });
        return new Date(nowStr);
    }

    function timeToMinutes(timeStr) {
        var parts = timeStr.trim().split(' ');
        var time = parts[0];
        var modifier = parts[1];
        var tp = time.split(':');
        var h = parseInt(tp[0], 10);
        var m = parseInt(tp[1], 10);
        if (modifier === 'PM' && h !== 12) h += 12;
        if (modifier === 'AM' && h === 12) h = 0;
        return h * 60 + m;
    }

    function time24ToMinutes(t) {
        if (!t) return 0;
        var p = t.split(':');
        return parseInt(p[0], 10) * 60 + parseInt(p[1], 10);
    }

    function getTimeSlots(storeId, selectedDate) {
        var weekdays = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
        var dateObj = new Date(selectedDate);
        var dayName = weekdays[dateObj.getDay()];
        if (!deliveryStoreHours[storeId] || !deliveryStoreHours[storeId][dayName]) return [];
        var slots = deliveryStoreHours[storeId][dayName];
        if (!slots || slots.length === 0) return [];

        var skipDays = deliveryStoreSkipDays[storeId] || 0;
        var now = getNow();
        var todayStr = (now.getMonth()+1) + '/' + now.getDate() + '/' + now.getFullYear();
        var isToday = (selectedDate === todayStr);

        if (skipDays === 0 && isToday) {
            var currentMinutes = now.getHours() * 60 + now.getMinutes();
            var cutoff = deliveryStoreCutoffTime[storeId] || '';
            if (cutoff && currentMinutes >= time24ToMinutes(cutoff)) return [];
            var skipHrs = deliveryStoreSkipHours[storeId] || 0;
            var earliest = currentMinutes + (skipHrs * 60);
            return slots.filter(function(slot) {
                return timeToMinutes(slot.split('-')[0].trim()) >= earliest;
            });
        }
        return slots.slice();
    }

    function populateDeliveryDates(storeId) {
        var dateSelect = document.getElementById('delivery_date_select');
        var timeSelect = document.getElementById('delivery_time_select');
        if (!dateSelect) return;

        dateSelect.innerHTML = '<option value="">-- Select Date --</option>';
        timeSelect.innerHTML = '<option value="">-- Select Time --</option>';

        if (!storeId || !deliveryStoreHours[storeId]) return;

        var now = getNow();
        var skipDays = deliveryStoreSkipDays[storeId] || 0;
        var startDate = new Date(now);
        startDate.setHours(0,0,0,0);
        startDate.setDate(startDate.getDate() + skipDays);

        var monthNames = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
        var collected = 0;
        for (var i = 0; i < 45 && collected < 15; i++) {
            var date = new Date(startDate);
            date.setDate(startDate.getDate() + i);
            var dateVal = (date.getMonth()+1) + '/' + date.getDate() + '/' + date.getFullYear();
            var slots = getTimeSlots(storeId, dateVal);
            if (slots.length > 0) {
                var display = date.getDate().toString().padStart(2,'0') + '-' + monthNames[date.getMonth()] + '-' + date.getFullYear();
                var opt = document.createElement('option');
                opt.value = dateVal;
                opt.textContent = display;
                dateSelect.appendChild(opt);
                collected++;
            }
        }
        if (collected === 0) {
            var opt = document.createElement('option');
            opt.value = '';
            opt.textContent = 'No available dates';
            opt.disabled = true;
            dateSelect.appendChild(opt);
        }
    }

    function populateDeliveryTimes(storeId, dateVal) {
        var timeSelect = document.getElementById('delivery_time_select');
        if (!timeSelect) return;
        timeSelect.innerHTML = '<option value="">-- Select Time --</option>';
        if (!storeId || !dateVal) return;

        var slots = getTimeSlots(storeId, dateVal);
        slots.forEach(function(slot) {
            var opt = document.createElement('option');
            opt.value = slot;
            opt.textContent = slot;
            timeSelect.appendChild(opt);
        });
        if (slots.length === 0) {
            var opt = document.createElement('option');
            opt.value = '';
            opt.textContent = 'No time slots available';
            opt.disabled = true;
            timeSelect.appendChild(opt);
        }
    }

    // Wait for DOM
    document.addEventListener('DOMContentLoaded', function() {
        var installerSelect = document.getElementById('delivery_installer_select');
        var dateSelect = document.getElementById('delivery_date_select');

        if (installerSelect) {
            installerSelect.addEventListener('change', function() {
                populateDeliveryDates(this.value);
                // Show/hide fitting location based on mobile van
                var selectedOption = this.options[this.selectedIndex];
                var isMobileVan = selectedOption ? selectedOption.getAttribute('data-ismobilevan') === '1' : false;
                var fittingWrap = document.getElementById('delivery_fitting_location_wrap');
                if (fittingWrap) {
                    fittingWrap.style.display = isMobileVan ? 'block' : 'none';
                }
            });
        }
        if (dateSelect) {
            dateSelect.addEventListener('change', function() {
                var storeId = installerSelect ? installerSelect.value : '';
                populateDeliveryTimes(storeId, this.value);
            });
        }
    });
})();
</script>

<!-- Google Maps Places for Fitting Location autocomplete -->
