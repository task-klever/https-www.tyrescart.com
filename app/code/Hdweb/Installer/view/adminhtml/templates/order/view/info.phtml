<script>
function initDeliveryPlacesAutocomplete() {
    var input = document.getElementById('delivery_pickup_location_input');
    if (!input || input._autocompleteInit) return;
    input._autocompleteInit = true;
    var autocomplete = new google.maps.places.Autocomplete(input, {
        componentRestrictions: { country: 'ae' }
    });
}
// Init when Maps API is ready
function onDeliveryMapsReady() {
    initDeliveryPlacesAutocomplete();
    // Also re-init when fitting location becomes visible (installer change)
    var installerSel = document.getElementById('delivery_installer_select');
    if (installerSel) {
        installerSel.addEventListener('change', function() {
            setTimeout(initDeliveryPlacesAutocomplete, 200);
        });
    }
}
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=<?php echo $gmapApiKey; ?>&libraries=places&callback=onDeliveryMapsReady" async defer></script>

