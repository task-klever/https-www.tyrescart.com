                        });
                        var chechMake = "<?php echo $order->getMake() ?>";
                        var chechModel = "<?php echo $order->getModel() ?>";
                        var yearSelected = "<?php echo $order->getYear() ?>";
                        if (chechMake != '' && chechModel != '' && yearSelected != '') {
                            if (chechMake == $("select[name='vehiclelist1']").val() && chechModel == $("select[name='vehiclemodel1']").val()) {
                                $("select[name='vehicleyear1']").val(yearSelected).trigger('change');
                            }
                        }
                    }
                    $('body').trigger('processStop');
                }).fail(function (response) {
                    //handle failure scenario
                });
            }
            
