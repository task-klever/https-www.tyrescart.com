<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order" resource="sales" comment="Sales Order Table">
        <column xsi:type="varchar" name="workorder_datetime" nullable="true" length="255" comment="Work Order DateTime"/>
        <column xsi:type="text" name="workorder_comment" nullable="true" comment="Work Order Comment"/>
        <column xsi:type="varchar" name="appointment_datetime" nullable="true" length="255" comment="Appointment DateTime"/>
        <column xsi:type="text" name="appointment_comment" nullable="true" comment="Appointment Comment"/>
    </table>
</schema>
