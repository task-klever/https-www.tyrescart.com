// ============ BRAND FINDER FUNCTIONS (Single Sidebar) ============

var brandFinderBrandsLoaded = false;

function BrandFinderModel() {
    document.getElementById("brand-finder-model").classList.remove("translate-x-full");
    document.getElementById("brand-finder-model-overlay").classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    document.addEventListener('keydown', brandFinderEscHandler);

    // Always show brands view when opening
    document.querySelector('.brand-view-brands').classList.remove('hidden');
    document.querySelector('.brand-view-sizes').classList.add('hidden');
    document.getElementById('brand-sidebar-title').innerHTML = '<?php echo __("Select"); ?> <span class="text-theme-blue"><?php echo __("Tire Brand"); ?></span>';

    // Load brands if not loaded yet
    if (!brandFinderBrandsLoaded) {
        document.getElementById('klever-loader-brand').classList.remove('hidden');
        fetch('<?php echo $this->getBaseUrl(); ?>tyrefinder/ajax/gettirebrands', {
            headers: { contentType: 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: new URLSearchParams({
                form_key: hyva.getFormKey(),
                uenc: btoa(window.location.href)
            }),
            method: 'POST',
            mode: 'cors',
            credentials: 'include',
        })
        .then(response => response.json())
        .then(data => {
            document.getElementById('allTireBrands').innerHTML = data.response;
            brandFinderBrandsLoaded = true;
            document.getElementById('klever-loader-brand').classList.add('hidden');
        })
        .catch(error => {
            console.error('Error loading tire brands:', error);
            document.getElementById('klever-loader-brand').classList.add('hidden');
        });
    }
}

function BrandFinderModelClose() {
    document.getElementById("brand-finder-model").classList.add("translate-x-full");
    document.getElementById("brand-finder-model-overlay").classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    document.removeEventListener('keydown', brandFinderEscHandler);
}

function brandFinderEscHandler(e) {
    if (e.key === 'Escape' || e.key === 'Esc') {
        BrandFinderModelClose();
    }
}

function filterBrandList(searchTerm) {
    var items = document.querySelectorAll('#allTireBrands .search');
    var term = searchTerm.toLowerCase().trim();
    items.forEach(function(item) {
        var name = item.getAttribute('data-name') || '';
        if (term === '' || name.indexOf(term) !== -1) {
            item.style.display = '';
        } else {
            item.style.display = 'none';
        }
    });
}

function filterFinderList(searchTerm, listId) {
    var container = document.getElementById(listId);
    if (!container) return;
    var items = container.children;
    var term = searchTerm.toLowerCase().trim();
    for (var i = 0; i < items.length; i++) {
        var item = items[i];
        var text = (item.textContent || item.innerText || '').toLowerCase();
        var dataName = (item.getAttribute('data-name') || '').toLowerCase();
        var dataValue = (item.getAttribute('data-value') || '').toLowerCase();
        if (term === '' || text.indexOf(term) !== -1 || dataName.indexOf(term) !== -1 || dataValue.indexOf(term) !== -1) {
            item.style.display = '';
        } else {
            item.style.display = 'none';
        }
    }
}

