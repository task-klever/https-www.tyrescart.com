    document.getElementById('brandOptionId-hidden').value = optionId;
    document.getElementById('brandUrlKey-hidden').value = urlKey;
    document.getElementById('brand-size-brand-name').textContent = brandName;

    // Update sidebar header
    document.getElementById('brand-sidebar-title').innerHTML = '<?php echo __("Select"); ?> <span class="text-theme-blue">' + brandName + '</span> <?php echo __("Size"); ?>';

    // Reset size selections
    brandResetSizePopup();

    // Switch view: hide brands, show sizes
    document.querySelector('.brand-view-brands').classList.add('hidden');
    document.querySelector('.brand-view-sizes').classList.remove('hidden');

    // Load widths for this brand
    document.getElementById('klever-loader-brand').classList.remove('hidden');
    fetch('<?php echo $this->getBaseUrl(); ?>tyrefinder/ajax/getbrandwidths', {
        headers: { contentType: 'application/x-www-form-urlencoded; charset=UTF-8' },
        body: new URLSearchParams({
            form_key: hyva.getFormKey(),
            brand_id: optionId,
            uenc: btoa(window.location.href)
        }),
        method: 'POST',
        mode: 'cors',
        credentials: 'include',
    })
    .then(response => response.json())
    .then(data => {
        document.getElementById('brandAllWidthOptions').innerHTML = data.fronthtml;
        document.getElementById('brandAllRearWidthOptions').innerHTML = data.rearhtml;
        document.getElementById('klever-loader-brand').classList.add('hidden');
    })
    .catch(error => {
        console.error('Error loading brand widths:', error);
        document.getElementById('klever-loader-brand').classList.add('hidden');
    });
}

