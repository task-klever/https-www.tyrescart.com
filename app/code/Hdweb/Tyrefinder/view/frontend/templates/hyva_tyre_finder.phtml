<script>
function openFitmentDrawer(mode) {
    if (!window.Alpine) return;
    const barRoot = document.querySelector('div[x-data="fitmentBarDrawer()"]');
    if (!barRoot) return;
    const barComponent = Alpine.$data(barRoot);
    if (!barComponent || typeof barComponent.openDrawer !== 'function') return;
    if (mode === 'vehicle-wheels') {
        barComponent.isCarWheelsSearch = true;
        barComponent.isVehicleOnlyTabs = true;
        barComponent.isSizeOnlyTab = false;
        barComponent.activeTab = 'byVehicle';
        barComponent.openDrawer('vehicle');
    } else if (mode === 'size-wheels') {
        barComponent.isCarWheelsSearch = true;
        barComponent.isVehicleOnlyTabs = true;
        barComponent.isSizeOnlyTab = false;
        barComponent.activeTab = 'bySize';
        barComponent.openDrawer('size');
    } else if (mode === 'size-motorbike') {
        barComponent.isCarWheelsSearch = false;
        barComponent.isVehicleOnlyTabs = true;
        barComponent.isSizeOnlyTab = true;
        barComponent.activeTab = 'bySize';
        barComponent.openDrawer('size');
    } else {
        barComponent.isCarWheelsSearch = false;
        barComponent.isVehicleOnlyTabs = false;
        barComponent.isSizeOnlyTab = false;
        if (mode === 'vehicle') barComponent.activeTab = 'byVehicle';
        else if (mode === 'size') barComponent.activeTab = 'bySize';
        barComponent.openDrawer(mode);
    }
}

