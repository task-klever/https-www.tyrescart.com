// ============ EV FINDER FUNCTIONS (Direct Size Selection) ============

var evWidthsLoaded = false;

function EvFinderModel() {
    document.getElementById("ev-finder-model").classList.remove("translate-x-full");
    document.getElementById("ev-finder-model-overlay").classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    document.addEventListener('keydown', evFinderEscHandler);

    // Load EV widths directly if not loaded yet
    if (!evWidthsLoaded) {
        document.getElementById('klever-loader-ev').classList.remove('hidden');
        fetch('<?php echo $this->getBaseUrl(); ?>tyrefinder/ajax/getevwidths', {
            headers: { contentType: 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: new URLSearchParams({ form_key: hyva.getFormKey(), uenc: btoa(window.location.href) }),
            method: 'POST', mode: 'cors', credentials: 'include',
        })
        .then(response => response.json())
        .then(data => {
            document.getElementById('evAllWidthOptions').innerHTML = data.fronthtml;
            document.getElementById('evAllRearWidthOptions').innerHTML = data.rearhtml;
            evWidthsLoaded = true;
            document.getElementById('klever-loader-ev').classList.add('hidden');
        })
        .catch(error => { console.error('Error:', error); document.getElementById('klever-loader-ev').classList.add('hidden'); });
    }
}
function EvFinderModelClose() {
    document.getElementById("ev-finder-model").classList.add("translate-x-full");
    document.getElementById("ev-finder-model-overlay").classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    document.removeEventListener('keydown', evFinderEscHandler);
}
function evFinderEscHandler(e) { if (e.key === 'Escape' || e.key === 'Esc') { EvFinderModelClose(); } }

