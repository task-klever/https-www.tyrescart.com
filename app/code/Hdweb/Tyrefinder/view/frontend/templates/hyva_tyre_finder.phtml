function brandGoback(step) {
    if (step === 'frontwidth') {
        document.querySelector('.brand-tyrefinder-front-height').classList.add('hidden');
        document.querySelector('.brand-tyrefinder-front-width').classList.remove('hidden');
        document.querySelector('.brand-size-front-selected .brand-width').textContent = '';
        document.getElementById('brandFrontWidthLabel-hidden').value = '';
        document.getElementById('brandFrontWidthValue-hidden').value = '';
    } else if (step === 'frontheight') {
        document.querySelector('.brand-tyrefinder-front-rim').classList.add('hidden');
        document.querySelector('.brand-tyrefinder-front-height').classList.remove('hidden');
        document.querySelector('.brand-size-front-selected .brand-height').textContent = '';
        document.getElementById('brandFrontHeightLabel-hidden').value = '';
        document.getElementById('brandFrontHeightValue-hidden').value = '';
    } else if (step === 'rearwidth') {
        document.querySelector('.brand-tyrefinder-rear-height').classList.add('hidden');
        document.querySelector('.brand-tyrefinder-rear-width').classList.remove('hidden');
        document.querySelector('.brand-size-rear-selected .brand-rear-width').textContent = '';
        document.getElementById('brandRearWidthLabel-hidden').value = '';
        document.getElementById('brandRearWidthValue-hidden').value = '';
    } else if (step === 'rearheight') {
        document.querySelector('.brand-tyrefinder-rear-rim').classList.add('hidden');
        document.querySelector('.brand-tyrefinder-rear-height').classList.remove('hidden');
        document.querySelector('.brand-size-rear-selected .brand-rear-height').textContent = '';
        document.getElementById('brandRearHeightLabel-hidden').value = '';
        document.getElementById('brandRearHeightValue-hidden').value = '';
    } else if (step === 'finalstep_fromrear') {
        document.querySelector('.brand-rear-tyre-selection').classList.add('hidden');
        document.querySelector('.brand-front-tyre-selection').classList.remove('hidden');
        document.querySelector('.brand-search-final-step').classList.remove('hidden');
        document.querySelector('.brand-diff-rear-size').classList.remove('hidden');
    }
}

