function evIsRearSizeSelected() { return document.getElementById('evRearRimValue-hidden').value !== ''; }

function evGoback(step) {
    if (step === 'frontwidth') {
        document.querySelector('.ev-tyrefinder-front-height').classList.add('hidden');
        document.querySelector('.ev-tyrefinder-front-width').classList.remove('hidden');
        document.querySelector('.ev-size-front-selected .ev-width').textContent = '';
        document.getElementById('evFrontWidthLabel-hidden').value = '';
        document.getElementById('evFrontWidthValue-hidden').value = '';
    } else if (step === 'frontheight') {
        document.querySelector('.ev-tyrefinder-front-rim').classList.add('hidden');
        document.querySelector('.ev-tyrefinder-front-height').classList.remove('hidden');
        document.querySelector('.ev-size-front-selected .ev-height').textContent = '';
        document.getElementById('evFrontHeightLabel-hidden').value = '';
        document.getElementById('evFrontHeightValue-hidden').value = '';
    } else if (step === 'rearwidth') {
        document.querySelector('.ev-tyrefinder-rear-height').classList.add('hidden');
        document.querySelector('.ev-tyrefinder-rear-width').classList.remove('hidden');
        document.querySelector('.ev-size-rear-selected .ev-rear-width').textContent = '';
        document.getElementById('evRearWidthLabel-hidden').value = '';
        document.getElementById('evRearWidthValue-hidden').value = '';
    } else if (step === 'rearheight') {
        document.querySelector('.ev-tyrefinder-rear-rim').classList.add('hidden');
        document.querySelector('.ev-tyrefinder-rear-height').classList.remove('hidden');
        document.querySelector('.ev-size-rear-selected .ev-rear-height').textContent = '';
        document.getElementById('evRearHeightLabel-hidden').value = '';
        document.getElementById('evRearHeightValue-hidden').value = '';
    } else if (step === 'finalstep_fromrear') {
        document.querySelector('.ev-rear-tyre-selection').classList.add('hidden');
        document.querySelector('.ev-front-tyre-selection').classList.remove('hidden');
        document.querySelector('.ev-search-final-step').classList.remove('hidden');
        document.querySelector('.ev-diff-rear-size').classList.remove('hidden');
    }
}

