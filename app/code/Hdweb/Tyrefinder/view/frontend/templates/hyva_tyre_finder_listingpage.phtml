<script>
function TyreFinderModel() {
    document.getElementById("tyre-finder-model").classList.remove("translate-x-full");
    document.getElementById("tyre-finder-model-overlay").classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    // Add Escape key listener
    document.addEventListener('keydown', tyreFinderEscHandler);
}
function TyreFinderModelClose() {
    document.getElementById("tyre-finder-model").classList.add("translate-x-full");
    document.getElementById("tyre-finder-model-overlay").classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    // Remove Escape key listener
    document.removeEventListener('keydown', tyreFinderEscHandler);
}
function VehicleFinderModel() {


     // Run only if the functions don't hit missing elements
    if (typeof removeRear === "function") {
        try { removeRear(); } catch(e) { console.warn("removeRear skipped:", e); }
    }

    if (typeof reselectFront === "function") {
        try { reselectFront(); } catch(e) { console.warn("reselectFront skipped:", e); }
    }

    //  Reset form values when closing
    document.getElementById('finder-size-form').reset();

    // Also clear hidden input values
    document.querySelectorAll('#finder-size-form input[type="hidden"]').forEach(el => {
        el.value = '';
    });

    document.getElementById("vehicle-finder-model").classList.remove("translate-x-full");
    document.getElementById("vehicle-finder-model-overlay").classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    // Add Escape key listener
    document.addEventListener('keydown', vehicleFinderEscHandler);
}
function VehicleFinderModelClose() {
    document.getElementById("vehicle-finder-model").classList.add("translate-x-full");
    document.getElementById("vehicle-finder-model-overlay").classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    // Remove Escape key listener
    document.removeEventListener('keydown', vehicleFinderEscHandler);
}
function vehicleFinderEscHandler(e) {
    if (e.key === 'Escape' || e.key === 'Esc') {
        VehicleFinderModelClose();
    }
}
function tyreFinderEscHandler(e) {
    if (e.key === 'Escape' || e.key === 'Esc') {
        TyreFinderModelClose();
    }
}
</script>
