<div class="w-full text-center" x-data="{...hyva.modal(), initialized: false, init() {
    if (this.initialized) return;
    this.initialized = true;
    //console.log('init called');
    const origShow = this.show;
    this.show = (value,event,data) => {
        if(value == 'tyre-finder-size-modal'){
            var allWidthOptionsLength = document.querySelectorAll('#allWidthOptions li').length;
            var allRearWidthOptionsLength = document.querySelectorAll('#allRearWidthOptions li').length;
            if (allWidthOptionsLength <= 0 || allRearWidthOptionsLength <= 0) {
                document.getElementById('klever-loader').classList.remove('hidden');
                fetch('<?php echo $this->getBaseUrl() . 'tyrefinder/ajax/getwidth'; ?>', {
                headers: {
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                },
                body: new URLSearchParams({
                    form_key: hyva.getFormKey(),
                    uenc: btoa(window.location.href)
                }),
                method: 'POST',
                mode: 'cors',
                credentials: 'include',
                })
                .then(response => response.json())
                .then(data => {
                    document.getElementById('allWidthOptions').innerHTML = data.fronthtml;
                    document.getElementById('allRearWidthOptions').innerHTML = data.rearhtml;
                    document.getElementById('klever-loader').classList.add('hidden');
                })
                .catch(error => {
                    // Handle error here
                    document.getElementById('klever-loader').classList.add('hidden');
                });
            }

            
            if (!document.getElementById('search-full-tyre-by-sizeUL').innerHTML.trim()) {
                document.getElementById('klever-loader').classList.remove('hidden');
                fetch('<?php echo $this->getBaseUrl() . 'tyrefinder/ajax/gettyresize'; ?>', {
                headers: {
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                },
                body: new URLSearchParams({
                    form_key: hyva.getFormKey(),
                    uenc: btoa(window.location.href)
                }),
                method: 'POST',
                mode: 'cors',
                credentials: 'include',
                })
                .then(response => response.json())
                .then(data => {
                    document.getElementById('search-full-tyre-by-sizeUL').innerHTML = data.response;
                    // Event listener for selecting items in the list
                    var dropdownList = document.getElementById('search-full-tyre-by-sizeUL');
                    const listItems = dropdownList.getElementsByTagName('li');
                    for (let i = 0; i < listItems.length; i++) {
                        const listItem = listItems[i];
                        listItem.addEventListener('click', () => toggleSelection(listItem));
                    }
                    document.getElementById('klever-loader').classList.add('hidden');
                })
                .catch(error => {
                    // Handle error here
                    document.getElementById('klever-loader').classList.add('hidden');
                });
            }
        }
        if(value == 'tyre-finder-vehicle-modal'){
            var allBrandOptionsLength = document.querySelectorAll('#allBrands li').length;
            if (allBrandOptionsLength <= 0) {
                document.getElementById('klever-loader2').classList.remove('hidden');
                fetch('<?php echo $this->getBaseUrl() . 'tyrefinder/ajax/getallbrands'; ?>', {
                        headers: {
                            contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                        },
                        body: new URLSearchParams({
                            form_key: hyva.getFormKey(),
                            uenc: btoa(window.location.href)
                        }),
                        method: 'POST',
                        mode: 'cors',
                        credentials: 'include',
                    })
                    .then(response => response.json())
                    .then(data => {
                        document.getElementById('allBrands').innerHTML = data.response;
                        document.getElementById('klever-loader2').classList.add('hidden');
                    })
                    .catch(error => {
                        // Handle error here
                        document.getElementById('klever-loader2').classList.add('hidden');
                    });
            }
        }
        return origShow.call(this, value);
    }
}}" x-init="init">
