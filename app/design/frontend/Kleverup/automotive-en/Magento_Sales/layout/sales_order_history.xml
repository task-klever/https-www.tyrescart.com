<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Ensure breadcrumbs block is visible -->
        <referenceBlock name="breadcrumbs" remove="false"/>

        <!-- Add breadcrumb items -->
        <referenceBlock name="breadcrumbs">
            <!-- Home -->
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">home</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string">Home</item>
                    <item name="title" xsi:type="string">Go to Home Page</item>
                    <item name="link" xsi:type="string">{{baseUrl}}</item>
                </argument>
            </action>

            <!-- My Account -->
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">my_account</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string">My Account</item>
                    <item name="title" xsi:type="string">My Account</item>
                    <item name="link" xsi:type="string">{{baseUrl}}customer/account/</item>
                </argument>
            </action>

            <!-- My Orders -->
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">my_orders</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string">My Orders</item>
                    <item name="title" xsi:type="string">My Orders</item>
                </argument>
            </action>
        </referenceBlock>

       
        <!-- Remove Wishlist sidebar -->
        <referenceBlock name="wishlist_sidebar" remove="true" />
                                   
    </body>
</page>
