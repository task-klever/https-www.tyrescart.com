<?php
/**
 * Order comment for email - English
 * Fetches the customer comment from the quote
 */
$_order = $block->getOrder();
$comment = '';

// Try order's customer_note first
if ($_order->getCustomerNote()) {
    $comment = $_order->getCustomerNote();
}

// Fallback: read from quote's customer_comment
if (!$comment) {
    $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
    try {
        $quoteId = $_order->getQuoteId();
        if ($quoteId) {
            $quote = $objectManager->create(\Magento\Quote\Model\Quote::class)->load($quoteId);
            if ($quote->getCustomerComment()) {
                $comment = $quote->getCustomerComment();
            }
        }
    } catch (\Exception $e) {
        // silently fail
    }
}

if ($comment):
?>
<?php echo $block->escapeHtml($comment); ?>
<?php endif; ?>
