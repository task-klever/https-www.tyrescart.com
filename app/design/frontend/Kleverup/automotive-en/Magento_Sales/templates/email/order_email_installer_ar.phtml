<?php
/**
 * Arabic version of order_email_installer.phtml
 */
$_order = $block->getOrder();
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();

$pickupStore = $_order->getPickupStore();
if ($pickupStore) {
    $installer = $objectManager->create('Ecomteck\StoreLocator\Model\Stores')->load($pickupStore);
    $country = $objectManager->create('\Magento\Directory\Model\Country')->load($installer['country'])->getName();

    $installerInfo = [
        'name' => $installer['name'],
        'address' => $installer['address'],
        'city' => $installer['city'],
        'country' => $country,
        'phone' => 'هاتف: ' . $installer['phone'],
        'email' => 'البريد: ' . $installer['email'],
    ];
}

$vehicleInfo = [];
if ($_order->getMake() || $_order->getPlate() || $_order->getModel() || $_order->getYear()) {
    $vehicleInfo = [
        'رقم اللوحة' => $_order->getPlate(),
        'الشركة المصنعة' => $_order->getMake(),
        'الموديل' => $_order->getModel(),
        'السنة' => $_order->getYear(),
    ];
}

$orderComment = $_order->getEcomteckOrderComment();

if($pickupStore !='' && $pickupStore != null && $pickupStore != 4):
?>

<table width="100%" cellpadding="0" cellspacing="0" border="0" dir="rtl">
    <tr valign="top">
        <?php if ($pickupStore): ?>
            <?php if ($_order->getShippingDescription() == "Install at Outlet") { ?>
                <td width="50%" style="padding:0 0 0 8px; vertical-align:top; text-align:right;">
                    <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;">معلومات المُركّب</p>
                    <div dir="ltr" style="unicode-bidi:embed; text-align:left; font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                        <?php echo implode('<br>', $installerInfo); ?>
                    </div>
                    <p style="font-family:Arial, sans-serif; margin:10px 0 0 0; font-size:13px; line-height:1.6; color:#444;">
                        <span style="font-weight:700;">تاريخ/وقت الموعد: </span>
                        <br><span dir="ltr" style="unicode-bidi:embed;"><?php echo date('Y-m-d', strtotime($_order->getPickupDate())) . " " . $_order->getPickupTime(); ?></span>
                    </p>
                </td>
            <?php } elseif ($_order->getShippingDescription() == "Mobile Van Service") { ?>
                <td width="50%" style="padding:0 0 0 8px; vertical-align:top; text-align:right;">
                    <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                        <span style="font-weight:700;">تاريخ/وقت الموعد: </span>
                        <br><span dir="ltr" style="unicode-bidi:embed;"><?php echo date('Y-m-d', strtotime($_order->getPickupDate())) . " " . $_order->getPickupTime(); ?></span>
                    </p>
                    <?php $pickupLocation = $_order->getPickupLocation(); ?>
                    <?php if ($pickupLocation): ?>
                    <p style="font-family:Arial, sans-serif; margin:10px 0 0 0; font-size:13px; line-height:1.6; color:#444; text-align:right;">
                        <span style="font-weight:700;">موقع الاستلام: </span>
                        <br><span dir="ltr" style="unicode-bidi:embed;"><a href="https://www.google.com/maps/search/?api=1&query=<?php echo urlencode($pickupLocation); ?>" target="_blank" style="color:#00843d; text-decoration:underline;"><?php echo $block->escapeHtml($pickupLocation); ?></a></span>
                    </p>
                    <?php endif; ?>
                </td>
            <?php } ?>
        <?php endif; ?>

        <?php if ($vehicleInfo): ?>
            <td width="50%" style="padding:0 8px 0 0; vertical-align:top; text-align:right;">
                <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;">معلومات المركبة</p>
                <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                    <?php
                    foreach ($vehicleInfo as $key => $value) {
                        echo $key . ": " . $value . "<br>";
                    }
                    ?>
                </p>
            </td>
        <?php endif; ?>
    </tr>
</table>

<?php if ($orderComment): ?>
<table width="100%" cellpadding="0" cellspacing="0" border="0" dir="rtl" style="margin-top:14px;">
    <tr>
        <td style="text-align:right;">
            <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;">تعليقات الطلب</p>
            <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;"><?php echo $orderComment; ?></p>
        </td>
    </tr>
</table>
<?php endif; ?>

<?php endif; ?>
