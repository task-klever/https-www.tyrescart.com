<?php
$_order = $block->getOrder();
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();

$pickupStore = $_order->getPickupStore();
if ($pickupStore) {
    $installer = $objectManager->create('Ecomteck\StoreLocator\Model\Stores')->load($pickupStore);
    $country = $objectManager->create('\Magento\Directory\Model\Country')->load($installer['country'])->getName();

    $installerInfo = [
        'name' => $installer['name'],
        'address' => $installer['address'],
        'city' => $installer['city'],
        'country' => $country,
        'phone' => 'T: ' . $installer['phone'],
        'email' => 'Email: ' . $installer['email'],
    ];
}

$vehicleInfo = [];
if ($_order->getMake() || $_order->getPlate() || $_order->getModel() || $_order->getYear()) {
    $vehicleInfo = [
        'plate' => $_order->getPlate(),
        'make' => $_order->getMake(),
        'model' => $_order->getModel(),
        'year' => $_order->getYear(),
    ];
}

$orderComment = $_order->getEcomteckOrderComment();

if($pickupStore !='' && $pickupStore != null && $pickupStore != 4):
?>

<table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr valign="top">
        <?php if ($pickupStore): ?>
            <?php if ($_order->getShippingDescription() == "Install at Outlet") { ?>
                <td width="50%" style="padding:0 8px 0 0; vertical-align:top;">
                    <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;"><?php echo __('Installer Information') ?></p>
                    <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                        <?php echo implode('<br>', $installerInfo); ?>
                        <br><br><span style="font-weight:700;"><?php echo __('Appointment Date/Time: ') ?></span>
                        <br><?php echo date('Y-m-d', strtotime($_order->getPickupDate())) . " " . $_order->getPickupTime(); ?>
                    </p>
                </td>
            <?php } elseif ($_order->getShippingDescription() == "Mobile Van Service") { ?>
                <td width="50%" style="padding:0 8px 0 0; vertical-align:top;">
                    <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                        <span style="font-weight:700;"><?php echo __('Appointment Date/Time: ') ?></span>
                        <br><?php echo date('Y-m-d', strtotime($_order->getPickupDate())) . " " . $_order->getPickupTime(); ?>
                    </p>
                    <?php $pickupLocation = $_order->getPickupLocation(); ?>
                    <?php if ($pickupLocation): ?>
                    <p style="font-family:Arial, sans-serif; margin:10px 0 0 0; font-size:13px; line-height:1.6; color:#444;">
                        <span style="font-weight:700;"><?php echo __('Pickup Location: ') ?></span>
                        <br><a href="https://www.google.com/maps/search/?api=1&query=<?php echo urlencode($pickupLocation); ?>" target="_blank" style="color:#00843d; text-decoration:underline;"><?php echo $block->escapeHtml($pickupLocation); ?></a>
                    </p>
                    <?php endif; ?>
                </td>
            <?php } ?>
        <?php endif; ?>

        <?php if ($vehicleInfo): ?>
            <td width="50%" style="padding:0 0 0 8px; vertical-align:top;">
                <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;"><?php echo __('Vehicle Information') ?></p>
                <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;">
                    <?php
                    foreach ($vehicleInfo as $key => $value) {
                        echo ucwords($key) . ": " . $value . "<br>";
                    }
                    ?>
                </p>
            </td>
        <?php endif; ?>
    </tr>
</table>

<?php if ($orderComment): ?>
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;">
    <tr>
        <td>
            <p style="font-weight:700; font-family:Arial, sans-serif; margin:0 0 10px 0;"><?php echo __('Order Comments') ?></p>
            <p style="font-family:Arial, sans-serif; margin:0; font-size:13px; line-height:1.6; color:#444;"><?php echo $orderComment; ?></p>
        </td>
    </tr>
</table>
<?php endif; ?>

<?php endif; ?>
