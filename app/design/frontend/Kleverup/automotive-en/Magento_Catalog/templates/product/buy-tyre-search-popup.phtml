<script>
function buyTyreSearchModal() {
    return {
        async openbuyTyreSearchModal(width, height, rim, productName, hasSuggestedSize) {
            try {
                // Show loader
                document.getElementById('klever-loader').classList.remove('hidden');

                // Fetch content
                const data = await this.fetchTyreData(width, height, rim);

                if (data.status === 'success') {
                    // Set product name
                    document.querySelector('#item-size .product-name').textContent = productName;

                    const customTextEl = document.querySelector('#item-size .product-custom-text');

                    if (customTextEl) {
                        customTextEl.textContent = 'Check if Matching Front/Rear Tyre Size Available?';
                        customTextEl.classList.add('hidden');

                        // Remove any previous click handler
                        customTextEl.onclick = null;

                        // Attach click to open Specifications popup
                        customTextEl.onclick = () => {
                            // Close Buy Tyre sidebar
                            ItemSize();

                            // Open Specifications modal (from pasted.txt)
                            SpecificationsOpenModal(width, height, rim);
                        };

                    }

                    // Insert content
                    document.querySelector('#item-size .tyre-popup-content').innerHTML = data.html;

                    // Reset search input
                    var searchInput = document.getElementById('item-size-search');
                    if (searchInput) { searchInput.value = ''; }

                    // Open sidebar
                    document.getElementById("item-size").classList.remove("translate-y-full");
                    document.getElementById("item-size-overlay").classList.remove("hidden");
                    document.body.classList.add("overflow-hidden");
                } else {
                    console.error('Server error:', data.message);
                }

                document.getElementById('klever-loader').classList.add('hidden');
            } catch (error) {
                console.error('Fetch error:', error);
                document.getElementById('klever-loader').classList.add('hidden');
            }
        },

        async fetchTyreData(width, height, rim) {
            const response = await fetch('<?php echo $this->getBaseUrl() . 'tyrefinder/ajax/buytyresearch'; ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: new URLSearchParams({
                    form_key: hyva.getFormKey(),
                    width: width,
                    height: height,
                    rim: rim,
                    uenc: btoa(window.location.href)
                }),
                credentials: 'include'
            });

            return await response.json();
        }
    };
}
</script>





