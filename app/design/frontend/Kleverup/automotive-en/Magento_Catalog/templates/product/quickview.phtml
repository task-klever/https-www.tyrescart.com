<?php
/**
 * Quick View popup content - loaded via AJAX
 */
use Hdweb\Tyrefinder\Helper\Productlisting as ListingHelper;
use Magento\Catalog\Helper\Output as CatalogOutputHelper;

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$escaper = $objectManager->get(\Magento\Framework\Escaper::class);
$listingHelper = $objectManager->get(ListingHelper::class);
$catalogOutputHelper = $objectManager->get(CatalogOutputHelper::class);
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$imageHelper = $objectManager->get(\Magento\Catalog\Helper\Image::class);
$priceHelper = $objectManager->get(\Magento\Framework\Pricing\Helper\Data::class);

$product = $block->getData('product');
if (!$product) return;

$productId = $product->getId();
$productName = $product->getName();
$productUrl = $product->getProductUrl();
$currency = $storeManager->getStore()->getCurrentCurrencyCode();
$mediaUrl = $storeManager->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);

// Image
$imageUrl = $imageHelper->init($product, 'category_page_grid')->getUrl();

// Brand
$brand = $catalogOutputHelper->productAttribute($product, $product->getBrand(), 'brand');
$brandImage = '';
$brandName = '';
$brandUrl = '';
if ($brand) {
    $brandDetails = $listingHelper->getBrandDetails($brand);
    if ($brandDetails) {
        $brandImage = $listingHelper->getBrandImageUrl($brandDetails);
        $brandName = $brandDetails->getName();
        $brandUrl = $listingHelper->getBrandUrl($brandDetails);
    } else {
        $brandName = $product->getAttributeText('brand') ?: '';
    }
}

// Attributes
$partsCategory = $product->getPartsCategory() ? $product->getAttributeText('parts_category') : '';
$pattern = $product->getPattern() ? $product->getAttributeText('pattern') : '';
$tyreSize = $product->getAttributeText('tyre_size');
$width = $product->getAttributeText('width');
$height = $product->getAttributeText('height');
$rim = $product->getAttributeText('rim');
$loadIndex = $product->getLoadIndex() ?: '';
$year = $product->getYear() ? $product->getAttributeText('year') : null;
$origin = $product->getCountry() ? $product->getAttributeText('country') : null;
$warranty_period = $product->getWarrantyPeriod() ? $product->getAttributeText('warranty_period') : '';
$oemMarking = $product->getOemMarking() ? $product->getAttributeText('oem_marking') : '';
$oem_tyres = $product->getResource()->getAttribute("oem_tyres")->getFrontend()->getValue($product);
$runflat = $product->getRunflat() ? $product->getAttributeText('runflat') : null;
$sku = $product->getSku();

// Pricing
$regularPrice = $product->getPriceInfo()->getPrice('regular_price')->getAmount()->getValue();
$finalPrice = $product->getPriceInfo()->getPrice('final_price')->getAmount()->getValue();
$savePercent = ($finalPrice < $regularPrice && $regularPrice > 0) ? round((($regularPrice - $finalPrice) / $regularPrice) * 100) : 0;
$set2price = $listingHelper->getSet2price($product);
$set4price = $listingHelper->getSet4price($product);

// Offer/discount data
$isOfferProduct = 'No';
$discountAmount = '';
$discountQty = '';
$productOfferRule = $listingHelper->isAnyRuleExist($product);
if (!empty($productOfferRule) && !empty($productOfferRule['rule_id'])) {
    if (!empty($productOfferRule['offer_price'])) {
        $isOfferProduct = 'Yes';
        $discountAmount = $productOfferRule['discount_amount'];
        $discountQty = $productOfferRule['discount_qty_step'];
    }
}

// Stock (same logic as listing page - cap at 8)
$prod_qty = $listingHelper->getProductAvailableQty($product->getSku());
$stockQty = 0;
if ($prod_qty >= 8) {
    $stockQty = 8;
} else {
    $stockQty = $prod_qty;
}
$isInStock = $stockQty > 0;

// Gallery images
$galleryImages = [];
$mediaGallery = $product->getMediaGalleryImages();
if ($mediaGallery) {
    foreach ($mediaGallery as $galleryImage) {
        $galleryImages[] = [
            'thumb' => $imageHelper->init($product, 'product_page_image_small')->setImageFile($galleryImage->getFile())->getUrl(),
            'img' => $imageHelper->init($product, 'product_page_image_medium')->setImageFile($galleryImage->getFile())->getUrl(),
        ];
    }
}
if (empty($galleryImages)) {
    $galleryImages[] = ['thumb' => $imageUrl, 'img' => $imageUrl];
}

// Form key
$formKey = $objectManager->get(\Magento\Framework\Data\Form\FormKey::class)->getFormKey();
$addToCartUrl = $storeManager->getStore()->getUrl('checkout/cart/add');
$qvId = 'qv-' . $productId;
