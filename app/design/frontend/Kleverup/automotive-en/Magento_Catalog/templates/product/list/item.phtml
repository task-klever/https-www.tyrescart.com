<script>
// Intercept quickview clicks at capture phase — before any form handler can fire
document.addEventListener('click', function(e) {
    var trigger = e.target.closest('.quickview-trigger');
    if (!trigger) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    var productId = trigger.getAttribute('data-quickview-id');
    if (productId) openQuickView(productId);
}, true);

function openQuickView(productId) {
    var modal = document.getElementById('quickview-modal');
    var overlay = document.getElementById('quickview-overlay');
    var content = document.getElementById('quickview-content');

    content.innerHTML = '<div class="flex items-center justify-center py-16"><svg class="animate-spin h-8 w-8 text-theme-blue" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg></div>';
    modal.classList.remove('translate-y-full');
    overlay.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');

    fetch(BASE_URL + 'tyrefinder/ajax/quickview?id=' + productId, {
        method: 'GET',
        credentials: 'include'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.status === 'success') {
            content.innerHTML = data.html;
        } else {
            content.innerHTML = '<p class="text-red-500 p-8 text-center">Unable to load product details.</p>';
        }
    })
    .catch(function() {
        content.innerHTML = '<p class="text-red-500 p-8 text-center">Unable to load product details.</p>';
    });
}

function closeQuickView() {
    document.getElementById('quickview-modal').classList.add('translate-y-full');
    document.getElementById('quickview-overlay').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
}

function quickViewAddToCart(productId, addToCartUrl, formKey) {
    var qtyEl = document.getElementById('qv-qty-' + productId);
    var qty = qtyEl ? qtyEl.value : 1;

    fetch(addToCartUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'form_key=' + formKey + '&product=' + productId + '&qty=' + qty + '&uenc=' + btoa(window.location.href),
        credentials: 'include'
    })
    .then(function(r) { return r.text(); })
    .then(function() {
        closeQuickView();
        window.location.reload();
    })
    .catch(function() {
        alert('Error adding to cart. Please try again.');
    });
}

function qvOpenBuyTyreSearch(width, height, rim, productName) {
    var baseUrl = BASE_URL || '/';
    var loader = document.getElementById('klever-loader');
    if (loader) loader.classList.remove('hidden');
    fetch(baseUrl + 'tyrefinder/ajax/buytyresearch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
        body: new URLSearchParams({ form_key: hyva.getFormKey(), width: width, height: height, rim: rim, uenc: btoa(window.location.href) }),
        credentials: 'include'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (loader) loader.classList.add('hidden');
        if (data.status === 'success') {
            var nameEl = document.querySelector('#item-size .product-name');
            if (nameEl) nameEl.textContent = productName;
            var contentEl = document.querySelector('#item-size .tyre-popup-content');
            if (contentEl) contentEl.innerHTML = data.html;
            var searchInput = document.getElementById('item-size-search');
            if (searchInput) searchInput.value = '';
            document.getElementById('item-size').classList.remove('translate-y-full');
            document.getElementById('item-size-overlay').classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }
    })
    .catch(function() { if (loader) loader.classList.add('hidden'); });
}

function qvChangePrice(selectElement, unitRegularPrice, unitFinalPrice, partsCategory, isOfferProduct, discountAmount, discountQty, productId) {
    var selectedQty = parseInt(selectElement.value);
    var formatter = new Intl.NumberFormat('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    var price;
    if (isOfferProduct == 'No') {
        price = selectedQty * unitFinalPrice;
    } else {
        discountAmount = parseFloat(discountAmount) || 0;
        discountQty = parseInt(discountQty) || 0;
        if (selectedQty >= discountQty && discountQty > 0) {
            price = selectedQty * unitFinalPrice;
            var discount = (discountAmount / 100) * unitFinalPrice * discountQty;
            var discountTimes = Math.floor(selectedQty / discountQty);
            discount = discount * discountTimes;
            price = price - discount;
        } else {
            price = selectedQty * unitFinalPrice;
        }
    }
    var setPriceBox = document.getElementById('qv-set-price-' + productId);
    if (setPriceBox && partsCategory !== 'battery') {
        var setOfEl = setPriceBox.querySelector('.qv-set-of');
        var setOfPriceEl = setPriceBox.querySelector('.qv-set-of-price');
        if (setOfEl) setOfEl.textContent = 'Set of ' + selectedQty + ':';
        if (setOfPriceEl) setOfPriceEl.textContent = formatter.format(price);
    }
    var btnPriceEl = document.getElementById('qv-btn-price-' + productId);
    if (btnPriceEl) btnPriceEl.textContent = Math.round(price).toLocaleString();
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeQuickView();
});
</script>

















