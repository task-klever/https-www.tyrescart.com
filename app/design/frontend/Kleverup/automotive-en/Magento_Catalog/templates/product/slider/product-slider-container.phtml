declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\ProductListItem;
use Hyva\Theme\ViewModel\ProductPage;
use Hyva\Theme\ViewModel\Store;
use Magento\Catalog\Block\Product\ReviewRendererInterface as ProductReviewRenderer;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var Store $viewModelStore */
$viewModelStore = $viewModels->require(Store::class);

/** @var ProductPage $productViewModel */
$productViewModel = $viewModels->require(ProductPage::class);

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

/** @var ProductListItem $productListItemViewModel */
$productListItemViewModel = $viewModels->require(ProductListItem::class);

$viewMode = 'grid';
$imageDisplayArea = 'category_page_grid';
$showDescription = false;

$name = (string) $block->getName();
$title = (string) $block->getTitle();
$headingTag = $block->getData('heading_tag') ?: 'h3';
$items = $block->getItems() ?? [];
if (is_object($items) && $items instanceof Iterator) {
    $items = iterator_to_array($items);
}
if (!$itemCount = count($items)) {
    return '';
}

$sliderIndex = 1;
$sliderItemRenderer = $block->getLayout()->getBlock('product_list_item')
    ?: $block->getChildBlock('slider.item.template')
    ?: $block->getLayout()->createBlock(Template::class);

$hideRatingSummary = (bool) $block->getData('hide_rating_summary');
$hideDetails       = (bool) $block->getData('hide_details');

$sliderItemRenderer->setData('hide_details', $hideDetails);
$sliderItemRenderer->setData('hide_rating_summary', $hideRatingSummary);
$sliderItemRenderer->setData('item_relation_type', $block->getData('item_relation_type') ?: 'related');

// The slider item renderer block is often a shared instance.
// If a specific item template is set for this slider, the previously set template must be reset later
// so the item template is only replaced for the one slider it is specified on.
$sharedItemRendererTemplate = null;
$isSharedItemRenderer       = $sliderItemRenderer !== $block->getChildBlock('slider.item.template');
if ($isSharedItemRenderer && $block->getChildBlock('slider.item.template')) {
    $sharedItemRendererTemplate = $sliderItemRenderer->getTemplate();
    $sliderSpecificItemTemplate = $block->getChildBlock('slider.item.template')->getTemplate();
    $sliderItemRenderer->setTemplate($sliderSpecificItemTemplate);
}

// The number of slides visible on the xl breakpoint
$maxVisibleSlides = $block->getData('max_visible') ?? 4;

$sliderSectionClasses = $block->getData('maybe_purged_tailwind_section_classes') ?? 'py-6 md:py-12 lg:py-14 text-gray-700 body-font';

?>
<script>
    'use strict';

    function initSliderComponent() {
        return {
            active: 0,
            itemCount: 0,
            pageSize: <?= (int) $maxVisibleSlides ?>,
            getSlider() {
                return this.$root.querySelector('.related-grid-track');
            },
            calcPageSize() {
                const slider = this.getSlider();
                if (slider) {
                    this.itemCount = slider.querySelectorAll('.related-grid-item').length;
                    const firstSlide = slider.querySelector('.related-grid-item');
                    if (firstSlide && slider.clientWidth > 0) {
                        this.pageSize = Math.round(slider.clientWidth / firstSlide.clientWidth) || <?= (int) $maxVisibleSlides ?>;
                    }
                }
            },
            calcActive() {
                const slider = this.getSlider();
                if (slider) {
                    const firstSlide = slider.querySelector('.related-grid-item');
                    if (firstSlide) {
                        this.active = Math.round(slider.scrollLeft / firstSlide.clientWidth);
                    }
                }
            },
            scrollPrevious() {
                this.scrollTo(Math.max(0, this.active - this.pageSize));
            },
            scrollNext() {
                const maxStart = Math.max(0, this.itemCount - this.pageSize);
                this.scrollTo(Math.min(maxStart, this.active + this.pageSize));
            },
            scrollTo(idx) {
                this.active = idx;
            },
            skipCarouselToNavigation(navSelector) {
                const element = document.getElementById(navSelector)
                if (element) {
                    element.scrollIntoView({behavior: 'smooth', block: 'end'});
                    const button = element.querySelector('button:not([disabled])');
                    this.$nextTick(() => button && button.focus({preventScroll: true}))
                }
            }
        }
    }
</script>
<section
    class="<?= /* @noEscape */ $sliderSectionClasses ?>"
    x-data="initSliderComponent()"
    x-init="calcPageSize();"
    x-id="['slider-nav', 'slider-desc', 'slider-id']"
    @resize.window.debounce="calcPageSize(); $nextTick( function() { calcActive() })"
    role="group"
    aria-roledescription="<?= $escaper->escapeHtmlAttr(__('Carousel')) ?>"
    aria-label="<?= $escaper->escapeHtmlAttr(__('Carousel %1', $title)) ?>"
    :aria-describedby="$id('slider-desc')"
    x-defer="intersect"
>
    <?php if ($items): ?>

        <div class="relative">
           <div class="container-theme w-full py-0 md:py-3 mx-auto">
           <div class="sec-title mb-2 md:mb-4 mx-auto">
               <div class="h2 text-theme-dark font-bold relative">
                   <span class="w-[70px] md:w-[100px] border-b border-theme-blue bg-theme-blue absolute left-0 bottom-0 hidden"></span>
                      <i class="icon icon-logo-icon mr-1 text-theme-blue"></i><<?= /* @noEscape */ $headingTag ?> class="inline-block">
                        <?php
                        $titleWords = explode(' ', $escaper->escapeHtml($title));
                        if (count($titleWords) > 1) {
                            echo $titleWords[0] . ' <span class="text-theme-blue">' . $titleWords[1] . '</span>';
                            if (count($titleWords) > 2) {
                                echo ' ' . implode(' ', array_slice($titleWords, 2));
                            }
                        } else {
                            echo $escaper->escapeHtml($title);
                        }
                        ?>
                      </<?= /* @noEscape */ $headingTag ?>>
               </div>
            </div>
            </div>
            <span
                class="sr-only"
                :id="$id('slider-desc')"
                tabindex="-1"
            >
                <?= $escaper->escapeHtml(__('Navigating through the elements of the carousel is possible using the tab key. You can skip the carousel or go straight to carousel navigation using the skip links.')) ?>
            </span>
            <a
                href="#<?= $escaper->escapeHtmlAttr($name) ?>-slider-end"
                class="action skip sr-only focus:not-sr-only focus:absolute focus:z-30 focus:bg-white"
            >
                <?= $escaper->escapeHtml(__('Press to skip carousel')) ?>
            </a>
            <button
                x-show="itemCount > pageSize"
                type="button"
                class="action skip sr-only focus:not-sr-only focus:absolute focus:z-30 focus:bg-white"
                @click.prevent="skipCarouselToNavigation($id('slider-nav'))"
            >
                <?= $escaper->escapeHtml(__('Press to go to carousel navigation')) ?>
            </button>

            <div class="container-theme-custom">
            <div class="related-grid-slider relative w-full">
                <div class="related-grid-track"
                     style="display:grid !important;grid-template-columns:repeat(<?= (int) $maxVisibleSlides ?>,1fr) !important;gap:0.5rem !important"
                >
                    <?php foreach ($items as $product): ?>
                        <?php
                        // Capture item HTML to prevent DOM breakage from fitment modals/scripts
                        // that escape <form> tags and become siblings in the grid
                        $itemHtml = $productListItemViewModel->getItemHtmlWithRenderer(
                            $sliderItemRenderer,
                            $product,
                            $block,
                            $viewMode,
                            ProductReviewRenderer::SHORT_VIEW,
                            $imageDisplayArea,
                            $showDescription
                        );
                        // Strip everything after the last closing </form> or </div> of the card
                        // to prevent fitment modals and scripts from leaking into the grid
                        $lastFormClose = strrpos($itemHtml, '</form>');
                        if ($lastFormClose !== false) {
                            $itemHtml = substr($itemHtml, 0, $lastFormClose + 7);
                        }
                        ?>
                        <div class="related-grid-item"
                             style="min-width:0 !important;overflow:hidden"
                             role="group"
                             aria-label="<?= $escaper->escapeHtmlAttr(__('Item %1', $sliderIndex)) ?>"
                             :aria-describedby="`slide-desc-<?= $escaper->escapeHtmlAttr($product->getId()) ?>-${$id('slider-id')}`"
                             x-show="<?= (int)($sliderIndex - 1) ?> >= active && <?= (int)($sliderIndex - 1) ?> < active + pageSize"
                             x-transition
                        ><?php $sliderIndex++; ?>
                            <?= /** @noEscape */ $itemHtml ?>
                        </div>
                    <?php endforeach; ?>
                </div>
                <script>
                // Fix DOM nesting: browser nests grid items inside the first item
                // due to complex form/div structure in item template.
                // Must run both immediately AND after Alpine deferred init.
                function fixRelatedGrid() {
                    var tracks = document.querySelectorAll('.related-grid-track');
                    tracks.forEach(function(track) {
                        var nested = track.querySelectorAll('.related-grid-item');
                        for (var i = 0; i < nested.length; i++) {
                            if (nested[i].parentElement !== track) {
                                track.appendChild(nested[i]);
                            }
                        }
                    });
                }
                // After DOM fix, update Alpine itemCount
                function updateAlpineItemCount() {
                    var track = document.querySelector('.related-grid-track');
                    if (track) {
                        var items = track.querySelectorAll('.related-grid-item');
                        var section = track.closest('[x-data]');
                        if (section && section.__x) {
                            section.__x.$data.itemCount = items.length;
                        }
                    }
                }
                fixRelatedGrid();
                // Re-run after Alpine deferred init and after full page load
                document.addEventListener('DOMContentLoaded', fixRelatedGrid);
                window.addEventListener('load', fixRelatedGrid);
                // Also observe for Alpine re-renders
                if (window.MutationObserver) {
                    var gridTrack = document.querySelector('.related-grid-track');
                    if (gridTrack) {
                        var obs = new MutationObserver(function() {
                            if (gridTrack.querySelectorAll('.related-grid-item').length > gridTrack.children.length) {
                                fixRelatedGrid();
                            }
                        });
                        obs.observe(gridTrack, {childList: true, subtree: true});
                    }
                }
                </script>
            </div>
            </div>
            <div class="pagination">
            <template x-if="itemCount > pageSize">
                <div
                    class="flex items-center justify-center"
                    :id="$id('slider-nav')"
                >
                    <button
                        type="button"
                        aria-label="<?= $escaper->escapeHtmlAttr(__('Previous slide')) ?>"
                        :disabled="active === 0"
                        class="text-theme-blue flex-none p-3"
                        :class="{ 'opacity-25 pointer-events-none' : active === 0 }"
                        @click="scrollPrevious"
                    >
                        <?= $heroicons->chevronLeftHtml("w-5 h-5", 25, 25, ['aria-hidden' => 'true']) ?>
                    </button>
                    <div class="flex flex-wrap w-full md:w-auto justify-center">
                    <?php for ($i=0; $i < $itemCount; $i++): ?>
                        <button
                            type="button"
                            :class="{
                                    'hidden': (pageSize !== 1 && !!(<?= (int) $i ?> % pageSize))
                                }"
                            :aria-current="active === <?= (int) $i ?>"
                            :aria-label="hyva.str('<?= $escaper->escapeJs(__('Display slide %1')) ?>', (<?= (int) $i ?> / pageSize) + 1)"
                            @click="scrollTo(<?= (int) $i ?>)"
                        >
                            <span
                                class="shrink-0 block w-3 h-3 m-1 bg-theme-blue bg-opacity-25 rounded-full shadow cursor-pointer"
                                :class="{
                                    'bg-opacity-100': active === <?= (int) $i ?>,
                                    'bg-opacity-25': active !== <?= (int) $i ?>,
                                    'hidden': (pageSize !== 1 && !!(<?= (int) $i ?> % pageSize))
                                }"
                                @click="scrollTo(<?= (int) $i ?>)"
                            ></span>
                        </button>
                    <?php endfor; ?>
                    </div>
                    <button
                        aria-label="<?= $escaper->escapeHtmlAttr(__('Next slide')) ?>"
                        :disabled="active >= itemCount-pageSize"
                        class="text-theme-blue flex-none p-3"
                        :class="{ 'opacity-25 pointer-events-none' : active >= itemCount-pageSize }"
                        @click="scrollNext"
                     >
                        <?= $heroicons->chevronRightHtml("w-5 h-5", 25, 25, ['aria-hidden' => 'true']) ?>
                    </button>
                </div>
            </template>
            </div>
            <span id="<?= $escaper->escapeHtmlAttr($name) ?>-slider-end" tabindex="-1"></span>
        </div>
    <?php endif; ?>
</section>
<?php

if ($sharedItemRendererTemplate) {
    $sliderItemRenderer->setTemplate($sharedItemRendererTemplate);
}

?>
