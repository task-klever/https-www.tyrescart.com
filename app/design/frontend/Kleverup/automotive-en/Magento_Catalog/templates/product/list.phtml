            <script type="text/javascript">
            function changeBundlePrice(selectElement, unitRegularPrice, unitFinalPrice, partsCategory, isOfferProduct,
                discountAmount, discountQty, frontProductId, rearProductId, type) {
                const selectedQty = parseInt(selectElement.value);
                if (type == 'front') {
                    var currentProductId = frontProductId;
                } else {
                    var currentProductId = rearProductId;
                }
                var bundleBox = selectElement.closest('.product-box');
                if (isOfferProduct == 'No') {
                    var price = selectedQty * unitFinalPrice;
                    var changedPrice = parseFloat(price).toFixed(2);
                    var setPriceBox = bundleBox.querySelector('.set-price-box.id-' + currentProductId);
                    var setOfElement = setPriceBox.querySelector('.set-of');
                    setOfElement.textContent = 'Set of ' + selectedQty + ':';
                    var setOfPriceElement = setPriceBox.querySelector('.set-of-price');
                    setOfPriceElement.textContent = changedPrice;
                    var bundleSetPriceBox = document.querySelector('.bundle-set-price-box.id-' + frontProductId + '-' +
                        rearProductId);
                    var frontPriceSection = document.querySelector('.front-price-section.id-' + frontProductId);
                    var rearPriceSection = document.querySelector('.rear-price-section.id-' + rearProductId);
                    var frontSelectedPrice = frontPriceSection.querySelector('.set-of-price').textContent;
                    var rearSelectedPrice = rearPriceSection.querySelector('.set-of-price').textContent;
                    frontSelectedPrice = frontSelectedPrice.replace(/,/g, '');
                    rearSelectedPrice = rearSelectedPrice.replace(/,/g, '');
                    frontSelectedPrice = parseFloat(frontSelectedPrice);
                    rearSelectedPrice = parseFloat(rearSelectedPrice);
                    var frontSelectedQty = document.querySelector('.front-qty-select-' + frontProductId).querySelector(
                        ':checked').value;
                    var rearSelectedQty = document.querySelector('.rear-qty-select-' + rearProductId).querySelector(
                        ':checked').value;
                    var bundleSetPrice = frontSelectedPrice + rearSelectedPrice;
                    bundleSetPrice = parseFloat(bundleSetPrice).toFixed(2);
                    var bundleSetQty = parseFloat(frontSelectedQty) + parseFloat(rearSelectedQty);
                    bundleSetPriceBox.querySelector('.set-of').textContent = 'Set of ' + bundleSetQty + ':';
                    bundleSetPriceBox.querySelector('.bundle-set-of-price').textContent = bundleSetPrice;
                } else {
                    if (selectedQty >= discountQty) {
                        var price = selectedQty * unitFinalPrice;
                        var discount = (discountAmount / 100) * unitFinalPrice * discountQty;
                        if (selectedQty % discountQty === 0) {
                            var discountTimes = selectedQty / discountQty;
                            discount = discount * discountTimes;
                        } else {
                            var discountTimes = 1;
                            discount = discount * discountTimes;
                        }
                        price = price - discount;
