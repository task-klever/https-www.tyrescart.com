                        var price = selectedQty * unitFinalPrice;
                    }
                    var changedPrice = parseFloat(price).toFixed(2);
                    var setPriceBox = bundleBox.querySelector('.set-price-box.id-' + currentProductId);
                    var setOfElement = setPriceBox.querySelector('.set-of');
                    if (setOfElement) setOfElement.textContent = 'Set of ' + selectedQty + ':';
