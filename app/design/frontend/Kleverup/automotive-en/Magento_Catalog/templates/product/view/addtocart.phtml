<script>
   function warrantyPopup() {
       return {
           open: false,
           loading: false,
           productId: null,
           selectedOption: null,
           options: window.warrantyOptions.values || [],
           openPopup(productId) {
               console.log("call open Popup");    
               this.productId = window.productId;
               this.open = true;
           },
           closePopup() {
               this.open = false;
               this.selectedOption = null;
           },
            // New method to select option by title and add to cart
       selectOptionAndAdd(optionTitle) {
   		if(optionTitle.toLowerCase()=="yes"){
           const option = this.options.find(o => o.title.toLowerCase() === optionTitle.toLowerCase());
           if (!option) {
               alert("Option not found.");
               return;
           }
           this.selectedOption = option.id;
           this.addToCart('Optionyes');
   		}else{
   			this.addToCart('Optionno');
   		}
       },
           async addToCart(optionTitle) {
   			/*
               if (!this.selectedOption) {
                   alert("Please select a warranty option.");
                   return;
               }
   */
               console.log("call add to cart");
   			console.log(optionTitle);
               this.loading = true;
   const formnew = document.getElementById('product_addtocart_form');
               let formData = new FormData(formnew);
               formData.append('product', window.productId);
               formData.append('form_key', window.formKey);
   			if(optionTitle=='Optionyes'){
               formData.append(`options[${window.warrantyOptions.option_id}]`, this.selectedOption);
   			}
   try{
               let response = await fetch('<?= $block->getUrl("checkout/cart/add") ?>', {
                   method: 'POST',
                   body: formData,
                   headers: { 'X-Requested-With': 'XMLHttpRequest' },
                   credentials: 'same-origin'
               });
               if (response.ok) {
                   // Reload Hyvä minicart
                   window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                   document.getElementById("modal-name").classList.add("translate-x-full");
                   document.getElementById("modal-name-overlay").classList.add("hidden");
                   document.body.classList.remove("overflow-hidden");
                   this.closePopup();
   // Open mini cart reliably
           window.dispatchEvent(new CustomEvent('toggle-cart', { detail: { isOpen: true } }));
               } else {
                   alert("Failed to add product.");
               }
           }catch (err) {
                   console.error(err);
                   alert("An error occurred. Please try again.");
               } finally {
                   this.loading = false;
               }
           }
       }
   }
</script>
