<script>
   function addToCartHandler() {
       return {
           loading: false,
           async handleAddToCartClick() {
               const qtyField = document.querySelector('select[name="qty"]');
               const qty = qtyField ? parseInt(qtyField.value) || 1 : 1;
               console.log("Selected quantity →", qty);
               if (qty >= 4) {
                   console.log('Quantity ≥ 5 → open warranty popup');
                   if (typeof OpenModal === "function") {
                       OpenModal();
                   } else {
                       console.warn("⚠️ OpenModal() not defined");
                   }
                   return;
               }
               console.log('Quantity below 5 → Add to Cart via AJAX');
               const form = document.getElementById('product_addtocart_form');
               if (!form) {
                   console.error('Add to Cart form not found');
                   return;
               }
               const formData = new FormData(form);
               this.loading = true;
               try {
                   let response = await fetch('<?= $block->getUrl("checkout/cart/add") ?>', {
                       method: 'POST',
                       body: formData,
                       headers: { 'X-Requested-With': 'XMLHttpRequest' },
                       credentials: 'same-origin'
                   });
                   if (response.ok) {
                       console.log('✅ Product added to cart');
                       // Reload minicart data
                       window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                       // Open minicart
                       window.dispatchEvent(new CustomEvent('toggle-cart', { detail: { isOpen: true } }));
                   } else {
                       alert("Failed to add product.");
                   }
               } catch (err) {
                   console.error('Error adding to cart:', err);
                   alert("An error occurred. Please try again.");
               } finally {
                   this.loading = false;
               }
           }
       }
   }
</script>
