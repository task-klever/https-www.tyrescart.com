<?php
/** @var \MGS\Blog\Block\Post\View\Faq $block */
if (!$block->hasFaqs()) {
    return;
}
$faqs = $block->getFaqs();
$jsonLd = $block->getJsonLdData();
?>

<?php if ($jsonLd): ?>
<script type="application/ld+json">
<?= /* @noEscape */ $jsonLd ?>
</script>
<?php endif; ?>

<div class="faq-section-blog mt-8" x-data="{ openSection: null }">
    <h2 class="font-bold text-xl lg:text-2xl text-black leading-tight mb-4"><?= $escaper->escapeHtml(__('Frequently Asked Questions')) ?></h2>
    <div class="faq-accordion flex flex-col gap-2">
        <?php foreach ($faqs as $index => $faq): ?>
        <?php $key = 'blog_faq_' . $index; ?>
        <div class="faq-item border border-border-theme rounded-lg overflow-hidden">
            <button
                type="button"
                class="faq-btn w-full flex items-center justify-between px-5 py-4 text-left font-semibold text-base transition-all duration-300"
                :class="openSection === '<?= $key ?>' ? 'bg-theme-blue text-white' : 'bg-white text-black'"
                @click="openSection = openSection === '<?= $key ?>' ? null : '<?= $key ?>'"
            >
                <span><?= $escaper->escapeHtml($faq['title']) ?></span>
                <svg
                    class="faq-icon w-4 h-4 flex-shrink-0 ml-3 transition-transform duration-300"
                    :class="openSection === '<?= $key ?>' ? 'rotate-180' : ''"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
            <div
                x-show="openSection === '<?= $key ?>'"
                x-collapse
            >
                <div class="px-5 py-4 text-sm text-gray-700 leading-relaxed border-t border-border-theme">
                    <?= /* @noEscape */ $faq['description'] ?>
                </div>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
</div>
