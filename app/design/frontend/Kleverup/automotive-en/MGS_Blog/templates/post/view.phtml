<script>
   function hdwebShareWindowOpen(url, type, title = '') {
       function reverse(s) {
           return s.split("").reverse().join("");
       }
       var u;
       switch (type) {
           case 'facebook':
               u = reverse('<?= strrev('https://www.facebook.com/sharer/sharer.php?u=') ?>') + encodeURIComponent(url)
                   + '&quote=' + encodeURIComponent(title);
               break;
           case 'pinterest':
               u = reverse('<?= strrev('https://pinterest.com/pin/create/button/?url=') ?>') + encodeURIComponent(url)
                   + '&quote=' + encodeURIComponent(title);
               break;
           case 'twitter':
               u = reverse('<?= strrev('http://twitter.com/share?url=') ?>') + encodeURIComponent(url)
                   + '&quote=' + encodeURIComponent(title);
               break;
           case 'linkedin':
               u = reverse('<?= strrev('https://www.linkedin.com/shareArticle?mini=true&url=') ?>') + encodeURIComponent(url)
                   + '&quote=' + encodeURIComponent(title);
               break;
           case 'whatsapp':
               u = reverse('<?= strrev('https://web.whatsapp.com/send?text=') ?>') + encodeURIComponent(url)
                   + '&quote=' + encodeURIComponent(title);
               break;
       }
       if (u) {
           window.open(u, null, "width=600,height=400");
       }
   }
</script>
