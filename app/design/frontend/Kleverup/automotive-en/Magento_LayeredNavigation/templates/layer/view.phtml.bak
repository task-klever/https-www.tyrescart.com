<script>
  function FilterItems() {
    document.getElementById("view-all").classList.remove("translate-x-full");
    document.getElementById("view-all-overlay").classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
  }
  function CLoseAllFilter() {
    document.getElementById("view-all").classList.add("translate-x-full");
    document.getElementById("view-all-overlay").classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
  }
<?php if ($bundleProduct == 1) { ?>
    const brand = document.getElementById("brand");
    if (brand) {
    brand.addEventListener("change", function () {
        const selectedValue = this.value;
        if (selectedValue) {
        const url = new URL(window.location.href);
        // Set or replace the "brand" parameter
        url.searchParams.set("brand", selectedValue);
        // Redirect to the new URL
        window.location.href = url.toString();
        }
    });
    }
    const brandSidebar = document.getElementById("brandSideBar");
    if (brandSidebar) {
    brandSidebar.addEventListener("change", function () {
        const selectedValue = this.value;
        if (selectedValue) {
        const url = new URL(window.location.href);
        // Set or replace the "brand" parameter
        url.searchParams.set("brand", selectedValue);
        // Redirect to the new URL
        window.location.href = url.toString();
        }
    });
