                    <argument name="metadata" xsi:type="array">
                        <item name="icon" xsi:type="array">
                            <item name="src" xsi:type="string">Tamara_Checkout::images/tamara-icon-img.png</item>
                            <item name="attributes" xsi:type="array">
                                <item name="class" xsi:type="string">mt-1</item>
                                <item name="width" xsi:type="string">80</item>
                                <item name="height" xsi:type="string">24</item>
                                <item name="alt" xsi:type="string">Tamara</item>
                            </item>
                        </item>
                    </argument>
                </arguments>
            </block>
