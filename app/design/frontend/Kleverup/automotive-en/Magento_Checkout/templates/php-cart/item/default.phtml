<script>
function updateCartOption(itemId, optionId, value) {
    fetch('/customcart/update/option', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
            form_key: window.formKey,
            item_id: itemId,
            options: { [optionId]: value }
        })
    })
    .then(r => r.json())
    .then(res => {
        if (res.success) {
            window.dispatchEvent(new CustomEvent('reload-customer-section-data', {
                detail: { sections: ['cart'] }
            }));
            window.dispatchEvent(new CustomEvent('reload-cart-summary'));
        } else {
            alert(res.message || 'Failed to update item.');
        }
    });
}
</script>






