        <?php foreach ($productOptions as $productOption): ?>
            <?php if ($productOption->getType() == 'radio'): ?>
                <?php
                $optionId = (int)$productOption->getId();
                $selectedCustomOption = $selectedOptions['option_' . $optionId] ?? null;
                // Selected value is usually option type id (not the label)
                $selectedValue = $selectedCustomOption ? $selectedCustomOption->getValue() : '';
                $values = $productOption->getValues() ?: [];
                ?>
                <dt class="font-bold float-left clear-left mr-2 mb-2">
                    <?= $escaper->escapeHtml($productOption->getTitle()) ?>:
                </dt>
                <dd class="float-left">
                    <!-- Alpine component per option -->
                    <div
                        x-data="{
                            selected: '<?= $escaper->escapeHtmlAttr($selectedValue) ?>',
                            loading: false,
                            itemId: <?= (int)$item->getId() ?>,
                            optionId: <?= $optionId ?>,
                            async update() {
    this.loading = true;
    try {
        const payload = {
            form_key: '<?= $escaper->escapeHtmlAttr($formKey) ?>',
            item_id: this.itemId,
            options: { [this.optionId]: this.selected }
        };

        const res = await fetch('<?= $block->getUrl('customcart/update/option') ?>', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(payload)
        });

        const json = await res.json();

        if (json.success) {
            // ✅ Trigger reload
            const waitForCartReload = new Promise(resolve => {
                const handler = () => {
                    window.removeEventListener('hyva:customer-sections-reloaded', handler);
                    resolve();
                };
                window.addEventListener('hyva:customer-sections-reloaded', handler);
            });

            window.dispatchEvent(new CustomEvent('reload-customer-section-data', {
                detail: { sections: ['cart'] }
            }));

            // Wait until reload event fires before hiding loader
            await waitForCartReload;
        } else {
            alert(json.message || 'Failed to update item.');
        }
    } catch (err) {
        console.error(err);
        alert(err.message || 'Network error while updating item.');
    } finally {
        this.loading = false;
    }
}
                        }"
                        class="flex gap-3 items-center"
                    >


