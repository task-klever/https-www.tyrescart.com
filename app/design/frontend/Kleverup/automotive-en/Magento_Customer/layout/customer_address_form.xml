<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <update handle="hyva_form_validation"/>
    <body>
       <referenceBlock name="breadcrumbs" remove="false"/>

    <referenceBlock name="breadcrumbs">
        <!-- Home -->
        <action method="addCrumb">
            <argument name="crumbName" xsi:type="string">home</argument>
            <argument name="crumbInfo" xsi:type="array">
                <item name="label" xsi:type="string">Home</item>
                <item name="title" xsi:type="string">Go to Home Page</item>
                <item name="link" xsi:type="string">{{baseUrl}}</item>
            </argument>
        </action>

        <!-- My Account -->
        <action method="addCrumb">
            <argument name="crumbName" xsi:type="string">my_account</argument>
            <argument name="crumbInfo" xsi:type="array">
                <item name="label" xsi:type="string">My Account</item>
                <item name="title" xsi:type="string">My Account</item>
                <item name="link" xsi:type="string">{{baseUrl}}customer/account/</item>
            </argument>
        </action>

        <!-- Address Book -->
        <action method="addCrumb">
            <argument name="crumbName" xsi:type="string">address_book</argument>
            <argument name="crumbInfo" xsi:type="array">
                <item name="label" xsi:type="string">Address Book</item>
                <item name="title" xsi:type="string">Address Book</item>
                <item name="link" xsi:type="string">{{baseUrl}}customer/address/</item>
            </argument>
        </action>

        <!-- Edit Address -->
        <action method="addCrumb">
            <argument name="crumbName" xsi:type="string">edit_address</argument>
            <argument name="crumbInfo" xsi:type="array">
                <item name="label" xsi:type="string">Edit Address</item>
                <item name="title" xsi:type="string">Edit Address</item>
            </argument>
        </action>
    </referenceBlock>
    </body>
</page>
