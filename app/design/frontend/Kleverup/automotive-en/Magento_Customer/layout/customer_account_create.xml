<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Create New Customer Account</title>
    </head>
    <update handle="hyva_form_validation"/>
    <body>
         <!-- Ensure breadcrumbs block is present -->
        <referenceBlock name="breadcrumbs" remove="false"/>

        <!-- Add breadcrumb items -->
        <referenceBlock name="breadcrumbs">
            <!-- Home link -->
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">home</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string">Home</item>
                    <item name="title" xsi:type="string">Go to Home Page</item>
                    <item name="link" xsi:type="string">{{baseUrl}}</item>
                </argument>
            </action>
            <!-- Create account -->
            <action method="addCrumb">
                <argument name="crumbName" xsi:type="string">create_account</argument>
                <argument name="crumbInfo" xsi:type="array">
                    <item name="label" xsi:type="string">Create New Customer Account</item>
                    <item name="title" xsi:type="string">Create New Customer Account</item>
                </argument>
            </action>
        </referenceBlock>
    </body>
</page>
