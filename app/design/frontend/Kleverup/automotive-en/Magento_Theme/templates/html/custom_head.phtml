<!-- Dynamic Product Schema (for Magento) --> 

<?php
$currentProduct = $objectManager->get('Magento\Framework\Registry')->registry('current_product');
    $imageUrl = '';
    $imageUrl = $this->helper('Magento\Catalog\Helper\Image')
        ->init($currentProduct, 'product_base_image')
        ->constrainOnly(true)
        ->keepAspectRatio(true)
        ->keepTransparency(true)
        ->keepFrame(false)
        ->getUrl();
    $brandLabel = '';
    // Check if the current product exists
    if ($currentProduct) {
        // Get the product's "brand" attribute value
        $brandAttributeValue = $currentProduct->getData('brand');

        // If the attribute has a value
        if ($brandAttributeValue !== null && $brandAttributeValue !== '') {
            // Load the product attribute model
            $productAttribute = $currentProduct->getResource()->getAttribute('brand');

            // If the attribute model exists and it is a dropdown attribute
            if ($productAttribute && $productAttribute->usesSource()) {
                // Get the label of the selected option
                $brandLabel = $productAttribute->getSource()->getOptionText($brandAttributeValue);
            }
        }
    }
    $finalPrice = $productPriceViewModel->getPriceValue(FinalPrice::PRICE_CODE, $currentProduct);
    $currency = $storeManager->getStore()->getCurrentCurrencyCode();
    if ($currentProduct->isSaleable()) {
        $availability = "https://schema.org/InStock";
    } else {
        $availability = "https://schema.org/OutOfStock";
    }
    $productUrl = $currentProduct->getProductUrl();

    ?>


<script type="application/ld+json"> 

{ 

  "@context": "https://schema.org/", 

  "@type": "Product", 

  "name": "<?php echo $currentProduct->getName(); ?>", 

  "image": "<?php echo $imageUrl; ?>", 

  "description": "<?php echo strip_tags($currentProduct->getDescription()); ?>",

  "sku": "<?php echo $currentProduct->getSku(); ?>",

  "brand": { 

    "@type": "Brand", 

    "name": "<?php echo $brandLabel; ?>" 

  }, 

  "offers": { 

    "@type": "Offer", 

    "url": "<?php echo $productUrl; ?>", 

    "priceCurrency": "<?php echo $currency; ?>", 

    "price": "<?php echo number_format((float)$finalPrice, 2, '.', ''); ?>",

    "availability": "<?php echo $availability; ?>"

  } 

} 

</script> 

