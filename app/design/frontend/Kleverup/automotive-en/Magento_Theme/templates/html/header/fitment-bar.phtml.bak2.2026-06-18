                <div class="last-search-info flex-col min-h-auto lg:min-h-[94px] md:flex-row box relative w-full px-2 md:px-4 py-2 md:py-2.5 flex items-start md:items-end justify-start gap-2 md:gap-0 md:justify-between rounded-md bg-cover bg-center bg-no-repeat" style="background-image: url('<?= $block->getViewFileUrl('images/finder-result-bg.webp') ?>')">
                    <!-- Close Button -->
                    <button type="button"
                            @click="lastSearchHidden = true"
                            class="info-close-btn absolute top-1 right-1 w-5 h-5 flex items-center justify-center rounded-full bg-black/30 hover:bg-black/50 text-white transition-colors duration-200"
