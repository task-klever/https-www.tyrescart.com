        </div>

        <!-- ===== STEP HEADER CONTENT (matches screenshots) ===== -->
        <div x-show="drawerMode !== 'mode'" x-cloak class="shrink-0 border-b border-[#e1e1e1] bg-white md:py-3 grid grid-cols-1 lg:grid-cols-2 gap-3 py-2 md:py-0">

             <div class="last-search-info">
                <h4 class="text-lg md:text-2xl font-extrabold text-gray-900" x-text="drawerStepHeading"></h4>
                <p class="text-sm text-gray-600 leading-relaxed" x-text="drawerStepDescription"></p>
                <p x-show="drawerMode !== 'brand'" class="text-sm mt-1">
                    <button
