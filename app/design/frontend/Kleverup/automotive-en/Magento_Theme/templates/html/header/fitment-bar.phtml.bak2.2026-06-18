                            <img src="<?= $block->getViewFileUrl('images/follow-instructions.webp') ?>" alt="<?= __('Registration certificate example') ?>" class="h-[300px] lg:h-[400px] mx-auto w-auto rounded-[10px]" loading="lazy"/> 
                        </div>
                        <p class="mt-3 md:mt-5 text-center font-semibold leading-snug text-gray-900 text-sm md:text-base">
                            <?php echo __('You will find your car’s model in rows D.1, D.2 and D.3 of the registration certificate.') ?>
                        </p>
                    </div>
                </template>

                <template x-if="instructionsContext !== 'vehicle'">
                    <div class="min-h-[300px] md:min-h-[500px] lg:min-h-[650px] content-center">
                        <h3 class="text-lg md:text-2xl font-extrabold leading-tight "><?= __('How to read a tyre sidewall') ?></h3>
                        <p class="mt-1 md:mt-3 leading-relaxed text-gray-800 text-sm md:text-base">
                            <?php echo __('All tyres have different numbers on the sidewall which correspond to: section width, aspect ratio, construction code and rim diameter, load index and speed code.') ?>
                        </p>
                        <a
                           href="#"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="mt-3 inline-flex items-center gap-2 font-bold text-theme-blue hover:text-theme-dark transition-colors text-sm">
                            <span><?= __('Read full article') ?></span>
                            <svg class="h-4 w-4 follow-instructions-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                        <div class="mt-5 md:mt-10">
                            <div class="flex items-center justify-between gap-0 md:gap-3 [direction:ltr]">
                                <button
                                        type="button"
                                        @click="prevInstructionSlide()"
                                        class="flex h-8 w-8 md:h-11 md:w-11 items-center justify-center rounded-full border border-gray-300 text-gray-600 transition-colors hover:border-gray-500 hover:text-gray-900 disabled:cursor-not-allowed disabled:opacity-35"
                                        :disabled="instructionSlideIndex === 0">
                                    <svg class="h-3 md:h-5 w-3 md:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                                    </svg>
                                </button>
                                <div class="flex-1">
                                    <div class="mx-auto max-w-[360px]">
                                        <div class="tyre-illustration relative overflow-hidden">
                                            <img
                                                    src="<?= $block->getViewFileUrl('images/tyre-sidewall-guide.svg') ?>"
                                                    alt="<?= __('Tyre sidewall marking guide') ?>"
                                                    class="h-full w-full object-contain"
                                                    loading="lazy" />
                                            <div class="absolute inset-0 pointer-events-none select-none font-primary font-black leading-none tracking-tight">
                                                <span class="instruction-token absolute left-[17%] md:left-[16%] top-[38%] md:top-[36%] -rotate-[45deg] text-[1.3rem] md:text-[1.6rem]"
                                                      :class="isInstructionTokenActive('width') ? 'text-theme-blue' : 'text-white'">245</span>
                                                <span class="instruction-token absolute left-[30.5%] md:left-[29.5%] top-[28%] md:top-[24%] -rotate-[14deg] text-[1.2rem] md:text-[1.4rem] text-white">|</span>
                                                <span class="instruction-token absolute left-[34.5%] md:left-[33.5%] top-[24%] md:top-[17.5%] -rotate-[15deg] text-[1.3rem] md:text-[1.6rem]"
                                                      :class="isInstructionTokenActive('ratio') ? 'text-theme-blue' : 'text-white'">35</span>
                                                <span class="instruction-token absolute left-[49%] top-[23%] md:top-[15%] rotate-[8deg] text-[1.2rem] md:text-[1.5rem]"
                                                      :class="isInstructionTokenActive('rim') ? 'text-theme-blue' : 'text-white'">R19</span>
                                                <span class="instruction-token absolute left-[64.5%] top-[33%] md:top-[27%] rotate-[36deg] text-[1.2rem] md:text-[1.5rem]"
                                                      :class="isInstructionTokenActive('load') ? 'text-theme-blue' : 'text-white'">93Y</span>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="mt-0 md:mt-3 mx-auto text-center font-medium leading-snug text-gray-900 text-sm absolute left-1/2 -translate-x-1/2 w-[80%]"
                                       x-text="instructionSlides[instructionSlideIndex].caption"></p>
                                </div>
                                <button
                                        type="button"
                                        @click="nextInstructionSlide()"
                                        class="flex h-8 w-8 md:h-11 md:w-11 items-center justify-center rounded-full border border-gray-300 text-gray-600 transition-colors hover:border-gray-500 hover:text-gray-900 disabled:cursor-not-allowed disabled:opacity-35"
                                        :disabled="instructionSlideIndex === instructionSlides.length - 1">
                                    <svg class="h-3 md:h-5 w-3 md:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
        </div>
   


        </div>
    </div>
</div>


<script>
function fitmentBarDrawer() {
    return {
        // ── Bar state ──
        activeTab: 'bySize',
        isScrolled: false,
        showNewSearch: false,

        // ── By Size selections ──
        sizeWidth: '',
        sizeWidthValue: '',
        sizeHeight: '',
        sizeHeightValue: '',
        sizeRim: '',
        sizeRimValue: '',
        sizeOffset: '',
        sizeOffsetValue: '',

        // ── Rear Size selections ──
        sizeMode: 'front',  // 'front' or 'rear'
        sizeRearWidth: '',
        sizeRearWidthValue: '',
        sizeRearHeight: '',
        sizeRearHeightValue: '',
        sizeRearRim: '',
        sizeRearRimValue: '',
        sizeRearOffset: '',
        sizeRearOffsetValue: '',

        // ── By Vehicle selections ──
        isCarWheelsSearch: false,   // Data flag: fetch car-wheels data at step 5
        isVehicleOnlyTabs: false,   // UI flag: show only Vehicle + Size tabs in drawer
        isSizeOnlyTab: false,       // UI flag: show only Size tab in drawer (motorbike)
        vehMake: '',
        vehMakeName: '',
        vehModel: '',
        vehModelName: '',
        vehYear: '',
        vehEngine: '',
        vehEngineName: '',

        // ── By Brand selections ──
        brandId: '',
        brandName: '',
        brandUrlKey: '',
        brandWidth: '',
        brandWidthValue: '',
        brandHeight: '',
        brandHeightValue: '',
        brandRim: '',
        brandRimValue: '',
        // ── Brand Rear ──
        brandMode: 'front',
        brandRearWidth: '',
        brandRearWidthValue: '',
        brandRearHeight: '',
        brandRearHeightValue: '',
        brandRearRim: '',
        brandRearRimValue: '',

        // ── By EV selections ──
        evWidth: '',
        evWidthValue: '',
        evHeight: '',
        evHeightValue: '',
        evRim: '',
        evRimValue: '',
        // ── EV Rear ──
        evMode: 'front',
        evRearWidth: '',
        evRearWidthValue: '',
        evRearHeight: '',
        evRearHeightValue: '',
        evRearRim: '',
        evRearRimValue: '',

        // ── Last Search (separated by type) ──
        lastSearchBySize: null,
        lastSearchByWheelSize: null,
        lastSearchByMotorbikeSize: null,
        lastSearchByVehicle: null,
        lastSearchByWheelVehicle: null,
        lastSearchByBrand: null,
        lastSearchByEv: null,
        lastSearch: null,
        lastSearchHidden: false,
        lastSearchLabel: '',
        lastFitmentDisplay: '',
        lastFitmentSizeDisplay: '',

        // ── Drawer state ──
        drawerOpen: false,
        drawerMode: '',
        drawerStep: 1,
        drawerTotalSteps: 3,
        drawerTitle: '',
                drawerStepHeading: '',
                drawerStepDescription: '',
        drawerSearch: '',
        drawerSearchPlaceholder: '',
        drawerLoading: false,
        navigating: false,
        drawerItems: [],
        drawerCurrentValue: '',
        drawerChips: [],
        instructionsModalOpen: false,
        instructionsContext: '',
        instructionSlideIndex: 0,
        instructionSlides: [
            {
                caption: '<?= __('The three-digit number tells you how wide your tyre is.') ?>',
                highlightKey: 'width',
            },
            {
                caption: '<?= __('The aspect ratio tells you how tall your tyre is.') ?>',
                highlightKey: 'ratio',
            },
            {
                caption: '<?= __('The two-digit number tells you the diameter of the rims that the tyre is meant to be mounted on, in inches.') ?>',
                highlightKey: 'rim',
            },
            {
                caption: '<?= __('The tyre load index states how much weight a tyre can bear.') ?>',
                highlightKey: 'load',
            },
        ],

        // ── Base URL ──
        baseUrl: '<?= $baseUrl ?>',

        // ───────────────────── INIT ─────────────────────
        init() {
            // Load size search
            const savedSize = localStorage.getItem('fitmentLastSearch_bySize');
            if (savedSize) {
                try { this.lastSearchBySize = JSON.parse(savedSize); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_bySize'); }
            }
            // Load wheel size search
            const savedWheelSize = localStorage.getItem('fitmentLastSearch_byWheelSize');
            if (savedWheelSize) {
                try { this.lastSearchByWheelSize = JSON.parse(savedWheelSize); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byWheelSize'); }
            }
            // Load motorbike size search
            const savedMotorbikeSize = localStorage.getItem('fitmentLastSearch_byMotorbikeSize');
            if (savedMotorbikeSize) {
                try { this.lastSearchByMotorbikeSize = JSON.parse(savedMotorbikeSize); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byMotorbikeSize'); }
            }
            // Load vehicle search
            const savedVehicle = localStorage.getItem('fitmentLastSearch_byVehicle');
            if (savedVehicle) {
                try { this.lastSearchByVehicle = JSON.parse(savedVehicle); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byVehicle'); }
            }
            // Load wheel vehicle search
            const savedWheelVehicle = localStorage.getItem('fitmentLastSearch_byWheelVehicle');
            if (savedWheelVehicle) {
                try { this.lastSearchByWheelVehicle = JSON.parse(savedWheelVehicle); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byWheelVehicle'); }
            }
            // Load brand search
            const savedBrand = localStorage.getItem('fitmentLastSearch_byBrand');
            if (savedBrand) {
                try { this.lastSearchByBrand = JSON.parse(savedBrand); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byBrand'); }
            }
            // Load EV search
            const savedEv = localStorage.getItem('fitmentLastSearch_byEv');
            if (savedEv) {
                try { this.lastSearchByEv = JSON.parse(savedEv); }
                catch(e) { localStorage.removeItem('fitmentLastSearch_byEv'); }
            }
            // Migrate old single key if exists
            if (!savedSize && !savedVehicle) {
                const legacy = localStorage.getItem('fitmentLastSearch');
                if (legacy) {
                    try {
                        const parsed = JSON.parse(legacy);
                        if (parsed.type === 'bySize') { this.lastSearchBySize = parsed; localStorage.setItem('fitmentLastSearch_bySize', legacy); }
                        else { this.lastSearchByVehicle = parsed; localStorage.setItem('fitmentLastSearch_byVehicle', legacy); }
                        localStorage.removeItem('fitmentLastSearch');
                    } catch(e) { localStorage.removeItem('fitmentLastSearch'); }
                }
            }
            // Detect car-wheels page: fetch wheels data + show only 2 tabs
            if (window.location.pathname.indexOf('car-wheels') !== -1) {
                this.isCarWheelsSearch = true;
                this.isVehicleOnlyTabs = true;
            }
            // Detect motorcycle-tyres page: show only Size tab
            if (window.location.pathname.indexOf('motorcycle-tyres') !== -1) {
                this.isSizeOnlyTab = true;
                this.isVehicleOnlyTabs = true;
                this.activeTab = 'bySize';
            }

            // Default activeTab to whichever search exists (prefer most recent)
            const contextSize = this._getContextSizeSearch();
            const contextVehicle = this._getContextVehicleSearch();
            if (contextSize && contextVehicle) {
                this.activeTab = (contextVehicle.timestamp > contextSize.timestamp) ? 'byVehicle' : 'bySize';
            } else if (contextVehicle && !contextSize) {
                this.activeTab = 'byVehicle';
            }
            this._buildLastFitmentDisplay();
        },

        // ───────────────────── LAST FITMENT DISPLAY ─────────────────────
        // Returns true if any last search exists that's relevant to the current page
        _hasRelevantLastSearch() {
            if (this.isSizeOnlyTab) {
                return !!this.lastSearchByMotorbikeSize;
            }
            if (this.isVehicleOnlyTabs && this.isCarWheelsSearch) {
                return !!(this.lastSearchByWheelSize || this.lastSearchByWheelVehicle);
            }
            return !!(this.lastSearchBySize || this.lastSearchByVehicle || this.lastSearchByBrand || this.lastSearchByEv);
        },
        _relevantLastSearchCount() {
            if (this.isSizeOnlyTab) {
                return this.lastSearchByMotorbikeSize ? 1 : 0;
            }
            if (this.isVehicleOnlyTabs && this.isCarWheelsSearch) {
                return [this.lastSearchByWheelSize, this.lastSearchByWheelVehicle].filter(Boolean).length;
            }
            return [this.lastSearchBySize, this.lastSearchByVehicle, this.lastSearchByBrand, this.lastSearchByEv].filter(Boolean).length;
        },
        _getContextSizeSearch() {
            if (this.isSizeOnlyTab) return this.lastSearchByMotorbikeSize;
            if (this.isVehicleOnlyTabs && this.isCarWheelsSearch) return this.lastSearchByWheelSize;
            return this.lastSearchBySize;
        },
        _getContextVehicleSearch() {
            if (this.isCarWheelsSearch) return this.lastSearchByWheelVehicle;
            return this.lastSearchByVehicle;
        },
        _getActiveLastSearch() {
            let primary = null;
            // When drawer is open on a specific tab, show only that tab's last search
            if (this.drawerOpen && this.drawerMode !== 'mode') {
                if (this.drawerMode === 'brand' && !this.isVehicleOnlyTabs) return this.lastSearchByBrand || null;
                if (this.drawerMode === 'ev' && !this.isVehicleOnlyTabs) return this.lastSearchByEv || null;
                if (this.drawerMode === 'vehicle' && !this.isSizeOnlyTab) return this._getContextVehicleSearch() || null;
                if (this.drawerMode === 'size') return this._getContextSizeSearch() || null;
                return null;
            }
            // Sticky bar / drawer mode selector — use activeTab with fallback
            if (this.activeTab === 'byBrand' && !this.isVehicleOnlyTabs) primary = this.lastSearchByBrand;
            else if (this.activeTab === 'byEv' && !this.isVehicleOnlyTabs) primary = this.lastSearchByEv;
            else if (this.activeTab === 'byVehicle' && !this.isSizeOnlyTab) primary = this._getContextVehicleSearch();
            else primary = this._getContextSizeSearch();
            // Fallback: try allowed types
            if (!primary) {
                if (this.isSizeOnlyTab) {
                    primary = this.lastSearchByMotorbikeSize || null;
                } else if (this.isVehicleOnlyTabs && this.isCarWheelsSearch) {
                    primary = this.lastSearchByWheelSize || this.lastSearchByWheelVehicle || null;
                } else {
                    primary = this.lastSearchBySize || this.lastSearchByVehicle || this.lastSearchByBrand || this.lastSearchByEv || null;
                }
            }
            return primary;
        },
        _buildSizeString(search) {
            if (!search || !search.width || !search.rim) return '';
            let front = '';
            let rear = '';
            const hasRear = !!(search.rearWidth && search.rearRim && (search.isWheelSearch || (search.rearHeight)));
            if (search.isWheelSearch) {
                front = search.width + 'Jx' + search.rim + (search.offset ? ' ET' + search.offset : '');
                if (hasRear) {
                    rear = search.rearWidth + 'Jx' + search.rearRim + (search.rearOffset ? ' ET' + search.rearOffset : '');
                }
            } else {
                front = search.width + '/' + (search.height || '') + ' R' + search.rim;
                if (hasRear) {
                    rear = search.rearWidth + '/' + search.rearHeight + ' R' + search.rearRim;
                }
            }
            if (hasRear) {
                return '<?= __('Front') ?>: ' + front + '  |  <?php echo __('Rear') ?>: ' + rear;
            }
            return front;
        },
        _buildLastFitmentDisplay() {
            const search = this._getActiveLastSearch();
            this.lastSearch = search;
            this.lastFitmentSizeDisplay = '';
            if (!search) { this.lastFitmentDisplay = ''; return; }
            if (search.type === 'byBrand') {
                this.lastFitmentDisplay = search.brandName || '';
                this.lastFitmentSizeDisplay = this._buildSizeString(search);
            } else if (search.type === 'byEv') {
                this.lastFitmentDisplay = 'EV';
                this.lastFitmentSizeDisplay = this._buildSizeString(search);
            } else if (search.type === 'bySize' || search.type === 'byWheelSize' || search.type === 'byMotorbikeSize') {
                this.lastFitmentDisplay = this._buildSizeString(search);
            } else {
                this.lastFitmentDisplay = (search.makeName || '') + ' ' + (search.modelName || '') + ' ' + (search.year || '') + (search.engineName ? ' ' + search.engineName : '');
                this.lastFitmentSizeDisplay = this._buildSizeString(search);
            }
        },

        // ── "See results" — go straight to search results for last search ──
        seeLastResults() {
            const search = this.lastSearch;
            if (!search) return;
            if (search.type === 'byBrand') {
                const params = new URLSearchParams({
                    width: search.width, height: search.height, rim: search.rim,
                    brand: search.brandName
                });
                if (search.rearWidth && search.rearHeight && search.rearRim) {
                    params.set('width_rear', search.rearWidth);
                    params.set('height_rear', search.rearHeight);
                    params.set('rim_rear', search.rearRim);
                    params.set('product_list_limit', '500');
                }
                this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
            } else if (search.type === 'byEv') {
                const params = new URLSearchParams({
                    width: search.width, height: search.height, rim: search.rim,
                    ev: 'EV'
                });
                if (search.rearWidth && search.rearHeight && search.rearRim) {
                    params.set('width_rear', search.rearWidth);
                    params.set('height_rear', search.rearHeight);
                    params.set('rim_rear', search.rearRim);
                    params.set('product_list_limit', '500');
                }
                this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
            } else if (search.type === 'bySize' || search.type === 'byWheelSize' || search.type === 'byMotorbikeSize') {
                if (search.isWheelSearch) {
                    const params = new URLSearchParams({
                        width: search.width, rim: search.rim, offset: search.offset || '',
                        product_list_order: 'recommended', product_list_limit: '5000'
                    });
                    this._navigateTo(this.baseUrl + 'car-wheels?' + params.toString());
                } else if (search.type === 'byMotorbikeSize') {
                    const params = new URLSearchParams({
                        width: search.width, height: search.height, rim: search.rim,
                        product_list_order: 'recommended'
                    });
                    if (search.rearWidth && search.rearHeight && search.rearRim) {
                        params.set('width_rear', search.rearWidth);
                        params.set('height_rear', search.rearHeight);
                        params.set('rim_rear', search.rearRim);
                        params.set('product_list_limit', '500');
                    }
                    this._navigateTo(this.baseUrl + 'motorcycle-tyres?' + params.toString());
                } else {
                    const params = new URLSearchParams({
                        width: search.width,
                        height: search.height,
                        rim: search.rim
                    });
                    if (search.rearWidth && search.rearHeight && search.rearRim) {
                        params.set('width_rear', search.rearWidth);
                        params.set('height_rear', search.rearHeight);
                        params.set('rim_rear', search.rearRim);
                        params.set('product_list_limit', '500');
                    } else {
                        params.set('width_rear', '');
                        params.set('height_rear', '');
                        params.set('rim_rear', '');
                    }
                    this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
                }
            } else {
                if (search.width && search.rim) {
                    if (search.isWheelSearch) {
                        const params = new URLSearchParams({
                            width: search.width, rim: search.rim, offset: search.offset || '',
                            product_list_order: 'recommended', product_list_limit: '5000'
                        });
                        if (search.rearWidth && search.rearRim) {
                            params.set('width_rear', search.rearWidth);
                            params.set('rim_rear', search.rearRim);
                            params.set('offset_rear', search.rearOffset || '');
                        }
                        this._navigateTo(this.baseUrl + 'car-wheels?' + params.toString());
                    } else {
                        const params = new URLSearchParams({
                            width: search.width, height: search.height || '', rim: search.rim
                        });
                        if (search.rearWidth && search.rearHeight && search.rearRim) {
                            params.set('width_rear', search.rearWidth);
                            params.set('height_rear', search.rearHeight);
                            params.set('rim_rear', search.rearRim);
                            params.set('product_list_limit', '5000');
                        }
                        params.set('product_list_order', 'recommended');
                        this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
                    }
                } else {
                    const params = new URLSearchParams({
                        make: search.make, model: search.model, year: search.year
                    });
                    this._navigateTo(this.baseUrl + 'tyrefinder/ajax/getsearchbymodel?' + params.toString());
                }
            }
        },

        clearLastSearch() {
            localStorage.removeItem('fitmentLastSearch_bySize');
            localStorage.removeItem('fitmentLastSearch_byWheelSize');
            localStorage.removeItem('fitmentLastSearch_byMotorbikeSize');
            localStorage.removeItem('fitmentLastSearch_byVehicle');
            localStorage.removeItem('fitmentLastSearch_byWheelVehicle');
            localStorage.removeItem('fitmentLastSearch_byBrand');
            localStorage.removeItem('fitmentLastSearch_byEv');
            localStorage.removeItem('fitmentLastSearch');
            this.lastSearchBySize = null;
            this.lastSearchByWheelSize = null;
            this.lastSearchByMotorbikeSize = null;
            this.lastSearchByVehicle = null;
            this.lastSearchByWheelVehicle = null;
            this.lastSearchByBrand = null;
            this.lastSearchByEv = null;
            this.lastSearch = null;
            this.lastFitmentDisplay = '';
            this.showNewSearch = false;
        },

        restoreLastSearch() {
            const search = this.lastSearch;
            if (!search) return;
            if (search.type === 'bySize') {
                this.activeTab = 'bySize';
                this.sizeWidth = search.width || '';
                this.sizeWidthValue = search.widthValue || '';
                this.sizeHeight = search.height || '';
                this.sizeHeightValue = search.heightValue || '';
                this.sizeRim = search.rim || '';
                this.sizeRimValue = search.rimValue || '';
                this.sizeRearWidth = search.rearWidth || '';
                this.sizeRearWidthValue = search.rearWidthValue || '';
                this.sizeRearHeight = search.rearHeight || '';
                this.sizeRearHeightValue = search.rearHeightValue || '';
                this.sizeRearRim = search.rearRim || '';
                this.sizeRearRimValue = search.rearRimValue || '';
                this.sizeMode = (search.rearRim) ? 'rear' : 'front';
            } else if (search.type === 'byBrand') {
                this.brandId = search.brandId || '';
                this.brandName = search.brandName || '';
                this.brandWidth = search.width || '';
                this.brandWidthValue = search.widthValue || '';
                this.brandHeight = search.height || '';
                this.brandHeightValue = search.heightValue || '';
                this.brandRim = search.rim || '';
                this.brandRimValue = search.rimValue || '';
                this.brandRearWidth = search.rearWidth || '';
                this.brandRearWidthValue = search.rearWidthValue || '';
                this.brandRearHeight = search.rearHeight || '';
                this.brandRearHeightValue = search.rearHeightValue || '';
                this.brandRearRim = search.rearRim || '';
                this.brandRearRimValue = search.rearRimValue || '';
                this.brandMode = (search.rearRim) ? 'rear' : 'front';
            } else if (search.type === 'byEv') {
                this.evWidth = search.width || '';
                this.evWidthValue = search.widthValue || '';
                this.evHeight = search.height || '';
                this.evHeightValue = search.heightValue || '';
                this.evRim = search.rim || '';
                this.evRimValue = search.rimValue || '';
                this.evRearWidth = search.rearWidth || '';
                this.evRearWidthValue = search.rearWidthValue || '';
                this.evRearHeight = search.rearHeight || '';
                this.evRearHeightValue = search.rearHeightValue || '';
                this.evRearRim = search.rearRim || '';
                this.evRearRimValue = search.rearRimValue || '';
                this.evMode = (search.rearRim) ? 'rear' : 'front';
            } else {
                this.activeTab = 'byVehicle';
                this.vehMake = search.make || '';
                this.vehMakeName = search.makeName || '';
                this.vehModel = search.model || '';
                this.vehModelName = search.modelName || '';
                this.vehYear = search.year || '';
                this.vehEngine = search.engine || '';
                this.vehEngineName = search.engineName || '';
            }
        },

        // ───────────────────── OPEN DRAWER ─────────────────────
        openDrawer(mode) {
            const prevMode = this.drawerMode;
            const wasOpen = this.drawerOpen;
            this.drawerMode = mode;
            this.drawerSearch = '';
            this.drawerCurrentValue = '';
            this.drawerOpen = true;
            this._syncBodyScrollLock();

            // Sync activeTab with drawer mode so "Last search" banner updates
            if (mode === 'vehicle') {
                this.activeTab = 'byVehicle';
            } else if (mode === 'brand') {
                this.activeTab = 'byBrand';
            } else if (mode === 'ev') {
                this.activeTab = 'byEv';
            } else {
                this.activeTab = 'bySize';
            }
            this.lastSearchHidden = false;
            this._buildLastFitmentDisplay();

            if (mode === 'mode') {
                // Reset UI tab visibility based on page context
                if (window.location.pathname.indexOf('car-wheels') !== -1) {
                    this.isVehicleOnlyTabs = true;
                    this.isSizeOnlyTab = false;
                } else if (window.location.pathname.indexOf('motorcycle-tyres') !== -1) {
                    this.isVehicleOnlyTabs = true;
                    this.isSizeOnlyTab = true;
                } else {
                    this.isVehicleOnlyTabs = false;
                    this.isSizeOnlyTab = false;
                }
                this.drawerTotalSteps = 1;
                this.drawerStep = 1;
                this.drawerTitle = '<?= __('Search mode') ?>';
                this.drawerStepHeading = '';
                this.drawerStepDescription = '';
                this.drawerSearchPlaceholder = '';
                this.drawerLoading = false;
                this.drawerItems = [];
                this.drawerChips = [];
            } else if (mode === 'size') {
                this.drawerTotalSteps = 3;
                this.drawerTitle = this.sizeMode === 'rear' ? '<?= __('Rear Size') ?>' : '<?= __('Size') ?>';
                this.drawerChips = [];
                if (this.isCarWheelsSearch) {
                    // Car-wheels flow: width → rim → offset
                    const pfx = this.sizeMode === 'rear' ? '<?= __('Rear ') ?>' : '';
                    const w = this.sizeMode === 'rear' ? this.sizeRearWidth : this.sizeWidth;
                    const r = this.sizeMode === 'rear' ? this.sizeRearRim : this.sizeRim;
                    if (w && r) {
                        this.drawerChips = [
                            { label: pfx + '<?= __('Width') ?>', value: w },
                            { label: pfx + '<?= __('Rim') ?>', value: r }
                        ];
                        this.drawerStep = 3;
                        this._loadSizeStep(3);
                    } else if (w) {
                        this.drawerChips = [{ label: pfx + '<?= __('Width') ?>', value: w }];
                        this.drawerStep = 2;
                        this._loadSizeStep(2);
                    } else {
                        this.drawerStep = 1;
                        this._loadSizeStep(1);
                    }
                } else if (this.sizeMode === 'rear') {
                    // Rear mode: resume rear flow
                    if (this.sizeRearWidth && this.sizeRearHeight) {
                        this.drawerChips = [
                            { label: '<?= __('Rear Width') ?>', value: this.sizeRearWidth },
                            { label: '<?= __('Rear Height') ?>', value: this.sizeRearHeight }
                        ];
                        this.drawerStep = 3;
                        this._loadSizeStep(3);
                    } else if (this.sizeRearWidth) {
                        this.drawerChips = [{ label: '<?= __('Rear Width') ?>', value: this.sizeRearWidth }];
                        this.drawerStep = 2;
                        this._loadSizeStep(2);
                    } else {
                        this.drawerStep = 1;
                        this._loadSizeStep(1);
                    }
                } else {
                    // Front mode
                    if (this.sizeWidth && this.sizeHeight) {
                        this.drawerChips = [
                            { label: '<?= __('Width') ?>', value: this.sizeWidth },
                            { label: '<?= __('Height') ?>', value: this.sizeHeight }
                        ];
                        this.drawerStep = 3;
                        this._loadSizeStep(3);
                    } else if (this.sizeWidth) {
                        this.drawerChips = [{ label: '<?= __('Width') ?>', value: this.sizeWidth }];
                        this.drawerStep = 2;
                        this._loadSizeStep(2);
                    } else {
                        this.drawerStep = 1;
                        this._loadSizeStep(1);
                    }
                }
            } else if (mode === 'brand') {
                this.drawerTotalSteps = 4;
                this.drawerTitle = '<?= __('Car Brands') ?>';
                this.drawerChips = [];
                if (this.brandId && this.brandWidth && this.brandHeight) {
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Width') ?>', value: this.brandWidth },
                        { label: '<?= __('Height') ?>', value: this.brandHeight }
                    ];
                    this.drawerStep = 4;
                    this._loadBrandStep(4);
                } else if (this.brandId && this.brandWidth) {
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Width') ?>', value: this.brandWidth }
                    ];
                    this.drawerStep = 3;
                    this._loadBrandStep(3);
                } else if (this.brandId) {
                    this.drawerChips = [{ label: '<?= __('Brand') ?>', value: this.brandName }];
                    this.drawerStep = 2;
                    this._loadBrandStep(2);
                } else {
                    this.drawerStep = 1;
                    this._loadBrandStep(1);
                }
            } else if (mode === 'ev') {
                this.drawerTotalSteps = 3;
                this.drawerTitle = '<?= __('EV Tires') ?>';
                this.drawerChips = [];
                if (this.evWidth && this.evHeight) {
                    this.drawerChips = [
                        { label: '<?= __('Width') ?>', value: this.evWidth },
                        { label: '<?= __('Height') ?>', value: this.evHeight }
                    ];
                    this.drawerStep = 3;
                    this._loadEvStep(3);
                } else if (this.evWidth) {
                    this.drawerChips = [{ label: '<?= __('Width') ?>', value: this.evWidth }];
                    this.drawerStep = 2;
                    this._loadEvStep(2);
                } else {
                    this.drawerStep = 1;
                    this._loadEvStep(1);
                }
            } else {
                this.drawerTotalSteps = 5;
                this.drawerTitle = '<?= __('Vehicle') ?>';
                this.drawerChips = [];
                if (this.vehMake && this.vehModel && this.vehYear && this.vehEngine) {
                    this.drawerChips = [
                        { label: '<?= __('Make') ?>', value: this.vehMakeName },
                        { label: '<?= __('Model') ?>', value: this.vehModelName },
                        { label: '<?= __('Year') ?>', value: this.vehYear },
                        { label: '<?= __('Engine') ?>', value: this.vehEngineName }
                    ];
                    this.drawerStep = 5;
                    this._loadVehicleStep(5);
                } else if (this.vehMake && this.vehModel && this.vehYear) {
                    this.drawerChips = [
                        { label: '<?= __('Make') ?>', value: this.vehMakeName },
                        { label: '<?= __('Model') ?>', value: this.vehModelName },
                        { label: '<?= __('Year') ?>', value: this.vehYear }
                    ];
                    this.drawerStep = 4;
                    this._loadVehicleStep(4);
                } else if (this.vehMake && this.vehModel) {
                    this.drawerChips = [
                        { label: '<?= __('Make') ?>', value: this.vehMakeName },
                        { label: '<?= __('Model') ?>', value: this.vehModelName }
                    ];
                    this.drawerStep = 3;
                    this._loadVehicleStep(3);
                } else if (this.vehMake) {
                    this.drawerChips = [{ label: '<?= __('Make') ?>', value: this.vehMakeName }];
                    this.drawerStep = 2;
                    this._loadVehicleStep(2);
                } else {
                    this.drawerStep = 1;
                    this._loadVehicleStep(1);
                }
            }
        },

        closeDrawer() {
            this.drawerOpen = false;
            this._syncBodyScrollLock();
        },

        _navigateTo(url) {
            this.$nextTick(() => {
                setTimeout(() => { window.location.href = url; }, 100);
            });
        },

        openInstructionsModal(context = '') {
            this.instructionsModalOpen = true;
            this.instructionsContext = context || this.drawerMode || '';
            this.instructionSlideIndex = 0;
            this._syncBodyScrollLock();
        },

        closeInstructionsModal() {
            this.instructionsModalOpen = false;
            this._syncBodyScrollLock();
        },

        _syncBodyScrollLock() {
            if (this.drawerOpen || this.instructionsModalOpen) {
                document.body.classList.add('overflow-hidden');
                return;
            }

            document.body.classList.remove('overflow-hidden');
        },

        nextInstructionSlide() {
            if (this.instructionSlideIndex < this.instructionSlides.length - 1) {
                this.instructionSlideIndex += 1;
            }
        },

        prevInstructionSlide() {
            if (this.instructionSlideIndex > 0) {
                this.instructionSlideIndex -= 1;
            }
        },

        isInstructionTokenActive(key) {
            return this.instructionSlides[this.instructionSlideIndex]?.highlightKey === key;
        },

        // ───────────────────── GO BACK ─────────────────────
        goBack() {
            if (this.drawerMode === 'mode') return;

            // Step 1 goes back — in rear mode, return to front-complete state; otherwise "Search mode".
            if (this.drawerStep <= 1) {
                if (this.sizeMode === 'rear' && this.drawerMode === 'size') {
                    this.exitRearMode();
                    return;
                }
                this.drawerMode = 'mode';
                // Reset tab visibility based on page context
                if (window.location.pathname.indexOf('car-wheels') !== -1) {
                    this.isVehicleOnlyTabs = true;
                    this.isSizeOnlyTab = false;
                } else if (window.location.pathname.indexOf('motorcycle-tyres') !== -1) {
                    this.isVehicleOnlyTabs = true;
                    this.isSizeOnlyTab = true;
                } else {
                    this.isVehicleOnlyTabs = false;
                    this.isSizeOnlyTab = false;
                }
                this.drawerTotalSteps = 1;
                this.drawerStep = 1;
                this.drawerTitle = '<?= __('Search mode') ?>';
                this.drawerStepHeading = '';
                this.drawerStepDescription = '';
                this.drawerSearch = '';
                this.drawerCurrentValue = '';
                this.drawerLoading = false;
                this.drawerItems = [];
                this.drawerChips = [];
                this.drawerSearchPlaceholder = '';
                return;
            }

            this.drawerStep--;
            this.drawerSearch = '';
            this.drawerCurrentValue = '';
            if (this.drawerChips.length > 0) this.drawerChips.pop();

            if (this.drawerMode === 'size') {
                if (this.isCarWheelsSearch) {
                    // Car-wheels: width → rim → offset
                    const isRear = this.sizeMode === 'rear';
                    if (this.drawerStep === 1) {
                        if (isRear) { this.sizeRearWidth = ''; this.sizeRearWidthValue = ''; this.sizeRearRim = ''; this.sizeRearRimValue = ''; this.sizeRearOffset = ''; this.sizeRearOffsetValue = ''; }
                        else { this.sizeWidth = ''; this.sizeWidthValue = ''; this.sizeRim = ''; this.sizeRimValue = ''; this.sizeOffset = ''; this.sizeOffsetValue = ''; }
                    } else if (this.drawerStep === 2) {
                        if (isRear) { this.sizeRearRim = ''; this.sizeRearRimValue = ''; this.sizeRearOffset = ''; this.sizeRearOffsetValue = ''; }
                        else { this.sizeRim = ''; this.sizeRimValue = ''; this.sizeOffset = ''; this.sizeOffsetValue = ''; }
                    }
                } else if (this.sizeMode === 'rear') {
                    if (this.drawerStep === 1) {
                        this.sizeRearWidth = ''; this.sizeRearWidthValue = '';
                        this.sizeRearHeight = ''; this.sizeRearHeightValue = '';
                        this.sizeRearRim = ''; this.sizeRearRimValue = '';
                    } else if (this.drawerStep === 2) {
                        this.sizeRearHeight = ''; this.sizeRearHeightValue = '';
                        this.sizeRearRim = ''; this.sizeRearRimValue = '';
                    }
                } else {
                    if (this.drawerStep === 1) {
                        this.sizeWidth = ''; this.sizeWidthValue = '';
                        this.sizeHeight = ''; this.sizeHeightValue = '';
                        this.sizeRim = ''; this.sizeRimValue = '';
                    } else if (this.drawerStep === 2) {
                        this.sizeHeight = ''; this.sizeHeightValue = '';
                        this.sizeRim = ''; this.sizeRimValue = '';
                    }
                }
                this._loadSizeStep(this.drawerStep);
            } else if (this.drawerMode === 'brand') {
                if (this.drawerStep === 1) {
                    this.brandId = ''; this.brandName = ''; this.brandUrlKey = '';
                    this.brandWidth = ''; this.brandWidthValue = '';
                    this.brandHeight = ''; this.brandHeightValue = '';
                    this.brandRim = ''; this.brandRimValue = '';
                } else if (this.drawerStep === 2) {
                    this.brandWidth = ''; this.brandWidthValue = '';
                    this.brandHeight = ''; this.brandHeightValue = '';
                    this.brandRim = ''; this.brandRimValue = '';
                } else if (this.drawerStep === 3) {
                    this.brandHeight = ''; this.brandHeightValue = '';
                    this.brandRim = ''; this.brandRimValue = '';
                }
                this._loadBrandStep(this.drawerStep);
            } else if (this.drawerMode === 'ev') {
                if (this.drawerStep === 1) {
                    this.evWidth = ''; this.evWidthValue = '';
                    this.evHeight = ''; this.evHeightValue = '';
                    this.evRim = ''; this.evRimValue = '';
                } else if (this.drawerStep === 2) {
                    this.evHeight = ''; this.evHeightValue = '';
                    this.evRim = ''; this.evRimValue = '';
                }
                this._loadEvStep(this.drawerStep);
            } else {
                if (this.drawerStep === 1) {
                    this.vehMake = ''; this.vehMakeName = '';
                    this.vehModel = ''; this.vehModelName = '';
                    this.vehYear = '';
                    this.vehEngine = ''; this.vehEngineName = '';
                } else if (this.drawerStep === 2) {
                    this.vehModel = ''; this.vehModelName = '';
                    this.vehYear = '';
                    this.vehEngine = ''; this.vehEngineName = '';
                } else if (this.drawerStep === 3) {
                    this.vehYear = '';
                    this.vehEngine = ''; this.vehEngineName = '';
                } else if (this.drawerStep === 4) {
                    this.vehEngine = ''; this.vehEngineName = '';
                }
                this._loadVehicleStep(this.drawerStep);
            }
        },

        // Switch popup back to the initial "Search mode" screen.
        // Keeps lastSearch data (for the banner) but clears current selections/step state.
        switchToSearchMode() {
            this.drawerMode = 'mode';
            this.drawerTotalSteps = 1;
            this.drawerStep = 1;
            this.drawerTitle = '<?= __('Search mode') ?>';
            this.drawerStepHeading = '';
            this.drawerStepDescription = '';
            this.drawerSearch = '';
            this.drawerSearchPlaceholder = '';
            this.drawerCurrentValue = '';
            this.drawerLoading = false;
            this.drawerItems = [];
            this.drawerChips = [];

            // Clear current flow selections so the user starts from step 1 again.
            this.sizeMode = 'front';
            this.sizeWidth = '';
            this.sizeWidthValue = '';
            this.sizeHeight = '';
            this.sizeHeightValue = '';
            this.sizeRim = '';
            this.sizeRimValue = '';
            this.sizeRearWidth = '';
            this.sizeRearWidthValue = '';
            this.sizeRearHeight = '';
            this.sizeRearHeightValue = '';
            this.sizeRearRim = '';
            this.sizeRearRimValue = '';

            this.vehMake = '';
            this.vehMakeName = '';
            this.vehModel = '';
            this.vehModelName = '';
            this.vehYear = '';
            this.vehEngine = '';
            this.vehEngineName = '';

            this.brandId = '';
            this.brandName = '';
            this.brandUrlKey = '';
            this.brandWidth = '';
            this.brandWidthValue = '';
            this.brandHeight = '';
            this.brandHeightValue = '';
            this.brandRim = '';
            this.brandRimValue = '';

            this.evWidth = '';
            this.evWidthValue = '';
            this.evHeight = '';
            this.evHeightValue = '';
            this.evRim = '';
            this.evRimValue = '';
        },

        removeChip(idx) {
            const targetStep = idx + 1;
            while (this.drawerStep > targetStep) this.goBack();
        },

        // ───────────────────── REAR TYRE MODE ─────────────────────
        enterRearMode() {
            this.sizeMode = 'rear';
            this.sizeRearWidth = '';
            this.sizeRearWidthValue = '';
            this.sizeRearHeight = '';
            this.sizeRearHeightValue = '';
            this.sizeRearRim = '';
            this.sizeRearRimValue = '';
            this.drawerStep = 1;
            this.drawerCurrentValue = '';
            this.drawerSearch = '';
            this.drawerChips = [];
            this.drawerTitle = '<?= __('Rear Size') ?>';
            this._loadSizeStep(1);
        },

        exitRearMode() {
            this.sizeMode = 'front';
            this.sizeRearWidth = '';
            this.sizeRearWidthValue = '';
            this.sizeRearHeight = '';
            this.sizeRearHeightValue = '';
            this.sizeRearRim = '';
            this.sizeRearRimValue = '';
            // Restore front-complete state
            this.drawerStep = 3;
            this.drawerCurrentValue = this.sizeRimValue || this.sizeRim;
            this.drawerSearch = '';
            this.drawerChips = [
                { label: '<?= __('Width') ?>', value: this.sizeWidth },
                { label: '<?= __('Height') ?>', value: this.sizeHeight }
            ];
            this.drawerTitle = '<?= __('Size') ?>';
            this._loadSizeStep(3);
        },

        // ───────────────────── SELECT ITEM ─────────────────────
        selectDrawerItem(item) {
            this.drawerCurrentValue = item.value;
            this.drawerSearch = '';
            if (this.drawerMode === 'size') {
                this._selectSizeItem(item);
            } else if (this.drawerMode === 'brand') {
                this._selectBrandItem(item);
            } else if (this.drawerMode === 'ev') {
                this._selectEvItem(item);
            } else {
                this._selectVehicleItem(item);
            }
        },

        // ───────────────────── SIZE STEPS ─────────────────────
        async _loadSizeStep(step) {
            this.drawerItems = [];
            this.drawerLoading = true;
            const isRear = this.sizeMode === 'rear';
            const prefix = isRear ? '<?= __('Rear ') ?>' : '';
            const widthVal = isRear ? (this.sizeRearWidthValue || this.sizeRearWidth) : (this.sizeWidthValue || this.sizeWidth);
            const heightVal = isRear ? (this.sizeRearHeightValue || this.sizeRearHeight) : (this.sizeHeightValue || this.sizeHeight);
            const fetchType = isRear ? 'rear' : 'front';
            const isMotorbike = this.isSizeOnlyTab;
            const isWheels = this.isCarWheelsSearch;
            const widthEndpoint = isMotorbike ? 'tyrefinder/ajax/getmotorbikewidth' : 'tyrefinder/ajax/getwidth';
            const heightEndpoint = isMotorbike ? 'tyrefinder/ajax/getmotorbikeheight' : 'tyrefinder/ajax/getheight';
            const rimEndpoint = isMotorbike ? 'tyrefinder/ajax/getmotorbikerim' : 'tyrefinder/ajax/getrim';
            const categoryParam = isWheels ? { category: 'car-wheels' } : {};
            const rimVal = isRear ? (this.sizeRearRimValue || this.sizeRearRim) : (this.sizeRimValue || this.sizeRim);
            if (isWheels) {
                // Car-wheels: width → rim → offset
                if (step === 1) {
                    this.drawerStepHeading = prefix + '<?= __('Width') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Select the rear wheel width.') ?>'
                        : '<?= __('Select the wheel width.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search width') ?>';
                    const data = await this._fetch(widthEndpoint, { ...categoryParam });
                    this.drawerItems = this._parseLi(data.fronthtml || data.response || '');
                } else if (step === 2) {
                    this.drawerStepHeading = prefix + '<?= __('Rim Size') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Select the rear wheel rim size.') ?>'
                        : '<?= __('Select the wheel rim size.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search rim size') ?>';
                    const data = await this._fetch(rimEndpoint, {
                        width: widthVal, type: fetchType, ...categoryParam
                    });
                    this.drawerItems = this._parseLi(data.response || data.html || '');
                } else if (step === 3) {
                    this.drawerStepHeading = prefix + '<?= __('Offset') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Select the rear wheel offset.') ?>'
                        : '<?= __('Select the wheel offset.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search offset') ?>';
                    const data = await this._fetch('tyrefinder/ajax/getoffset', {
                        width: widthVal, rim: rimVal, type: fetchType
                    });
                    this.drawerItems = this._parseLi(data.response || '');
                }
            } else {
                // Tyres / Motorbike: width → height → rim
                if (step === 1) {
                    this.drawerStepHeading = prefix + '<?= __('Size') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Now select the rear tyre width.') ?>'
                        : '<?= __('Tell us the tyre size you are looking for.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search the size') ?>';
                    const data = await this._fetch(widthEndpoint, { ...categoryParam });
                    this.drawerItems = this._parseLi(data.fronthtml || data.response || '');
                } else if (step === 2) {
                    this.drawerStepHeading = prefix + '<?= __('Aspect Ratio') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Select the rear tyre aspect ratio.') ?>'
                        : '<?= __('Tell us the aspect ratio you are looking for.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search the aspect ratio') ?>';
                    const data = await this._fetch(heightEndpoint, {
                        width: widthVal, type: fetchType, ...categoryParam
                    });
                    this.drawerItems = this._parseLi(data.response || data.html || '');
                } else if (step === 3) {
                    this.drawerStepHeading = prefix + '<?= __('Rim Size') ?>';
                    this.drawerStepDescription = isRear
                        ? '<?= __('Select the rear tyre rim size.') ?>'
                        : '<?= __('Tell us the rim size you are looking for.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search the rim size') ?>';
                    const data = await this._fetch(rimEndpoint, {
                        width: widthVal, height: heightVal, type: fetchType, ...categoryParam
                    });
                    this.drawerItems = this._parseLi(data.response || data.html || '');
                }
            }
            this.drawerLoading = false;
            this.$nextTick(() => { if (this.$refs.drawerSearchInput) this.$refs.drawerSearchInput.focus(); });
        },

        _selectSizeItem(item) {
            if (this.isCarWheelsSearch) {
                // Car-wheels: width → rim → offset
                const isRear = this.sizeMode === 'rear';
                const pfx = isRear ? '<?= __('Rear ') ?>' : '';
                if (this.drawerStep === 1) {
                    if (isRear) {
                        this.sizeRearWidth = item.label; this.sizeRearWidthValue = item.value;
                        this.sizeRearRim = ''; this.sizeRearRimValue = '';
                        this.sizeRearOffset = ''; this.sizeRearOffsetValue = '';
                    } else {
                        this.sizeWidth = item.label; this.sizeWidthValue = item.value;
                        this.sizeRim = ''; this.sizeRimValue = '';
                        this.sizeOffset = ''; this.sizeOffsetValue = '';
                    }
                    this.drawerChips = [{ label: pfx + '<?= __('Width') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadSizeStep(2);
                } else if (this.drawerStep === 2) {
                    if (isRear) {
                        this.sizeRearRim = item.label; this.sizeRearRimValue = item.value;
                        this.sizeRearOffset = ''; this.sizeRearOffsetValue = '';
                    } else {
                        this.sizeRim = item.label; this.sizeRimValue = item.value;
                        this.sizeOffset = ''; this.sizeOffsetValue = '';
                    }
                    const w = isRear ? this.sizeRearWidth : this.sizeWidth;
                    this.drawerChips = [
                        { label: pfx + '<?= __('Width') ?>', value: w },
                        { label: pfx + '<?= __('Rim') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadSizeStep(3);
                } else if (this.drawerStep === 3) {
                    if (isRear) {
                        this.sizeRearOffset = item.label; this.sizeRearOffsetValue = item.value;
                    } else {
                        this.sizeOffset = item.label; this.sizeOffsetValue = item.value;
                    }
                    this.drawerCurrentValue = item.value;
                }
            } else if (this.sizeMode === 'rear') {
                if (this.drawerStep === 1) {
                    this.sizeRearWidth = item.label; this.sizeRearWidthValue = item.value;
                    this.sizeRearHeight = ''; this.sizeRearHeightValue = '';
                    this.sizeRearRim = ''; this.sizeRearRimValue = '';
                    this.drawerChips = [{ label: '<?= __('Rear Width') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadSizeStep(2);
                } else if (this.drawerStep === 2) {
                    this.sizeRearHeight = item.label; this.sizeRearHeightValue = item.value;
                    this.sizeRearRim = ''; this.sizeRearRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Rear Width') ?>', value: this.sizeRearWidth },
                        { label: '<?= __('Rear Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadSizeStep(3);
                } else if (this.drawerStep === 3) {
                    this.sizeRearRim = item.label; this.sizeRearRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            } else {
                if (this.drawerStep === 1) {
                    this.sizeWidth = item.label; this.sizeWidthValue = item.value;
                    this.sizeHeight = ''; this.sizeHeightValue = '';
                    this.sizeRim = ''; this.sizeRimValue = '';
                    this.drawerChips = [{ label: '<?= __('Width') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadSizeStep(2);
                } else if (this.drawerStep === 2) {
                    this.sizeHeight = item.label; this.sizeHeightValue = item.value;
                    this.sizeRim = ''; this.sizeRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Width') ?>', value: this.sizeWidth },
                        { label: '<?= __('Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadSizeStep(3);
                } else if (this.drawerStep === 3) {
                    this.sizeRim = item.label; this.sizeRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            }
        },

        // ───────────────────── VEHICLE STEPS ─────────────────────
        async _loadVehicleStep(step) {
            this.drawerItems = [];
            this.drawerLoading = true;
            if (step === 1) {
                this.drawerStepHeading = '<?= __('Vehicle') ?>';
                this.drawerStepDescription = '<?= __('Select your vehicle to continue.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search vehicle') ?>';
                const data = await this._fetch('tyrefinder/ajax/getallbrands', {});
                this.drawerItems = this._parseLi(data.response || data.html || '');
            } else if (step === 2) {
                // "Serie" in your reference design corresponds to the next level after make.
                this.drawerStepHeading = '<?= __('Serie') ?>';
                this.drawerStepDescription = '<?= __('Select serie.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search serie') ?>';
                const data = await this._fetch('tyrefinder/ajax/getmodel', { make: this.vehMake });
                this.drawerItems = this._parseLi(data.response || data.html || '');
            } else if (step === 3) {
                this.drawerStepHeading = '<?= __('Year') ?>';
                this.drawerStepDescription = '<?= __('Select year to continue.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search year') ?>';
                const data = await this._fetch('tyrefinder/ajax/getyear', {
                    make: this.vehMake, model: this.vehModel
                });
                this.drawerItems = this._parseLi(data.response || data.html || '');
            } else if (step === 4) {
                this.drawerStepHeading = '<?= __('Engine') ?>';
                this.drawerStepDescription = '<?= __('Select engine to continue.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search engine') ?>';
                const data = await this._fetch('tyrefinder/ajax/getmodifications', {
                    make: this.vehMake, model: this.vehModel, year: this.vehYear
                });
                this.drawerItems = this._parseLi(data.response || data.html || '');
            } else if (step === 5) {
                if (this.isCarWheelsSearch) {
                    this.drawerStepHeading = '<?= __('Car Wheels') ?>';
                    this.drawerStepDescription = '<?= __('Select your car wheel size.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search car wheels') ?>';
                } else {
                    this.drawerStepHeading = '<?= __('Car Tyres') ?>';
                    this.drawerStepDescription = '<?= __('Select your car tyre size.') ?>';
                    this.drawerSearchPlaceholder = '<?= __('Search car tyres') ?>';
                }
                const fetchParams = {
                    make: this.vehMake, model: this.vehModel, year: this.vehYear, modification: this.vehEngine
                };
                if (this.isCarWheelsSearch) {
                    fetchParams.category = 'car-wheels';
                }
                const data = await this._fetch('tyrefinder/ajax/getsearchbymodel', fetchParams);
                const tyreHtml = (data.enginesTyre || []).join('');
                this.drawerItems = this._parseTyreSize(tyreHtml);
            }
            this.drawerLoading = false;
            this.$nextTick(() => { if (this.$refs.drawerSearchInput) this.$refs.drawerSearchInput.focus(); });
        },

        _selectVehicleItem(item) {
            if (this.drawerStep === 1) {
                this.vehMake = item.value; this.vehMakeName = item.label;
                this.vehModel = ''; this.vehModelName = ''; this.vehYear = '';
                this.vehEngine = ''; this.vehEngineName = '';
                this.drawerChips = [{ label: '<?= __('Make') ?>', value: item.label }];
                this.drawerStep = 2;
                this._loadVehicleStep(2);
            } else if (this.drawerStep === 2) {
                this.vehModel = item.value; this.vehModelName = item.label;
                this.vehYear = '';
                this.vehEngine = ''; this.vehEngineName = '';
                this.drawerChips = [
                    { label: '<?= __('Make') ?>', value: this.vehMakeName },
                    { label: '<?= __('Model') ?>', value: item.label }
                ];
                this.drawerStep = 3;
                this._loadVehicleStep(3);
            } else if (this.drawerStep === 3) {
                this.vehYear = item.label;
                this.vehEngine = ''; this.vehEngineName = '';
                this.drawerChips = [
                    { label: '<?= __('Make') ?>', value: this.vehMakeName },
                    { label: '<?= __('Model') ?>', value: this.vehModelName },
                    { label: '<?= __('Year') ?>', value: item.label }
                ];
                this.drawerStep = 4;
                this._loadVehicleStep(4);
            } else if (this.drawerStep === 4) {
                this.vehEngine = item.value; this.vehEngineName = item.label;
                this.drawerChips = [
                    { label: '<?= __('Make') ?>', value: this.vehMakeName },
                    { label: '<?= __('Model') ?>', value: this.vehModelName },
                    { label: '<?= __('Year') ?>', value: this.vehYear },
                    { label: '<?= __('Engine') ?>', value: item.label, displayValue: item.chipLabel || item.label }
                ];
                this.drawerStep = 5;
                this._loadVehicleStep(5);
            } else if (this.drawerStep === 5) {
                const d = item.tyreData || {};
                const vehicleType = this.isCarWheelsSearch ? 'byWheelVehicle' : 'byVehicle';
                this._saveLastSearch(vehicleType, {
                    make: this.vehMake, makeName: this.vehMakeName,
                    model: this.vehModel, modelName: this.vehModelName,
                    year: this.vehYear,
                    engine: this.vehEngine, engineName: this.vehEngineName,
                    isWheelSearch: !!d.isWheel,
                    width: d.width || '', height: d.height || '', rim: d.rim || '',
                    offset: d.offset || '',
                    rearWidth: d.rearWidth || '', rearHeight: d.rearHeight || '', rearRim: d.rearRim || '',
                    rearOffset: d.rearOffset || '',
                    sizeLabel: item.label || ''
                });
                if (d.isWheel) {
                    const params = new URLSearchParams({
                        width: d.width || '', rim: d.rim || '', offset: d.offset || '',
                        width_rear: d.rearWidth || '', rim_rear: d.rearRim || '', offset_rear: d.rearOffset || '',
                        product_list_order: 'recommended', product_list_limit: '5000'
                    });
                    this._navigateTo(this.baseUrl + 'car-wheels?' + params.toString());
                } else {
                    const params = new URLSearchParams({
                        width: d.width || '', height: d.height || '', rim: d.rim || '',
                        width_rear: d.rearWidth || '', height_rear: d.rearHeight || '', rim_rear: d.rearRim || '',
                        product_list_order: 'recommended', product_list_limit: '5000'
                    });
                    this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
                }
            }
        },

        // ───────────────────── SUBMIT / SEARCH ─────────────────────
        submitDrawer() {
            if (this.drawerMode === 'size') this.searchBySize();
            else if (this.drawerMode === 'brand') this.searchByBrand();
            else if (this.drawerMode === 'ev') this.searchByEv();
            else this.searchByVehicle();
        },

        searchBySize() {
            if (this.isCarWheelsSearch) {
                // Car-wheels: width + rim + offset
                if (!this.sizeWidth || !this.sizeRim || !this.sizeOffset) return;
                this._saveLastSearch('byWheelSize', {
                    width: this.sizeWidth, widthValue: this.sizeWidthValue,
                    rim: this.sizeRim, rimValue: this.sizeRimValue,
                    offset: this.sizeOffset, offsetValue: this.sizeOffsetValue,
                    isWheelSearch: true
                });
                const params = new URLSearchParams({
                    width: this.sizeWidth, rim: this.sizeRim, offset: this.sizeOffset,
                    product_list_order: 'recommended', product_list_limit: '5000'
                });
                if (this.sizeRearWidth && this.sizeRearRim && this.sizeRearOffset) {
                    params.set('width_rear', this.sizeRearWidth);
                    params.set('rim_rear', this.sizeRearRim);
                    params.set('offset_rear', this.sizeRearOffset);
                }
                this._navigateTo(this.baseUrl + 'car-wheels?' + params.toString());
            } else {
                if (!this.sizeWidth || !this.sizeHeight || !this.sizeRim) return;
                const sizeType = this.isSizeOnlyTab ? 'byMotorbikeSize' : 'bySize';
                this._saveLastSearch(sizeType, {
                    width: this.sizeWidth, widthValue: this.sizeWidthValue,
                    height: this.sizeHeight, heightValue: this.sizeHeightValue,
                    rim: this.sizeRim, rimValue: this.sizeRimValue,
                    rearWidth: this.sizeRearWidth, rearWidthValue: this.sizeRearWidthValue,
                    rearHeight: this.sizeRearHeight, rearHeightValue: this.sizeRearHeightValue,
                    rearRim: this.sizeRearRim, rearRimValue: this.sizeRearRimValue
                });
                const params = new URLSearchParams({
                    width: this.sizeWidth, height: this.sizeHeight, rim: this.sizeRim
                });
                if (this.sizeRearWidth && this.sizeRearHeight && this.sizeRearRim) {
                    params.set('width_rear', this.sizeRearWidth);
                    params.set('height_rear', this.sizeRearHeight);
                    params.set('rim_rear', this.sizeRearRim);
                    params.set('product_list_limit', '500');
                } else {
                    params.set('width_rear', '');
                    params.set('height_rear', '');
                    params.set('rim_rear', '');
                }
                if (this.isSizeOnlyTab) {
                    params.set('product_list_order', 'recommended');
                }
                const categoryPath = this.isSizeOnlyTab ? 'motorcycle-tyres' : 'tyres';
                this._navigateTo(this.baseUrl + categoryPath + '?' + params.toString());
            }
        },

        searchBySizeSameAll() {
            if (this.isCarWheelsSearch) {
                if (!this.sizeWidth || !this.sizeRim || !this.sizeOffset) return;
            } else {
                if (!this.sizeWidth || !this.sizeHeight || !this.sizeRim) return;
            }
            this.exitRearMode();
        },

        searchByVehicle() {
            if (!this.vehMake || !this.vehModel || !this.vehYear || !this.vehEngine) return;
            this.openDrawer('vehicle');
        },

        resetAll() {
            this.sizeMode = 'front';
            this.sizeWidth = ''; this.sizeWidthValue = '';
            this.sizeHeight = ''; this.sizeHeightValue = '';
            this.sizeRim = ''; this.sizeRimValue = '';
            this.sizeOffset = ''; this.sizeOffsetValue = '';
            this.sizeRearWidth = ''; this.sizeRearWidthValue = '';
            this.sizeRearHeight = ''; this.sizeRearHeightValue = '';
            this.sizeRearRim = ''; this.sizeRearRimValue = '';
            this.sizeRearOffset = ''; this.sizeRearOffsetValue = '';
            this.vehMake = ''; this.vehMakeName = '';
            this.vehModel = ''; this.vehModelName = '';
            this.vehYear = '';
            this.vehEngine = ''; this.vehEngineName = '';
            this.brandMode = 'front';
            this.brandId = ''; this.brandName = ''; this.brandUrlKey = '';
            this.brandWidth = ''; this.brandWidthValue = '';
            this.brandHeight = ''; this.brandHeightValue = '';
            this.brandRim = ''; this.brandRimValue = '';
            this.brandRearWidth = ''; this.brandRearWidthValue = '';
            this.brandRearHeight = ''; this.brandRearHeightValue = '';
            this.brandRearRim = ''; this.brandRearRimValue = '';
            this.evMode = 'front';
            this.evWidth = ''; this.evWidthValue = '';
            this.evHeight = ''; this.evHeightValue = '';
            this.evRim = ''; this.evRimValue = '';
            this.evRearWidth = ''; this.evRearWidthValue = '';
            this.evRearHeight = ''; this.evRearHeightValue = '';
            this.evRearRim = ''; this.evRearRimValue = '';
            this.drawerChips = [];
            this.clearLastSearch();
        },

        _saveLastSearch(type, data) {
            const payload = { type, ...data, timestamp: Date.now() };
            const key = 'fitmentLastSearch_' + type;
            localStorage.setItem(key, JSON.stringify(payload));
            if (type === 'bySize') { this.lastSearchBySize = payload; this.activeTab = 'bySize'; }
            else if (type === 'byWheelSize') { this.lastSearchByWheelSize = payload; this.activeTab = 'bySize'; }
            else if (type === 'byMotorbikeSize') { this.lastSearchByMotorbikeSize = payload; this.activeTab = 'bySize'; }
            else if (type === 'byBrand') { this.lastSearchByBrand = payload; }
            else if (type === 'byEv') { this.lastSearchByEv = payload; }
            else if (type === 'byWheelVehicle') { this.lastSearchByWheelVehicle = payload; this.activeTab = 'byVehicle'; }
            else { this.lastSearchByVehicle = payload; this.activeTab = 'byVehicle'; }
            this.showNewSearch = false;
            this._buildLastFitmentDisplay();
        },

        // ───────────────────── FILTERED ITEMS ─────────────────────
        get filteredDrawerItems() {
            if (!this.drawerItems || !Array.isArray(this.drawerItems)) return [];
            if (!this.drawerSearch) return this.drawerItems;
            const q = this.drawerSearch.toLowerCase();
            return this.drawerItems.filter(i => i.label.toLowerCase().includes(q));
        },

        isDrawerItemActive(item) {
            return item.value === this.drawerCurrentValue || item.label === this.drawerCurrentValue;
        },

        // ───────────────────── FETCH HELPER ─────────────────────
        async _fetch(endpoint, params) {
            try {
                const body = new URLSearchParams({
                    form_key: hyva.getFormKey(),
                    uenc: btoa(window.location.href),
                    ...params
                });
                const res = await fetch(this.baseUrl + endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body, credentials: 'include', mode: 'cors'
                });
                return await res.json();
            } catch(e) {
                console.error('Fitment drawer fetch error:', e);
                return {};
            }
        },

        // ───────────────────── PARSE <li> HTML ─────────────────────
        _parseLi(html) {
            if (!html) return [];
            const doc = new DOMParser().parseFromString('<ul>' + html + '</ul>', 'text/html');
            const items = [];
            doc.querySelectorAll('li').forEach(li => {
                if (li.classList.contains('engine-li')) return;
                const supEl = li.querySelector('sup');
                const hpText = supEl ? supEl.textContent.trim() : '';
                if (supEl) supEl.remove();
                const aEl = li.querySelector('a');
                const label = aEl ? aEl.textContent.trim() : (li.querySelector('span')?.textContent || li.textContent || '').trim();
                if (!label) return;
                let value = li.getAttribute('data-value')
                         || li.getAttribute('data-id')
                         || li.getAttribute('value') || '';
                let urlKey = '';
                if (!value) {
                    const onclick = li.querySelector('a[onclick]')?.getAttribute('onclick')
                                 || li.querySelector('div[onclick]')?.getAttribute('onclick') || '';
                    const m = onclick.match(/\(\s*'([^']+)'/);
                    if (m) value = m[1];
                    const brandMatch = onclick.match(/selectTireBrand\s*\(\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*\)/);
                    if (brandMatch) urlKey = brandMatch[3];
                }
                if (!value) {
                    const id = li.querySelector('a[id]')?.getAttribute('id') || '';
                    const im = id.match(/(?:front|rear)-\w+-(.+)/);
                    if (im) value = im[1];
                }
                if (!value) value = label;
                // Extract image URL if present
                const img = li.querySelector('img');
                const image = img ? (img.getAttribute('src') || '') : '';
                if (!items.find(i => i.value === value && i.label === label)) {
                    const displayLabel = hpText ? label + '<sup class="text-[10px] text-gray-500 ml-0.5">' + hpText + '</sup>' : label;
                    const chipLabel = hpText ? label + '<sup class="text-[10px] ml-0.5" style="color:#fff">' + hpText + '</sup>' : label;
                    const item = { label: label + (hpText ? ' ' + hpText : ''), value, displayLabel, chipLabel };
                    if (urlKey) item.urlKey = urlKey;
                    if (image) item.image = image;
                    items.push(item);
                }
            });
            return items;
        },

        // ───────────────────── BRAND STEPS ─────────────────────
        async _loadBrandStep(step) {
            this.drawerItems = [];
            this.drawerLoading = true;
            const isRear = this.brandMode === 'rear';
            const prefix = isRear ? '<?= __('Rear ') ?>' : '';
            const fetchType = isRear ? 'rear' : 'front';
            const widthVal = isRear ? (this.brandRearWidthValue || this.brandRearWidth) : (this.brandWidthValue || this.brandWidth);
            const heightVal = isRear ? (this.brandRearHeightValue || this.brandRearHeight) : (this.brandHeightValue || this.brandHeight);
            if (step === 1) {
                this.drawerStepHeading = '<?= __('Car Brand') ?>';
                this.drawerStepDescription = '<?= __('Select a car brand to continue.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search brand') ?>';
                const data = await this._fetch('tyrefinder/ajax/gettirebrands', {});
                this.drawerItems = this._parseLi(data.response || '');
            } else if (step === 2) {
                this.drawerStepHeading = prefix + '<?= __('Width') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Now select the rear tyre width.') ?>'
                    : '<?= __('Select the tyre width for') ?> ' + this.brandName + '.';
                this.drawerSearchPlaceholder = '<?= __('Search width') ?>';
                const data = await this._fetch('tyrefinder/ajax/getbrandwidths', { brand_id: this.brandId });
                this.drawerItems = this._parseButton(data.fronthtml || '');
            } else if (step === 3) {
                this.drawerStepHeading = prefix + '<?= __('Aspect Ratio') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Select the rear tyre aspect ratio.') ?>'
                    : '<?= __('Select the aspect ratio.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search aspect ratio') ?>';
                const data = await this._fetch('tyrefinder/ajax/getbrandheights', {
                    brand_id: this.brandId, width: widthVal, type: fetchType
                });
                this.drawerItems = this._parseButton(data.response || '');
            } else if (step === 4) {
                this.drawerStepHeading = prefix + '<?= __('Rim Size') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Select the rear tyre rim size.') ?>'
                    : '<?= __('Select the rim size.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search rim size') ?>';
                const data = await this._fetch('tyrefinder/ajax/getbrandrims', {
                    brand_id: this.brandId, width: widthVal, height: heightVal, type: fetchType
                });
                this.drawerItems = this._parseButton(data.response || '');
            }
            this.drawerLoading = false;
            this.$nextTick(() => { if (this.$refs.drawerSearchInput) this.$refs.drawerSearchInput.focus(); });
        },

        _selectBrandItem(item) {
            const isRear = this.brandMode === 'rear';
            if (isRear) {
                if (this.drawerStep === 2) {
                    this.brandRearWidth = item.label; this.brandRearWidthValue = item.value;
                    this.brandRearHeight = ''; this.brandRearHeightValue = '';
                    this.brandRearRim = ''; this.brandRearRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Rear Width') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadBrandStep(3);
                } else if (this.drawerStep === 3) {
                    this.brandRearHeight = item.label; this.brandRearHeightValue = item.value;
                    this.brandRearRim = ''; this.brandRearRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Rear Width') ?>', value: this.brandRearWidth },
                        { label: '<?= __('Rear Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 4;
                    this._loadBrandStep(4);
                } else if (this.drawerStep === 4) {
                    this.brandRearRim = item.label; this.brandRearRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            } else {
                if (this.drawerStep === 1) {
                    this.brandId = item.value; this.brandName = item.label; this.brandUrlKey = item.urlKey || '';
                    this.brandWidth = ''; this.brandWidthValue = '';
                    this.brandHeight = ''; this.brandHeightValue = '';
                    this.brandRim = ''; this.brandRimValue = '';
                    this.drawerChips = [{ label: '<?= __('Brand') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadBrandStep(2);
                } else if (this.drawerStep === 2) {
                    this.brandWidth = item.label; this.brandWidthValue = item.value;
                    this.brandHeight = ''; this.brandHeightValue = '';
                    this.brandRim = ''; this.brandRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Width') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadBrandStep(3);
                } else if (this.drawerStep === 3) {
                    this.brandHeight = item.label; this.brandHeightValue = item.value;
                    this.brandRim = ''; this.brandRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Brand') ?>', value: this.brandName },
                        { label: '<?= __('Width') ?>', value: this.brandWidth },
                        { label: '<?= __('Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 4;
                    this._loadBrandStep(4);
                } else if (this.drawerStep === 4) {
                    this.brandRim = item.label; this.brandRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            }
        },

        enterBrandRearMode() {
            this.brandMode = 'rear';
            this.brandRearWidth = '';
            this.brandRearWidthValue = '';
            this.brandRearHeight = '';
            this.brandRearHeightValue = '';
            this.brandRearRim = '';
            this.brandRearRimValue = '';
            this.drawerStep = 2;
            this.drawerCurrentValue = '';
            this.drawerSearch = '';
            this.drawerChips = [{ label: '<?= __('Brand') ?>', value: this.brandName }];
            this.drawerTitle = '<?= __('Rear Size') ?>';
            this._loadBrandStep(2);
        },

        exitBrandRearMode() {
            this.brandMode = 'front';
            this.brandRearWidth = '';
            this.brandRearWidthValue = '';
            this.brandRearHeight = '';
            this.brandRearHeightValue = '';
            this.brandRearRim = '';
            this.brandRearRimValue = '';
            this.drawerStep = 4;
            this.drawerCurrentValue = this.brandRimValue || this.brandRim;
            this.drawerSearch = '';
            this.drawerChips = [
                { label: '<?= __('Brand') ?>', value: this.brandName },
                { label: '<?= __('Width') ?>', value: this.brandWidth },
                { label: '<?= __('Height') ?>', value: this.brandHeight }
            ];
            this.drawerTitle = '<?= __('Car Brands') ?>';
            this._loadBrandStep(4);
        },

        searchByBrandSameAll() {
            if (!this.brandId || !this.brandWidth || !this.brandHeight || !this.brandRim) return;
            this.exitBrandRearMode();
        },

        searchByBrand() {
            if (!this.brandId || !this.brandWidth || !this.brandHeight || !this.brandRim) return;
            this._saveLastSearch('byBrand', {
                brandId: this.brandId, brandName: this.brandName, brandUrlKey: this.brandUrlKey,
                width: this.brandWidth, widthValue: this.brandWidthValue,
                height: this.brandHeight, heightValue: this.brandHeightValue,
                rim: this.brandRim, rimValue: this.brandRimValue,
                rearWidth: this.brandRearWidth, rearWidthValue: this.brandRearWidthValue,
                rearHeight: this.brandRearHeight, rearHeightValue: this.brandRearHeightValue,
                rearRim: this.brandRearRim, rearRimValue: this.brandRearRimValue
            });
            const params = new URLSearchParams({
                width: this.brandWidth, height: this.brandHeight, rim: this.brandRim,
                brand: this.brandName
            });
            if (this.brandRearWidth && this.brandRearHeight && this.brandRearRim) {
                params.set('width_rear', this.brandRearWidth);
                params.set('height_rear', this.brandRearHeight);
                params.set('rim_rear', this.brandRearRim);
                params.set('product_list_limit', '500');
            }
            this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
        },

        // ───────────────────── EV STEPS ─────────────────────
        async _loadEvStep(step) {
            this.drawerItems = [];
            this.drawerLoading = true;
            const isRear = this.evMode === 'rear';
            const prefix = isRear ? '<?= __('Rear ') ?>' : '';
            const fetchType = isRear ? 'rear' : 'front';
            const widthVal = isRear ? (this.evRearWidthValue || this.evRearWidth) : (this.evWidthValue || this.evWidth);
            const heightVal = isRear ? (this.evRearHeightValue || this.evRearHeight) : (this.evHeightValue || this.evHeight);
            if (step === 1) {
                this.drawerStepHeading = prefix + '<?= __('EV Width') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Now select the rear EV tyre width.') ?>'
                    : '<?= __('Select the EV tyre width.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search width') ?>';
                const data = await this._fetch('tyrefinder/ajax/getevwidths', {});
                this.drawerItems = this._parseButton(data.fronthtml || '');
            } else if (step === 2) {
                this.drawerStepHeading = prefix + '<?= __('Aspect Ratio') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Select the rear EV tyre aspect ratio.') ?>'
                    : '<?= __('Select the EV tyre aspect ratio.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search aspect ratio') ?>';
                const data = await this._fetch('tyrefinder/ajax/getevheights', {
                    width: widthVal, type: fetchType
                });
                this.drawerItems = this._parseButton(data.response || '');
            } else if (step === 3) {
                this.drawerStepHeading = prefix + '<?= __('Rim Size') ?>';
                this.drawerStepDescription = isRear
                    ? '<?= __('Select the rear EV tyre rim size.') ?>'
                    : '<?= __('Select the EV tyre rim size.') ?>';
                this.drawerSearchPlaceholder = '<?= __('Search rim size') ?>';
                const data = await this._fetch('tyrefinder/ajax/getevrims', {
                    width: widthVal, height: heightVal, type: fetchType
                });
                this.drawerItems = this._parseButton(data.response || '');
            }
            this.drawerLoading = false;
            this.$nextTick(() => { if (this.$refs.drawerSearchInput) this.$refs.drawerSearchInput.focus(); });
        },

        _selectEvItem(item) {
            const isRear = this.evMode === 'rear';
            if (isRear) {
                if (this.drawerStep === 1) {
                    this.evRearWidth = item.label; this.evRearWidthValue = item.value;
                    this.evRearHeight = ''; this.evRearHeightValue = '';
                    this.evRearRim = ''; this.evRearRimValue = '';
                    this.drawerChips = [{ label: '<?= __('Rear Width') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadEvStep(2);
                } else if (this.drawerStep === 2) {
                    this.evRearHeight = item.label; this.evRearHeightValue = item.value;
                    this.evRearRim = ''; this.evRearRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Rear Width') ?>', value: this.evRearWidth },
                        { label: '<?= __('Rear Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadEvStep(3);
                } else if (this.drawerStep === 3) {
                    this.evRearRim = item.label; this.evRearRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            } else {
                if (this.drawerStep === 1) {
                    this.evWidth = item.label; this.evWidthValue = item.value;
                    this.evHeight = ''; this.evHeightValue = '';
                    this.evRim = ''; this.evRimValue = '';
                    this.drawerChips = [{ label: '<?= __('Width') ?>', value: item.label }];
                    this.drawerStep = 2;
                    this._loadEvStep(2);
                } else if (this.drawerStep === 2) {
                    this.evHeight = item.label; this.evHeightValue = item.value;
                    this.evRim = ''; this.evRimValue = '';
                    this.drawerChips = [
                        { label: '<?= __('Width') ?>', value: this.evWidth },
                        { label: '<?= __('Height') ?>', value: item.label }
                    ];
                    this.drawerStep = 3;
                    this._loadEvStep(3);
                } else if (this.drawerStep === 3) {
                    this.evRim = item.label; this.evRimValue = item.value;
                    this.drawerCurrentValue = item.value;
                }
            }
        },

        enterEvRearMode() {
            this.evMode = 'rear';
            this.evRearWidth = '';
            this.evRearWidthValue = '';
            this.evRearHeight = '';
            this.evRearHeightValue = '';
            this.evRearRim = '';
            this.evRearRimValue = '';
            this.drawerStep = 1;
            this.drawerCurrentValue = '';
            this.drawerSearch = '';
            this.drawerChips = [];
            this.drawerTitle = '<?= __('Rear Size') ?>';
            this._loadEvStep(1);
        },

        exitEvRearMode() {
            this.evMode = 'front';
            this.evRearWidth = '';
            this.evRearWidthValue = '';
            this.evRearHeight = '';
            this.evRearHeightValue = '';
            this.evRearRim = '';
            this.evRearRimValue = '';
            this.drawerStep = 3;
            this.drawerCurrentValue = this.evRimValue || this.evRim;
            this.drawerSearch = '';
            this.drawerChips = [
                { label: '<?= __('Width') ?>', value: this.evWidth },
                { label: '<?= __('Height') ?>', value: this.evHeight }
            ];
            this.drawerTitle = '<?= __('EV Tires') ?>';
            this._loadEvStep(3);
        },

        searchByEvSameAll() {
            if (!this.evWidth || !this.evHeight || !this.evRim) return;
            this.exitEvRearMode();
        },

        searchByEv() {
            if (!this.evWidth || !this.evHeight || !this.evRim) return;
            this._saveLastSearch('byEv', {
                width: this.evWidth, widthValue: this.evWidthValue,
                height: this.evHeight, heightValue: this.evHeightValue,
                rim: this.evRim, rimValue: this.evRimValue,
                rearWidth: this.evRearWidth, rearWidthValue: this.evRearWidthValue,
                rearHeight: this.evRearHeight, rearHeightValue: this.evRearHeightValue,
                rearRim: this.evRearRim, rearRimValue: this.evRearRimValue
            });
            const params = new URLSearchParams({
                width: this.evWidth, height: this.evHeight, rim: this.evRim,
                ev: 'EV'
            });
            if (this.evRearWidth && this.evRearHeight && this.evRearRim) {
                params.set('width_rear', this.evRearWidth);
                params.set('height_rear', this.evRearHeight);
                params.set('rim_rear', this.evRearRim);
                params.set('product_list_limit', '500');
            }
            this._navigateTo(this.baseUrl + 'tyres?' + params.toString());
        },

        // ───────────────────── PARSE <button> HTML ─────────────────────
        _parseButton(html) {
            if (!html) return [];
            const doc = new DOMParser().parseFromString('<div>' + html + '</div>', 'text/html');
            const items = [];
            doc.querySelectorAll('button').forEach(btn => {
                const label = (btn.querySelector('span')?.textContent || btn.textContent || '').trim();
                if (!label) return;
                let value = '';
                const onclick = btn.getAttribute('onclick') || '';
                const m = onclick.match(/\(\s*'?([^',)]+)'?\s*,\s*'([^']*)'/);
                if (m) { value = m[1]; }
                if (!value) value = label;
                if (!items.find(i => i.value === value && i.label === label)) {
                    items.push({ label, value });
                }
            });
            return items;
        },

        _parseTyreSize(html) {
            if (!html) return [];
            const doc = new DOMParser().parseFromString('<ul>' + html + '</ul>', 'text/html');
            const items = [];
            doc.querySelectorAll('li').forEach(li => {
                const a = li.querySelector('a[onclick]');
                if (!a) return;
                const onclick = a.getAttribute('onclick') || '';
                const isFactory = li.classList.contains('oem');
                const sizeLabel = isFactory ? 'FACTORY SIZE' : 'OPTIONAL SIZE';
                const labelClass = isFactory ? 'factory' : 'optional';

                // Check runflat
                const isRunflat = !!li.querySelector('.runflat-label img');

                // Match showproduct (tyres)
                const m = onclick.match(/showproduct\(\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*(?:,\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*)?\)/);
                if (m) {
                    const tyreData = {
                        width: m[1], height: m[2], rim: m[3],
                        rearWidth: m[4] || '', rearHeight: m[5] || '', rearRim: m[6] || ''
                    };
                    const rimSize = m[3];
                    const frontSize = m[1] + '/' + m[2] + 'R' + m[3];
                    const rearSize = tyreData.rearWidth ? tyreData.rearWidth + '/' + tyreData.rearHeight + 'R' + tyreData.rearRim : '';
                    const isStaggered = !!tyreData.rearWidth;
                    const displayText = rimSize + '" | ' + frontSize;
                    let label = displayText;
                    if (isStaggered) {
                        label += ' | Rear: ' + rearSize;
                    }
                    items.push({ label, value: label, tyreData, sizeLabel, labelClass, displayText, frontSize, rearSize, isStaggered, isRunflat, isTyreCard: true });
                    return;
                }

                // Match showWheelProduct (wheels)
                // Format: showWheelProduct(rimWidth, rimDia, rimOffset, tireWidth, tireAspect [, rearRimWidth, rearRimDia, rearRimOffset, rearTireWidth, rearTireAspect])
                const w = onclick.match(/showWheelProduct\(([^)]+)\)/);
                if (w) {
                    const args = w[1].split(',').map(s => s.trim().replace(/'/g, ''));
                    let tyreData, frontWheelSize, frontTireSize, rearWheelSize, rearTireSize, isStaggered;
                    if (args.length >= 10) {
                        // Staggered: 10 params
                        tyreData = {
                            width: args[0], rim: args[1], offset: args[2],
                            tireWidth: args[3], tireHeight: args[4],
                            rearWidth: args[5], rearRim: args[6], rearOffset: args[7],
                            rearTireWidth: args[8], rearTireHeight: args[9],
                            isWheel: true
                        };
                        frontWheelSize = args[0] + 'Jx' + args[1] + ' ET' + args[2];
                        frontTireSize = args[3] + '/' + args[4] + 'R' + args[1];
                        rearWheelSize = args[5] + 'Jx' + args[6] + ' ET' + args[7];
                        rearTireSize = args[8] + '/' + args[9] + 'R' + args[6];
                        isStaggered = true;
                    } else {
                        // Non-staggered: 5 params
                        tyreData = {
                            width: args[0], rim: args[1], offset: args[2],
                            tireWidth: args[3] || '', tireHeight: args[4] || '',
                            rearWidth: '', rearRim: '', rearOffset: '',
                            isWheel: true
                        };
                        frontWheelSize = args[0] + 'Jx' + args[1] + ' ET' + args[2];
                        frontTireSize = (args[3] && args[4]) ? args[3] + '/' + args[4] + 'R' + args[1] : '';
                        rearWheelSize = '';
                        rearTireSize = '';
                        isStaggered = false;
                    }
                    const frontSize = frontTireSize ? frontWheelSize + ' | ' + frontTireSize : frontWheelSize;
                    const rearSize = isStaggered ? (rearTireSize ? rearWheelSize + ' | ' + rearTireSize : rearWheelSize) : '';
                    const displayText = frontSize;
                    let label = displayText;
                    if (isStaggered) {
                        label += ' | Rear: ' + rearSize;
                    }
                    items.push({ label, value: label, tyreData, sizeLabel, labelClass, displayText, frontSize, rearSize, isStaggered, isRunflat, isTyreCard: true });
                    return;
                }
            });
            return items;
        }
    }
}
</script>
<?php $hyvaCsp->registerInlineScript() ?>
