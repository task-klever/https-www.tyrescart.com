        <!-- ===== SEARCH MODE VIEW ===== -->
        <div x-show="drawerMode === 'mode'" x-cloak class="flex flex-1 flex-col gap-4 overflow-y-auto py-2">
        <div class="h-full relative flex flex-col justify-center">
         <div class="flex flex-col gap-2 mb-3">
                <h4 class="text-xl font-extrabold text-gray-900"><?= __('Search mode') ?></h4>
                <p class="text-sm text-gray-600 leading-relaxed"><?php echo __('There is only one step left to discover the perfect tyres for your car. Select one of the following options to continue.') ?></p>
            </div>
            <!-- Desktop: split layout (40% buttons + 60% search) | Mobile: stacked -->
            <div class="mt-1 flex flex-col lg:flex-row gap-4">
                <!-- Left: Search mode image cards (40% on desktop) -->
                <div class="w-full lg:w-[40%]">
                    <div class="grid gap-2 grid-cols-2">
