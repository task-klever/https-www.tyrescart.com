        </div>

       


        

       

        <!-- ===== SELECTED CHIPS ===== -->

        <div x-show="drawerMode !== 'mode'" x-cloak class="flex flex-wrap gap-0 xl:gap-3 items-start xl:items-center border-b border-[#e1e1e1] mb-2 flex-col xl:flex-row">

            <!-- ===== SEARCH INPUT ===== -->
            <div x-show="drawerMode !== 'mode'" class="shrink-0 py-2 md:py-3 search-input-box min-w-full xl:min-w-[500px]" x-cloak>
                <div class="relative brand-serach-input">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input type="text" x-model="drawerSearch" x-ref="drawerSearchInput"
                        class="w-full pl-10 pr-10 py-2.5 border border-gray-200 rounded-[10px] text-sm focus:outline-none focus:ring-2 focus:ring-theme-blue/30 focus:border-theme-blue transition-all"
                        :placeholder="drawerSearchPlaceholder">
                    <button x-show="drawerSearch" @click="drawerSearch = ''; $refs.drawerSearchInput.focus()"
