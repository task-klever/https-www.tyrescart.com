                      x-text="drawerStep + '/' + drawerTotalSteps"></span>
            </div>

            <button @click="closeDrawer()"
                    class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-200 text-gray-500 hover:text-gray-800 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- ===== MODE TABS (Vehicle / Size / Brand / EV) ===== -->
        <div x-show="drawerMode !== 'mode'" x-cloak class="shrink-0 border-b border-[#e1e1e1] bg-white py-2">
            <div class="grid bg-gray-100 rounded-xl p-0.5 w-full dwaver-buttons-tab"
