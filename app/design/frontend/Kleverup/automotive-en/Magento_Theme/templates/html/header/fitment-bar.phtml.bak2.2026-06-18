<!-- ============================================================
     FITMENT BAR + TYRE SIZE DRAWER
     Pirelli-style: sticky bar + last fitment panel + sliding drawer
     Colors: theme-blue (#00843D), theme-yellow (#FFC300)
     ============================================================ -->

<div x-data="fitmentBarDrawer()" x-init="init()" @keydown.escape.window="closeDrawer(); closeInstructionsModal()" class="fitment-bar-wrapper">

    <!-- ===================== STICKY FITMENT BAR ===================== -->
    <div class="fitment-bar w-full bg-white border-b border-gray-200 transition-all duration-300"
         :class="{ '': isScrolled }"
         @scroll.window="isScrolled = (window.scrollY > 10)"
         id="fitment-bar">

        <!-- ===== LAST FITMENT PANEL (Pirelli: style_lastSearch / style_lastVersion) ===== -->
        <div x-show="_hasRelevantLastSearch() && !showNewSearch" x-cloak
             class="fitment-last-panel bg-white">
            <div class="container-theme mx-auto px-3 md:px-4 py-3 md:py-4">
                <!-- Tab switcher (show if multiple relevant types have saved searches) -->

                <div x-show="_relevantLastSearchCount() > 1" class="flex justify-center mb-3">
                    <div class="flex bg-gray-100 rounded-full p-0.5 flex-wrap justify-center gap-0.5">
                        <button x-show="_getContextSizeSearch()" @click="activeTab = 'bySize'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'bySize' ? 'bg-theme-dark text-white font-bold' : 'text-gray-500 hover:text-gray-700'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-tyre-size text-sm mr-1"></i><?php echo __('Size') ?>
                        </button>
                        <button x-show="!isSizeOnlyTab && _getContextVehicleSearch()" @click="activeTab = 'byVehicle'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'byVehicle' ? 'bg-theme-dark text-white font-bold' : 'text-gray-500 hover:text-gray-700'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-vehicel text-sm mr-1"></i><?php echo __('Vehicle') ?>
                        </button>
                        <button x-show="!isVehicleOnlyTabs && lastSearchByBrand" @click="activeTab = 'byBrand'; drawerMode = 'brand'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'byBrand' ? 'bg-theme-dark text-white font-bold' : 'text-gray-500 hover:text-gray-700'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-tyre-brand text-sm mr-1"></i><?php echo __('Brand') ?>
                        </button>
                        <button x-show="!isVehicleOnlyTabs && lastSearchByEv" @click="activeTab = 'byEv'; drawerMode = 'ev'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'byEv' ? 'bg-theme-dark text-white font-bold' : 'text-gray-500 hover:text-gray-700'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-ev text-sm mr-1"></i><?php echo __('EV') ?>
                        </button>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
                    <!-- Left: Last search info -->
                    <div class="flex items-center gap-3 flex-1 min-w-0">
                        <!-- Tyre icon -->
                        <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7 text-theme-dark" width="24" height="24" fill="none" viewBox="0 0 20 20">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.667 10a1.667 1.667 0 1 1-3.334 0 1.667 1.667 0 0 1 3.334 0ZM10 4.167v4.166M15.55 8.2l-3.975 1.292M13.425 14.717l-2.45-3.375"/>
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 15.833a5.833 5.833 0 1 0 0-11.666 5.833 5.833 0 0 0 0 11.666ZM4.45 8.2l3.975 1.292M6.575 14.717l2.45-3.375"/>
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 18.333a8.333 8.333 0 1 0 0-16.666 8.333 8.333 0 0 0 0 16.666Z"/>
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm text-gray-500 leading-tight"><?php echo __('Search tyre fitments for:') ?></p>
                            <p class="text-lg md:text-xl font-black text-theme-dark leading-tight truncate" x-text="lastFitmentDisplay"></p>
                            <p x-show="lastFitmentSizeDisplay" class="text-xs md:text-sm font-medium text-gray-500 leading-tight mt-0.5" x-text="lastFitmentSizeDisplay"></p>
                        </div>
                    </div>
                    <!-- Right: CTA buttons (Pirelli yellow) -->
                    <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto shrink-0">
                        <button @click="seeLastResults()"
                                class="fitment-cta-yellow flex items-center justify-center gap-2 px-5 py-2.5 md:py-3 rounded-full font-bold text-sm md:text-base transition-all duration-200 w-full sm:w-auto">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" width="24" height="24" fill="none" viewBox="0 0 20 20">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.667 10a1.667 1.667 0 1 1-3.334 0 1.667 1.667 0 0 1 3.334 0ZM10 4.167v4.166M15.55 8.2l-3.975 1.292M13.425 14.717l-2.45-3.375"/>
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 15.833a5.833 5.833 0 1 0 0-11.666 5.833 5.833 0 0 0 0 11.666ZM4.45 8.2l3.975 1.292M6.575 14.717l2.45-3.375"/>
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 18.333a8.333 8.333 0 1 0 0-16.666 8.333 8.333 0 0 0 0 16.666Z"/>
                            </svg>
                            <span><?php echo __('See results') ?></span>
                        </button>
                        <button @click="showNewSearch = true; openDrawer('mode')"
                                class="fitment-cta-yellow flex items-center justify-center gap-2 px-5 py-2.5 md:py-3 rounded-full font-bold text-sm md:text-base transition-all duration-200 w-full sm:w-auto">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            <span><?php echo __('New search') ?></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== NORMAL SEARCH BAR (shows when no last search OR user clicks "New search") ===== -->
        <div x-show="!_hasRelevantLastSearch() || showNewSearch"
             class="bg-theme-dark">
            <div class="container-theme mx-auto px-3 py-2">
                <div class="flex flex-wrap lg:flex-nowrap items-center gap-2 lg:gap-3">

                    <!-- Back to last search (if user clicked "New search") -->
                    <button x-show="_hasRelevantLastSearch() && showNewSearch" x-cloak
                            @click="showNewSearch = false"
                            class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-all"
                            title="<?= __('Back to last search') ?>">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>

                    <!-- Tab Switcher -->
                    <div x-show="!isSizeOnlyTab" class="flex bg-white/10 rounded-full p-0.5 shrink-0">
                        <button @click="activeTab = 'bySize'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'bySize' ? 'bg-theme-yellow text-theme-dark font-bold' : 'text-white/80 hover:text-white'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-tyre-size text-sm mr-1"></i><?= __('Car Tyres') ?>
                        </button>
                        <button @click="activeTab = 'byVehicle'; _buildLastFitmentDisplay()"
                                :class="activeTab === 'byVehicle' ? 'bg-theme-yellow text-theme-dark font-bold' : 'text-white/80 hover:text-white'"
                                class="px-3 py-1.5 text-xs md:text-sm rounded-full transition-all duration-200 whitespace-nowrap">
                            <i class="icon icon-vehicel text-sm mr-1"></i><?= __('Vehicle') ?>
                        </button>
                    </div>

                    <!-- BY SIZE: Button that opens drawer -->
                    <div x-show="activeTab === 'bySize'" x-transition class="flex-1 min-w-0">
                        <div class="flex flex-wrap md:flex-nowrap items-center gap-2">
                            <button @click="openDrawer('size')"
                                    class="fitment-dropdown w-full md:flex-1 flex items-center justify-between bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-sm text-white hover:border-theme-yellow/50 transition-all">
                                <span :class="sizeWidth ? 'text-white' : 'text-white/50'"
                                      x-text="sizeWidth ? (isCarWheelsSearch ? (sizeWidth + 'Jx' + (sizeRim || '…') + (sizeOffset ? ' ET' + sizeOffset : '')) : (sizeWidth + '/' + (sizeHeight || '…') + ' R' + (sizeRim || '…') + (sizeRearWidth ? (' | Rear: ' + sizeRearWidth + '/' + (sizeRearHeight || '…') + ' R' + (sizeRearRim || '…')) : ''))) : (isCarWheelsSearch ? '<?= __('Select Width / Rim / Offset') ?>' : '<?= __('Select Width / Height / Rim') ?>')"></span>
                                <svg class="w-3 h-3 ml-2 text-white/50 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                            <button @click="searchBySize()"
                                    class="w-full md:w-auto px-5 py-2 rounded-lg text-sm font-bold transition-all duration-200 whitespace-nowrap"
                                    :class="(isCarWheelsSearch ? sizeOffset : sizeRim) ? 'bg-theme-yellow text-theme-dark hover:brightness-110 hover:shadow-lg' : 'bg-theme-yellow/30 text-theme-dark/50 cursor-not-allowed'"
                                    :disabled="isCarWheelsSearch ? !sizeOffset : !sizeRim">
                                <?php echo __('SEARCH') ?> <i class="icon icon-three-arrow text-f9 ml-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- BY VEHICLE: Button that opens drawer -->
                    <div x-show="activeTab === 'byVehicle'" x-transition x-cloak class="flex-1 min-w-0">
                        <div class="flex flex-wrap md:flex-nowrap items-center gap-2">
                            <button @click="openDrawer('vehicle')"
                                    class="fitment-dropdown w-full md:flex-1 flex items-center justify-between bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-sm text-white hover:border-theme-yellow/50 transition-all">
                                <span :class="vehMakeName ? 'text-white' : 'text-white/50'"
                                      x-text="vehMakeName ? (vehMakeName + (vehModelName ? ' > ' + vehModelName : '') + (vehYear ? ' > ' + vehYear : '') + (vehEngineName ? ' > ' + vehEngineName : '')) : '<?= __('Select Make / Model / Year / Engine') ?>'"></span>
                                <svg class="w-3 h-3 ml-2 text-white/50 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                            <button @click="searchByVehicle()"
                                    class="w-full md:w-auto px-5 py-2 rounded-lg text-sm font-bold transition-all duration-200 whitespace-nowrap"
