                </div>
                <!-- Right: Tyre size search bar (60% on desktop) — OpenSearch powered -->
                <div class="w-full lg:w-[60%]">
                    <div class="search search-full-tyre-by-size-drawer w-full transition-all">
                        <form action="<?= $baseUrl ?>tyres?" class="tyre-size-search-full-form-drawer relative w-full py-2 border border-gray-200 rounded-[10px] text-sm focus:outline-none focus:ring-2 focus:ring-theme-blue/30 focus:border-theme-blue transition-all" method="GET" x-data="{...hyva.formValidation($el), ...initOsTyreSizeSearchDrawer()}" @submit.prevent="submitOsTyreSizeSearchDrawerForm()">
                            <div class="flex items-center flex-wrap gap-2 pl-2 pr-8" id="os-tyresize-selected-items-drawer">
                                <a class="active os-front-selected-atag-drawer hidden inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-theme-blue text-white shrink-0">
                                    <span class="os-front-selected-drawer ml-1 font-normal"></span>
                                    <button type="button" class="os-remove-selected-drawer cursor-pointer remove ml-1">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </button>
                                </a>
                                <a class="active os-rear-selected-atag-drawer hidden inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-theme-blue text-white shrink-0">
                                    <span class="os-rear-selected-drawer ml-1 font-normal"></span>
                                    <button type="button" class="os-remove-selected-drawer cursor-pointer remove ml-1">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </button>
                                </a>
                                <input type="text" class="input-text pl-0 pr-1 py-2 text-sm text-theme-blue h-auto border-0 font-normal leading-none focus:outline-none focus:ring-0 bg-transparent flex-1 min-w-[80px] w-5/6" id="os-tyresize-input-drawer" autocomplete="off" placeholder="<?= __('Search Tyre Size e.g 1956515 or 195/65 R15') ?>" title="Search here">
                            </div>
                            <div class="field field-error absolute -bottom-[27px]">
                                <div class="messages hidden text-sm" id="os-tyresize-min-chars-drawer"><?= __('Please enter 3 or more characters') ?></div>
                                <div class="messages hidden text-sm" id="os-tyresize-no-result-drawer"><?= __('No results found') ?></div>
                                <div class="messages hidden text-sm" id="os-tyresize-limit-drawer"><?= __('You can only select 2 items') ?></div>
                            </div>
                            <input type="hidden" id="os-tyresize-drawer-width" name="width" value="" data-validate='{ "required": true }' data-msg-required="<?= $escaper->escapeHtmlAttr('You must select a size') ?>" />
                            <input type="hidden" id="os-tyresize-drawer-height" name="height" value="" />
                            <input type="hidden" id="os-tyresize-drawer-rim" name="rim" value="" />
                            <input type="hidden" id="os-tyresize-drawer-rear-width" name="width_rear" value="" />
                            <input type="hidden" id="os-tyresize-drawer-rear-height" name="height_rear" value="" />
                            <input type="hidden" id="os-tyresize-drawer-rear-rim" name="rim_rear" value="" />
                            <button type="submit" class="absolute right-3 top-3.5 text-lg sm:text-xl">
                                <svg class="w-5 h-auto text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </button>
                        </form>
                        <!-- OpenSearch results panel -->
                        <div class="hidden mt-3 border border-gray-200 rounded-[10px] bg-white shadow-lg max-h-[420px] overflow-y-auto" id="os-results-panel-drawer">
                            <!-- Tyre Sizes -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-tyresizes-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Tyre Sizes') ?></div>
                                <div class="flex flex-wrap gap-2" id="os-list-tyresizes-drawer"></div>
                            </div>
                            <!-- Products -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-products-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Products') ?></div>
                                <div class="divide-y divide-gray-100" id="os-list-products-drawer"></div>
                            </div>
                            <!-- Brands -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-brands-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Brands') ?></div>
                                <div class="divide-y divide-gray-100" id="os-list-brands-drawer"></div>
                            </div>
                            <!-- Vehicles -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-vehicles-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Vehicles') ?></div>
                                <div class="divide-y divide-gray-100" id="os-list-vehicles-drawer"></div>
                            </div>
                            <!-- Blogs -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-blogs-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Blogs') ?></div>
                                <div class="divide-y divide-gray-100" id="os-list-blogs-drawer"></div>
                            </div>
                            <!-- CMS Pages -->
                            <div class="hidden px-4 pt-3 pb-2" id="os-section-cms-drawer">
                                <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider mb-2"><?= __('Pages') ?></div>
                                <div class="divide-y divide-gray-100" id="os-list-cms-drawer"></div>
                            </div>
                        </div>
                        <button type="button" class="hidden mt-4 bg-theme-yellow hover:bg-theme-blue text-theme-blue hover:text-white rounded-full uppercase inline-flex items-center justify-center px-4 py-2 font-semibold transition-colors text-xs gap-1.5" id="os-tyresize-submit-drawer" onclick="window.osSubmitDrawerTyreSizeSearch()">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            <span><?= $escaper->escapeHtml(__('Search Tyres')) ?></span>
                        </button>
                    </div>
                    <script>
                    function initOsTyreSizeSearchDrawer() {
                        return {
                            submitOsTyreSizeSearchDrawerForm() {
                                this.validate()
                                    .then(() => {
                                        var form = event.target;
                                        var rearWidth = form.querySelector('[name="width_rear"]').value;
                                        var rearHeight = form.querySelector('[name="height_rear"]').value;
                                        var rearRim = form.querySelector('[name="rim_rear"]').value;
                                        if (rearWidth && rearHeight && rearRim && !form.querySelector('[name="product_list_limit"]')) {
                                            var input = document.createElement('input');
                                            input.type = 'hidden';
                                            input.name = 'product_list_limit';
                                            input.value = '5000';
                                            form.appendChild(input);
                                        }
                                        form.submit();
                                    })
                                    .catch((invalid) => { if (invalid.length > 0) invalid[0].focus(); });
                            }
                        }
                    }
                    (function() {
                        var PREFIX       = '.tyre-size-search-full-form-drawer';
                        var searchInput  = document.getElementById('os-tyresize-input-drawer');
                        var panel        = document.getElementById('os-results-panel-drawer');
                        var selectedBox  = document.getElementById('os-tyresize-selected-items-drawer');
                        var minCharsMsg  = document.getElementById('os-tyresize-min-chars-drawer');
                        var noResultMsg  = document.getElementById('os-tyresize-no-result-drawer');
                        var limitMsg     = document.getElementById('os-tyresize-limit-drawer');
                        var submitBtn    = document.getElementById('os-tyresize-submit-drawer');
                        var searchUrl    = '<?= $baseUrl ?>elastyresearch/ajax/search?q=';
                        var maxSelect    = 2;
                        var selectedCount = 0;
                        var debounceTimer = null;

                        function parseTyreSize(s) {
                            var m = s.match(/(\d+)\s*\/\s*(\d+)\s*R\s*(\d+)/i);
                            return m ? { width: m[1], height: m[2], rim: m[3] } : null;
                        }

                        function hideMessages() {
                            minCharsMsg.classList.add('hidden');
                            noResultMsg.classList.add('hidden');
                            limitMsg.classList.add('hidden');
                        }

                        function hidePanel() {
                            panel.classList.add('hidden');
                        }

                        function updatePlaceholder() {
                            if (selectedCount > 0) {
                                searchInput.setAttribute('placeholder', '');
                                searchInput.classList.add('w-1/5');
                                searchInput.classList.remove('w-5/6');
                            } else {
                                searchInput.setAttribute('placeholder', '<?= __('Search Tyre Size e.g 1956515 or 195/65 R15') ?>');
                                searchInput.classList.remove('w-1/5');
                                searchInput.classList.add('w-5/6');
                            }
                        }

                        /* ── Section renderers ── */

                        function renderTyreSizes(sizes) {
                            var section = document.getElementById('os-section-tyresizes-drawer');
                            var list    = document.getElementById('os-list-tyresizes-drawer');
                            list.innerHTML = '';
                            if (!sizes || !sizes.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            sizes.forEach(function(item) {
                                var parsed = parseTyreSize(item.size);
                                if (!parsed) return;
                                var pill = document.createElement('button');
                                pill.type = 'button';
                                pill.textContent = item.size;
                                pill.className = 'inline-flex items-center px-3 py-1.5 rounded-full border border-gray-300 text-sm text-gray-700 hover:border-theme-blue hover:text-theme-blue transition-colors cursor-pointer';
                                pill.setAttribute('data-width', parsed.width);
                                pill.setAttribute('data-height', parsed.height);
                                pill.setAttribute('data-rim', parsed.rim);
                                pill.addEventListener('click', function() { selectSize(pill); });
                                list.appendChild(pill);
                            });
                        }

                        function renderProducts(products) {
                            var section = document.getElementById('os-section-products-drawer');
                            var list    = document.getElementById('os-list-products-drawer');
                            list.innerHTML = '';
                            if (!products || !products.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            products.forEach(function(p) {
                                var a = document.createElement('a');
                                a.href = p.url;
                                a.className = 'flex items-center gap-3 py-2.5 hover:bg-gray-50 transition-colors rounded-lg px-1';
                                a.innerHTML = '<img src="' + (p.image || '') + '" alt="" class="w-11 h-11 object-contain rounded-md flex-shrink-0 bg-gray-50" loading="lazy" onerror="this.style.display=\'none\'">'
                                    + '<div class="flex-1 min-w-0">'
                                    + '<div class="text-sm text-gray-800 font-medium truncate">' + p.name + '</div>'
                                    + '<div class="flex items-center gap-2 mt-0.5">'
                                    + (p.brand ? '<span class="text-xs text-gray-400">' + p.brand + '</span>' : '')
                                    + '<span class="text-sm font-semibold text-theme-blue"><?= __('AED') ?> ' + p.price + '</span>'
                                    + '</div>'
                                    + '</div>';
                                list.appendChild(a);
                            });
                        }

                        function renderBrands(brands) {
                            var section = document.getElementById('os-section-brands-drawer');
                            var list    = document.getElementById('os-list-brands-drawer');
                            list.innerHTML = '';
                            if (!brands || !brands.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            brands.forEach(function(b) {
                                var a = document.createElement('a');
                                a.href = b.url || '#';
                                a.className = 'flex items-center gap-3 py-2 hover:bg-gray-50 transition-colors rounded-lg px-1';
                                a.innerHTML = (b.image ? '<img src="' + b.image + '" alt="" class="w-8 h-8 object-contain rounded flex-shrink-0" loading="lazy" onerror="this.style.display=\'none\'">' : '')
                                    + '<span class="text-sm text-gray-700">' + b.name + '</span>';
                                list.appendChild(a);
                            });
                        }

                        function renderVehicles(vehicles) {
                            var section = document.getElementById('os-section-vehicles-drawer');
                            var list    = document.getElementById('os-list-vehicles-drawer');
                            list.innerHTML = '';
                            if (!vehicles || !vehicles.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            vehicles.forEach(function(v) {
                                var a = document.createElement('a');
                                a.href = v.url || '#';
                                a.className = 'flex items-center gap-3 py-2 hover:bg-gray-50 transition-colors rounded-lg px-1';
                                a.innerHTML = (v.image ? '<img src="' + v.image + '" alt="" class="w-8 h-8 object-contain rounded flex-shrink-0" loading="lazy" onerror="this.style.display=\'none\'">' : '')
                                    + '<span class="text-sm text-gray-700">' + v.name + '</span>';
                                list.appendChild(a);
                            });
                        }

                        function renderBlogs(blogs) {
                            var section = document.getElementById('os-section-blogs-drawer');
                            var list    = document.getElementById('os-list-blogs-drawer');
                            list.innerHTML = '';
                            if (!blogs || !blogs.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            blogs.forEach(function(b) {
                                var a = document.createElement('a');
                                a.href = b.url || '#';
                                a.className = 'flex items-center gap-3 py-2 hover:bg-gray-50 transition-colors rounded-lg px-1';
                                a.innerHTML = (b.image ? '<img src="' + b.image + '" alt="" class="w-8 h-8 object-contain rounded flex-shrink-0" loading="lazy" onerror="this.style.display=\'none\'">' : '')
                                    + '<span class="text-sm text-gray-700">' + (b.title || b.name || '') + '</span>';
                                list.appendChild(a);
                            });
                        }

                        function renderCms(pages) {
                            var section = document.getElementById('os-section-cms-drawer');
                            var list    = document.getElementById('os-list-cms-drawer');
                            list.innerHTML = '';
                            if (!pages || !pages.length) { section.classList.add('hidden'); return; }
                            section.classList.remove('hidden');
                            pages.forEach(function(p) {
                                var a = document.createElement('a');
                                a.href = p.url || '#';
                                a.className = 'block py-2 px-1 text-sm text-theme-blue hover:underline';
                                a.textContent = p.title || '';
                                list.appendChild(a);
                            });
                        }

                        /* ── Search ── */

                        function doSearch() {
                            var val = searchInput.value.trim();
                            if (selectedCount >= maxSelect) { limitMsg.classList.remove('hidden'); return; }
                            if (val.length < 3) {
                                hidePanel();
                                minCharsMsg.classList.remove('hidden');
                                noResultMsg.classList.add('hidden');
                                return;
                            }
                            hideMessages();
                            fetch(searchUrl + encodeURIComponent(val), { credentials: 'include' })
                                .then(function(r) { return r.json(); })
                                .then(function(data) {
                                    renderTyreSizes(data.tyresizes);
                                    renderProducts(data.products);
                                    renderBrands(data.brands);
                                    renderVehicles(data.vehicles);
                                    renderBlogs(data.blogs);
                                    renderCms(data.cms);
                                    var hasAny = (data.tyresizes && data.tyresizes.length)
                                              || (data.products && data.products.length)
                                              || (data.brands && data.brands.length)
                                              || (data.vehicles && data.vehicles.length)
                                              || (data.blogs && data.blogs.length)
                                              || (data.cms && data.cms.length);
                                    if (hasAny) {
                                        panel.classList.remove('hidden');
                                        noResultMsg.classList.add('hidden');
                                    } else {
                                        hidePanel();
                                        noResultMsg.classList.remove('hidden');
                                    }
                                })
                                .catch(function() {});
                        }

                        /* ── Size selection (front/rear) ── */

                        function selectSize(pill) {
                            if (selectedCount >= maxSelect) return;
                            var w = pill.getAttribute('data-width');
                            var h = pill.getAttribute('data-height');
                            var r = pill.getAttribute('data-rim');
                            var label = w + '/' + h + ' R' + r;
                            if (selectedCount === 0) {
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-width').value = w;
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-height').value = h;
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rim').value = r;
                                selectedBox.querySelector('.os-front-selected-drawer').textContent = label;
                                selectedBox.querySelector('.os-front-selected-atag-drawer').classList.remove('hidden');
                            } else if (selectedCount === 1) {
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-width').value = w;
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-height').value = h;
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-rim').value = r;
                                selectedBox.querySelector('.os-rear-selected-drawer').textContent = label;
                                selectedBox.querySelector('.os-rear-selected-atag-drawer').classList.remove('hidden');
                            }
                            selectedCount++;
                            submitBtn.classList.remove('hidden');
                            searchInput.value = '';
                            hidePanel();
                            hideMessages();
                            updatePlaceholder();
                            searchInput.focus();
                        }

                        function removeSelection(isFront) {
                            if (isFront) {
                                var rw = document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-width').value;
                                var rh = document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-height').value;
                                var rr = document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-rim').value;
                                if (rw && rh && rr) {
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-width').value = rw;
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-height').value = rh;
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-rim').value = rr;
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-width').value = '';
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-height').value = '';
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-rim').value = '';
                                    selectedBox.querySelector('.os-front-selected-drawer').textContent = rw + '/' + rh + ' R' + rr;
                                    selectedBox.querySelector('.os-front-selected-atag-drawer').classList.remove('hidden');
                                    selectedBox.querySelector('.os-rear-selected-atag-drawer').classList.add('hidden');
                                    selectedBox.querySelector('.os-rear-selected-drawer').textContent = '';
                                } else {
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-width').value = '';
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-height').value = '';
                                    document.querySelector(PREFIX + ' #os-tyresize-drawer-rim').value = '';
                                    selectedBox.querySelector('.os-front-selected-atag-drawer').classList.add('hidden');
                                    selectedBox.querySelector('.os-front-selected-drawer').textContent = '';
                                }
                            } else {
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-width').value = '';
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-height').value = '';
                                document.querySelector(PREFIX + ' #os-tyresize-drawer-rear-rim').value = '';
                                selectedBox.querySelector('.os-rear-selected-atag-drawer').classList.add('hidden');
                                selectedBox.querySelector('.os-rear-selected-drawer').textContent = '';
                            }
                            selectedCount--;
                            if (selectedCount <= 0) { selectedCount = 0; submitBtn.classList.add('hidden'); }
                            updatePlaceholder();
                        }

                        /* ── Event listeners ── */

                        searchInput.addEventListener('input', function() {
                            clearTimeout(debounceTimer);
                            debounceTimer = setTimeout(doSearch, 300);
                        });
                        searchInput.addEventListener('focus', function() { updatePlaceholder(); });
                        searchInput.addEventListener('focusout', function() {
                            hideMessages();
                            updatePlaceholder();
                            /* Delay hiding panel so click events on results fire first */
                            setTimeout(function() { hidePanel(); }, 200);
                        });

                        document.querySelectorAll('.search-full-tyre-by-size-drawer .os-remove-selected-drawer').forEach(function(btn) {
                            btn.addEventListener('click', function(e) {
                                var parent = e.currentTarget.closest('a');
                                if (!parent) return;
                                removeSelection(parent.classList.contains('os-front-selected-atag-drawer'));
                            });
                        });

                        window.osSubmitDrawerTyreSizeSearch = function() {
                            var form = document.querySelector(PREFIX);
                            var w = form.querySelector('[name="width"]').value;
                            var h = form.querySelector('[name="height"]').value;
                            var r = form.querySelector('[name="rim"]').value;
                            if (w && h && r) {
                                var url = form.action + 'width=' + encodeURIComponent(w) + '&height=' + encodeURIComponent(h) + '&rim=' + encodeURIComponent(r);
                                var rw = form.querySelector('[name="width_rear"]').value;
                                var rh = form.querySelector('[name="height_rear"]').value;
                                var rr = form.querySelector('[name="rim_rear"]').value;
                                if (rw && rh && rr) { url += '&width_rear=' + encodeURIComponent(rw) + '&height_rear=' + encodeURIComponent(rh) + '&rim_rear=' + encodeURIComponent(rr) + '&product_list_limit=5000'; }
                                else { url += '&width_rear=&height_rear=&rim_rear='; }
                                window.location.href = url;
                            }
                        };
                    })();
                    </script>
                </div>
            </div>
        </div>
            <div class="text-xs text-gray-500 mt-auto">
                <?php echo __('You can close this window with the "X" button.') ?>
            </div>
