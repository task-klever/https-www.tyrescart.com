                            </div>
                        </div>
                        <div class="box rounded-[10px] overflow-hidden relative cursor-pointer" x-show="!isVehicleOnlyTabs" @click="openDrawer('ev')">
                            <img src="<?= $block->getViewFileUrl('images/ev-car-tire.webp') ?>" alt="EV Car Tire" class="w-full">
                            <div class="absolute inset-x-0 bottom-0 p-1.5">
                                <button class="w-full inline-flex items-center justify-center bg-white gap-1 hover:text-white px-2 py-1.5 rounded-full font-medium text-xs hover:bg-theme-blue text-black transition-colors duration-300">
