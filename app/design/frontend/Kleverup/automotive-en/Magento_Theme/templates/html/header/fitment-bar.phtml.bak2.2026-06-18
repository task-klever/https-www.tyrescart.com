                                <?php echo __('SEARCH') ?> <i class="icon icon-three-arrow text-f9 ml-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Reset -->
                    <button x-show="sizeWidth || vehMake" x-cloak @click="resetAll()"
