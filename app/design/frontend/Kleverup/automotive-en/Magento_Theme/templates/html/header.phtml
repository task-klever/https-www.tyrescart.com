<script>
   document.addEventListener("DOMContentLoaded", function() {
       const headerSearchFullButton = document.getElementById("header-search-full-icon");
       headerSearchFullButton.addEventListener("click", function(event) {
           event.stopPropagation(); // Stop the click event from propagating further
   
           if (!document.getElementById('search-full-tyre-by-sizeUL-head').innerHTML.trim()) {
               document.getElementById('klever-loader2').style.display = 'flex';
               fetch('<?php echo $this->getBaseUrl() . 'klever-vehicle/ajax/tyreSizes'; ?>', {
                       headers: {
                           contentType: "application/x-www-form-urlencoded; charset=UTF-8",
                       },
                       body: new URLSearchParams({
                           form_key: hyva.getFormKey(),
                           uenc: btoa(window.location.href)
                       }),
                       method: "POST",
                       mode: "cors",
                       credentials: "include",
                   })
                   .then(response => response.json())
                   .then(data => {
                       document.getElementById('search-full-tyre-by-sizeUL-head').innerHTML = data.response;
                       // Event listener for selecting items in the list
                       var dropdownList = document.getElementById('search-full-tyre-by-sizeUL-head');
                       const listItemsHead = dropdownList.getElementsByTagName('li');
                       for (let i = 0; i < listItemsHead.length; i++) {
                           const listItem = listItemsHead[i];
                           listItem.addEventListener('click', () => toggleSelectionHead(listItem));
                       }
                       document.getElementById('hklever-loader2').style.display = 'none';
                   })
                   .catch(error => {
                       document.getElementById('klever-loader2').style.display = 'none';
                       // Handle error here
                   });
           } else {
               //console.log(" no ajax");
           }
           var tyreSizeFullSearch = document.getElementById("tyre-size-search-full-head");
           if (tyreSizeFullSearch) tyreSizeFullSearch.classList.remove("hidden");
           document.getElementById("tyre-size-search-full-input-head")?.focus();
       });
   
       const tyreSizeSearchFullClose = document.getElementById("tyre-size-search-full-close");
   
       if(tyreSizeSearchFullClose){
           tyreSizeSearchFullClose.addEventListener("click", function(event) {
               var tyreSizeFullSearch = document.getElementById("tyre-size-search-full-head");
               if (tyreSizeFullSearch) tyreSizeFullSearch.classList.add("hidden");
           });
       }
       document.addEventListener("click", function(event) {
           const tyreSizeFullSearch = document.getElementById("tyre-size-search-full-head");
           const searchPopup = document.querySelector(".search-popup");
   
           if (searchPopup && tyreSizeFullSearch && !searchPopup.contains(event.target)) {
               tyreSizeFullSearch.classList.add("hidden");
           }
       });
   });
</script>
