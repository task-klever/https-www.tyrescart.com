<script>
   function tyresizeModal() {
       // Detect page context from URL
       var path = window.location.pathname;
       var btnVehicle = document.getElementById('tyre-search-btn-vehicle');
       var btnSize = document.getElementById('tyre-search-btn-size');
       var btnBrand = document.getElementById('tyre-search-btn-brand');
       var btnEv = document.getElementById('tyre-search-btn-ev');
       var btnContainer = document.getElementById('tyre-search-popup-buttons');

       if (path.indexOf('car-wheels') !== -1) {
           // Car Wheels: show only Vehicle + Size
           window._tyreSearchContext = 'wheels';
           btnVehicle.style.display = '';
           btnSize.style.display = '';
           btnBrand.style.display = 'none';
           btnEv.style.display = 'none';
           btnContainer.classList.remove('md:grid-cols-4');
           btnContainer.classList.add('md:grid-cols-2');
       } else if (path.indexOf('motorcycle-tyres') !== -1) {
           // Motorbike: show only Size
           window._tyreSearchContext = 'motorbike';
           btnVehicle.style.display = 'none';
           btnSize.style.display = '';
           btnBrand.style.display = 'none';
           btnEv.style.display = 'none';
           btnContainer.classList.remove('md:grid-cols-4');
           btnContainer.classList.add('md:grid-cols-2');
       } else {
           // Car Tires (default): show all 4
           window._tyreSearchContext = 'tyres';
           btnVehicle.style.display = '';
           btnSize.style.display = '';
           btnBrand.style.display = '';
           btnEv.style.display = '';
           btnContainer.classList.remove('md:grid-cols-2');
           btnContainer.classList.add('md:grid-cols-4');
       }

       document.getElementById("tyre-size-search-full").classList.remove("translate-y-full");
       document.getElementById("tyre-size-search-full-overlay").classList.remove("hidden");
       document.body.classList.add("overflow-hidden");

       /* Load tyre size list if not already loaded */
       var sizeList = document.getElementById('search-full-tyre-by-sizeUL-head');
       if (sizeList && !sizeList.innerHTML.trim()) {
           document.getElementById('klever-loader2').style.display = 'flex';
           fetch('<?php echo $this->getBaseUrl() . 'klever-vehicle/ajax/tyreSizes'; ?>', {
               headers: { contentType: "application/x-www-form-urlencoded; charset=UTF-8" },
               body: new URLSearchParams({ form_key: hyva.getFormKey(), uenc: btoa(window.location.href) }),
               method: "POST", mode: "cors", credentials: "include"
           })
           .then(response => response.json())
           .then(data => {
               sizeList.innerHTML = data.response;
               var listItems = sizeList.getElementsByTagName('li');
               for (var i = 0; i < listItems.length; i++) {
                   listItems[i].addEventListener('click', (function(item) { return function() { toggleSelectionHead(item); }; })(listItems[i]));
               }
               document.getElementById('klever-loader2').style.display = 'none';
           })
           .catch(function() { document.getElementById('klever-loader2').style.display = 'none'; });
       }
       document.getElementById("tyre-size-search-full-input-head")?.focus();
   }
   function tyresizeModalClose() {
       document.getElementById("tyre-size-search-full").classList.add("translate-y-full");
       document.getElementById("tyre-size-search-full-overlay").classList.add("hidden");
       document.body.classList.remove("overflow-hidden");
   }

    // ========== ESC key handler ==========
       document.addEventListener('keydown', function (event) {
           if (event.key === 'Escape' || event.key === 'Esc') {
               // check if popup is open
   
               const popup = document.getElementById('tyre-size-search-full');
               const overlay = document.getElementById('tyre-size-search-full-overlay');
               const isOpen = popup && !popup.classList.contains('translate-y-full');
               if (isOpen) {
                   if (typeof tyresizeModalClose === 'function') {
                       tyresizeModalClose();
                   } else {
                       // fallback DOM close
                       if (popup) popup.classList.add('translate-y-full');
                       if (overlay) overlay.classList.add('hidden');
                       document.body.classList.remove('overflow-hidden');
                   }
               }
           }
       }, { passive: true });
</script>
