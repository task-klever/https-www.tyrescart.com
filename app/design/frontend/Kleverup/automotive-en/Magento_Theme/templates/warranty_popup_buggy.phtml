<div x-data="warrantyModal()" x-show="open"
     @open-warranty-popup.window="openPopup($event.detail.productId, $event.detail.itemId)"
     style="display:none"
     class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white p-6 rounded-xl shadow-lg w-[400px]">
        <h2 class="text-xl font-semibold mb-4">Add Warranty</h2>

        <form @submit.prevent="submitWarranty()">
            <div>
                <label>
                    <input type="radio" name="warranty" value="1"> Yes (+5%)
                </label>
                <label class="ml-4">
                    <input type="radio" name="warranty" value=""> None
                </label>
            </div>

            <div class="mt-4 flex justify-end gap-2">
                <button type="button" @click="skipWarranty()" class="px-4 py-2 bg-gray-200 rounded">Skip</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Update</button>
            </div>
        </form>
    </div>

    <script>
        function warrantyModal() {
            return {
                open: false,
                productId: null,
                itemId: null,

                openPopup(productId, itemId) {
                    this.productId = productId;
                    this.itemId = itemId;
                    this.open = true;
                },

                async submitWarranty() {
                    const selected = this.$el.querySelector('input[name=warranty]:checked')?.value || '';
                    if (!selected) {
                        this.open = false;
                        window.dispatchEvent(new CustomEvent('open-hyva-minicart'));
                        return;
                    }

                    try {
                        if (this.itemId) {
                            // Logged-in → update existing item
                            const formBody = new URLSearchParams();
                            formBody.append('item_id', this.itemId);
                            formBody.append('options[1]', selected);

                            await fetch('/checkout/cart/updatePost', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: formBody
                            });
                        } else {
                            // Guest → use stored lastCartItemId
                            const cartId = window.checkoutConfig?.quoteData?.quote_id;
                            const itemId = window.lastCartItemId;

                            if (!cartId || !itemId) {
                                console.error('Guest cart ID or item ID missing, cannot update');
                                this.open = false;
                                window.dispatchEvent(new CustomEvent('open-hyva-minicart'));
                                return;
                            }

                            const data = {
                                cartItem: {
                                    item_id: itemId,
                                    sku: this.productId,
                                    qty: 1,
                                    product_option: {
                                        extension_attributes: {
                                            custom_options: [
                                                { option_id: '1', option_value: selected }
                                            ]
                                        }
                                    }
                                }
                            };

                            await fetch(`/rest/default/V1/guest-carts/${cartId}/items/${itemId}`, {
                                method: 'PUT',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(data)
                            });
                        }

                        this.open = false;
                        window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                        window.dispatchEvent(new CustomEvent('open-hyva-minicart'));
                    } catch (err) {
                        console.error('Error updating cart item:', err);
                        this.open = false;
                        window.dispatchEvent(new CustomEvent('open-hyva-minicart'));
                    }
                },

                skipWarranty() {
                    this.open = false;
                    window.dispatchEvent(new CustomEvent('open-hyva-minicart'));
                }
            }
        }
    </script>
</div>