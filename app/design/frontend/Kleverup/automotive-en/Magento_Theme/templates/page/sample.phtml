<script>
(function () {
  function initFaqAccordion(accordion) {
    accordion.querySelectorAll('.faq-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item   = btn.closest('.faq-item');
        var body   = item.querySelector('.faq-body');
        var icon   = btn.querySelector('.faq-icon');
        var isOpen = item.classList.contains('faq-open');

        /* close all items in this accordion */
        accordion.querySelectorAll('.faq-item.faq-open').forEach(function (openItem) {
          openItem.querySelector('.faq-body').style.maxHeight = '0';
          openItem.querySelector('.faq-btn').style.backgroundColor = '';
          openItem.querySelector('.faq-btn').style.color = '';
          openItem.querySelector('.faq-icon').style.transform = '';
          openItem.classList.remove('faq-open');
        });

        /* open clicked item if it was closed */
        if (!isOpen) {
          body.style.maxHeight = body.scrollHeight + 'px';
          btn.style.backgroundColor = '#00843D';
          btn.style.color = '#ffffff';
          icon.style.transform = 'rotate(180deg)';
          item.classList.add('faq-open');
        }
      });
    });
  }

  function init() {
    document.querySelectorAll('.faq-section-blog .faq-accordion').forEach(initFaqAccordion);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
