<?php if ($showAjaxCartModal || $showMiniCart): ?>
    <script>
        function initAjaxCartModal() {
            return {
                open: false,
                loading: false,
                cart: {},
                initialTotalCartAmount: 0,
                totalCartAmount: 0,
                cartItem: null,
                loaderElement: null,
                showSku: <?= $escaper->escapeHtmlAttr($ajaxCartOptionShowSku) ?>,
                init() {
                    window.addEventListener('private-content-loaded', (event) => {
                        const cartData = event.detail.data && event.detail.data.cart;
                        if (!cartData) return;

                        this.cart = cartData;
                        this.totalCartAmount = this.cart.summary_count;
                        this.initialTotalCartAmount = this.cart.summary_count;
                    }, { once: true });

                    this.$watch('totalCartAmount', (value, oldValue) => {
                        if (this.initialTotalCartAmount === this.totalCartAmount) return;
                        <?php if ($showMiniCart): ?>
                            window.dispatchEvent(new CustomEvent('toggle-cart'));
                            // Remove loader when minicart opens
                            if (document.getElementById('ajax-cart-loader')) {
                                document.getElementById('ajax-cart-loader').remove();
                            }
                        <?php endif; ?>
                        <?php if ($showAjaxCartModal): ?>
                            this.openDialog();
                        <?php endif; ?>
                        this.initialTotalCartAmount = this.totalCartAmount;
                    })
                },
                sortObjectByNumberKey(obj) {
                    let keys = Object.keys(obj).map(Number).sort((a, b) => a - b);
                    let sortedObj = {};
                    keys.forEach(key => sortedObj[key] = obj[key]);
                    return sortedObj;
                },
                setNewCartData(event) {
                    const productData = event.detail;
                    window.addEventListener('private-content-loaded', (event) => {
                        const cartData = event.detail.data && event.detail.data.cart;
                        if (!cartData) return;
                        this.cart = cartData;
                        this.totalCartAmount = this.cart.summary_count;

                        if (!productData) return;
                        this.getCurrentProductFromCart(productData);
                    }, { once: true });
                },
                getCurrentProductFromCart(productData) {
                    if (!this.cart.items) return;
                    this.cartItem = this.cart.items.filter((item) => {
                        if (item.product_id !== productData.productId) return;
                        if (item.product_type !== "configurable") {
                            return item;
                        }

                        let cartItemOptions = {};
                        for (const option of item.options) {
                            const filterOptions = { [option.option_id]: option.option_value };
                            cartItemOptions = { ...cartItemOptions, ...filterOptions }
                        }

                        const cartItemOptionsCompare = JSON.stringify(this.sortObjectByNumberKey(cartItemOptions));
                        const productDataOptionsCompare = JSON.stringify(this.sortObjectByNumberKey(productData.options));
                        if (cartItemOptionsCompare === productDataOptionsCompare) {
                            return item;
                        }
                    });

                    if (this.cartItem > 1) {
                        this.cartItem = this.cartItem.slice(0, 1);
                    }

                    this.cartItem = this.cartItem[0];
                },
                getItemCountText() {
                    if (this.totalCartAmount > 1) {
                        return hyva.str('(<?= $escaper->escapeJs(__('%1 items')) ?>)', this.totalCartAmount);
                    }

                    return hyva.str('(<?= $escaper->escapeJs(__('%1 item')) ?>)', this.totalCartAmount);
                },
                openDialog() {
                    if (!this.cartItem) return;
                    this.loading = true;
                    this.scrollLock(true);
                    
                    // Create and show the custom cart loader
                    const loaderContainer = document.createElement('div');
                    loaderContainer.id = 'ajax-cart-loader';
                    loaderContainer.innerHTML = createCustomCartLoader();
                    document.body.appendChild(loaderContainer);
                    
                    // Show loading for a brief moment before opening sidebar
                    setTimeout(() => {
                        // Remove the loader
                        if (document.getElementById('ajax-cart-loader')) {
                            document.getElementById('ajax-cart-loader').remove();
                        }
                        this.loading = false;
                        this.open = true;
                    }, 1200); // 1200ms loading delay for better effect
                },
                closeDialog() {
                    this.open = false;
                    this.loading = false;
                    // Clean up loader if it exists
                    if (document.getElementById('ajax-cart-loader')) {
                        document.getElementById('ajax-cart-loader').remove();
                    }
                    this.scrollLock(false);
                },
                scrollLock(use = true) {
                    document.body.style.overflow = use ? "hidden" : "";
                }
            }
        }
    </script>
    <?php $hyvaCsp->registerInlineScript() ?>
