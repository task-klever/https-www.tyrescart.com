<?php
/** @var \Magento\Framework\View\Element\Template $block */
$brandDataHelper = $this->helper('MGS\Brand\Helper\Data');
$brandCollection = $block->getCollection();
$baseUrl = $block->getBaseUrl();
$mediaUrl = $brandDataHelper->getBaseMediaUrl();
$brandRoute = $brandDataHelper->getBrandRoute();

// Load brand_segment data from DB
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$resource = $objectManager->get(\Magento\Framework\App\ResourceConnection::class);
$conn = $resource->getConnection();
$segmentMap = [];
$segmentRows = $conn->fetchAll('SELECT brand_id, brand_segment FROM mgs_brand WHERE brand_segment IS NOT NULL AND brand_segment != ""');
foreach ($segmentRows as $sr) { $segmentMap[$sr['brand_id']] = $sr['brand_segment']; }

$brandsData = [];
$availableLetters = [];
$urlKeys = [];

// Group by segment
$segmentBrands = [
    'top_premium' => [],
    'top_quality' => [],
    'top_budget'  => [],
];
$otherBrands = [];

foreach ($brandCollection as $brand) {
    $name = trim($brand->getName());
    if (!$name) { continue; }
    $urlKey = $brand->getUrlKey();
    if (!$urlKey) {
        $urlKey = strtolower(preg_replace('/[^a-z0-9]+/', '-', $name));
        $urlKey = trim($urlKey, '-');
    }
    $originalUrlKey = $urlKey;
    $i = 1;
    while (in_array($urlKey, $urlKeys)) {
        $urlKey = $originalUrlKey . '-' . $i;
        $i++;
    }
    $urlKeys[] = $urlKey;
    $firstLetter = strtoupper(substr($name, 0, 1));
    if (!in_array($firstLetter, $availableLetters)) {
        $availableLetters[] = $firstLetter;
    }

    $brandData = [
        'name' => $name,
        'urlKey' => $urlKey,
        'image' => $brand->getImage() ? $mediaUrl . $brand->getImage() : '',
        'firstLetter' => $firstLetter,
        'category' => $brand->getBrandCategory(),
        'segment' => $segmentMap[$brand->getBrandId()] ?? '',
    ];

    $brandsData[] = $brandData;

    $seg = $segmentMap[$brand->getBrandId()] ?? '';
    if ($seg && isset($segmentBrands[$seg]) && $brand->getBrandCategory() === 'Tyres') {
        $segmentBrands[$seg][] = $brandData;
    }
}
sort($availableLetters);

$hasSegmentBrands = !empty($segmentBrands['top_premium']) || !empty($segmentBrands['top_quality']) || !empty($segmentBrands['top_budget']);

$segmentConfig = [
    'top_premium' => ['label' => __('Premium Brands'), 'bg' => 'bg-gradient-to-r from-[#1a1a2e] to-[#16213e]', 'text' => 'text-white'],
    'top_quality' => ['label' => __('Quality Brands'), 'bg' => 'bg-gradient-to-r from-[#00843D] to-[#00a64d]', 'text' => 'text-white'],
    'top_budget'  => ['label' => __('Budget Brands'), 'bg' => 'bg-gradient-to-r from-[#f39c12] to-[#e67e22]', 'text' => 'text-white'],
];
?>
