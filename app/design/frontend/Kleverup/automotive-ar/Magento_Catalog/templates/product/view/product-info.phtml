<?php
// Brand Switcher: load all products with same tyre_size, different brands
$brandSwitcherProducts = [];
if ($tyreSize && $product->getData('tyre_size')) {
    $tyreSizeOptionId = $product->getData('tyre_size');
    $brandSwitcherCollection = $objectManager->create(\Magento\Catalog\Model\ResourceModel\Product\Collection::class);
    $brandSwitcherCollection->addAttributeToSelect('*')
        ->addAttributeToFilter('status', \Magento\Catalog\Model\Product\Attribute\Source\Status::STATUS_ENABLED)
        ->addAttributeToFilter('visibility', ['in' => [
            \Magento\Catalog\Model\Product\Visibility::VISIBILITY_IN_CATALOG,
            \Magento\Catalog\Model\Product\Visibility::VISIBILITY_BOTH
        ]])
        ->addAttributeToFilter('tyre_size', $tyreSizeOptionId)
        ->addAttributeToFilter('entity_id', ['neq' => $product->getId()])
        ->setOrder('brand', 'ASC');
    $brandSwitcherCollection->setPageSize(50);

    foreach ($brandSwitcherCollection as $brProduct) {
        $brBrand = $brProduct->getAttributeText('brand') ?: '';
        $brPattern = $brProduct->getAttributeText('pattern') ?: '';
        if ($brBrand) {
            $brName = $brProduct->getName();
            if ($brBrand && stripos($brName, $brBrand) === 0) {
                $brName = trim(substr($brName, strlen($brBrand)));
            }
            $brPrice = $brProduct->getPriceInfo()->getPrice('final_price')->getValue();
            $brRunflat = $brProduct->getRunflat() ? $brProduct->getAttributeText('runflat') : '';
            $brOrigin = $brProduct->getCountry() ? $brProduct->getAttributeText('country') : '';
            $brYear = $brProduct->getYear() ? $brProduct->getAttributeText('year') : '';
            $brBrandOptionId = $brProduct->getData('brand');
            $brBrandLogo = '';
            if ($brBrandOptionId) {
                $brBrandObj = $listingHelper->getBrandDetails($brBrandOptionId);
                if ($brBrandObj) {
                    $brBrandLogo = $listingHelper->getBrandImageUrl($brBrandObj) ?: '';
                }
            }
            $brandSwitcherProducts[] = [
                'name'    => $brName,
                'brand'   => $brBrand,
                'logo'    => $brBrandLogo,
                'pattern' => $brPattern,
                'price'   => number_format((float)$brPrice, 2),
                'runflat' => $brRunflat,
                'origin'  => $brOrigin,
                'year'    => $brYear,
                'url'     => $brProduct->getProductUrl(),
            ];
        }
    }
}
?>
