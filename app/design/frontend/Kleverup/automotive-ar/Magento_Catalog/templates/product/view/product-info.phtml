<script>
function stickyAddToCart() {
    return {
        visible: false,
        atBottom: false,
        init() {
            const checkBottom = () => {
                this.atBottom = (window.innerHeight + window.scrollY) >= (document.documentElement.scrollHeight - 100);
            };
            window.addEventListener('scroll', checkBottom, { passive: true });
            checkBottom();
            const addToCartSection = document.querySelector('.product-detail-addtocart');
            if (!addToCartSection) return;

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    this.visible = !entry.isIntersecting;
                });
            }, { threshold: 0 });

            observer.observe(addToCartSection);

            // Sync set price from main to sticky
            const mainSetPrice = document.querySelector('.set-price-box .set-of-price');
            const stickySetPrice = document.querySelector('.sticky-set4-price');
            const mainSetLabel = document.querySelector('.set-price-box .set-of');
            const stickySetLabel = document.querySelector('.sticky-set4-label');
            if (mainSetPrice && stickySetPrice) {
                const priceObserver = new MutationObserver(() => {
                    stickySetPrice.textContent = mainSetPrice.textContent;
                    if (mainSetLabel && stickySetLabel) {
                        stickySetLabel.textContent = mainSetLabel.textContent;
                    }
                });
                priceObserver.observe(mainSetPrice, { childList: true, characterData: true, subtree: true });
            }

            // Sync main qty dropdown to sticky when main changes
            const mainQty = document.querySelector('.product-detail-addtocart select[name=qty]');
            const stickyQty = document.getElementById('sticky-qty-select');
            if (mainQty && stickyQty) {
                mainQty.addEventListener('change', () => {
                    stickyQty.value = mainQty.value;
                });
            }
        }
    };
}
</script>
