<script>
function PricePerItem(partsCategory) {
    const panel = document.getElementById("price-per-item");
    const overlay = document.getElementById("price-per-item-overlay");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100", "pointer-events-auto");
    requestAnimationFrame(() => {
        panel.classList.remove("translate-y-full");
        panel.classList.add("translate-y-0");
    });
    document.body.classList.add("overflow-hidden");

    if (partsCategory == 'Tyres') {
        document.querySelector('.tyre-popup-content').classList.remove('hidden');
        document.querySelector('.battery-popup-content').classList.add('hidden');
        document.querySelector('.tyre-popup-title').classList.remove('hidden');
        document.querySelector('.battery-popup-title').classList.add('hidden');
    }
    if (partsCategory == 'Battery') {
        document.querySelector('.tyre-popup-content').classList.add('hidden');
        document.querySelector('.battery-popup-content').classList.remove('hidden');
        document.querySelector('.tyre-popup-title').classList.add('hidden');
        document.querySelector('.battery-popup-title').classList.remove('hidden');
    }
}

function CLosePerItem() {
    const panel = document.getElementById("price-per-item");
    const overlay = document.getElementById("price-per-item-overlay");
    panel.classList.remove("translate-y-0");
    panel.classList.add("translate-y-full");
    overlay.classList.remove("opacity-100", "pointer-events-auto");
    overlay.classList.add("opacity-0", "pointer-events-none");
    document.body.classList.remove("overflow-hidden");
}

document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape' || event.key === 'Esc') {
        const popup = document.getElementById('price-per-item');
        if (popup && !popup.classList.contains('translate-y-full')) {
            CLosePerItem();
        }
    }
});

</script>

