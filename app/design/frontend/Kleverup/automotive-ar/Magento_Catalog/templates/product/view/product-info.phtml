                <circle cx="49" cy="50" r="5" style="animation: spinner-ball-triangle3 2.2s linear infinite"></circle>
            </svg>
            <span class="text-xl select-none">Loading...</span>
        </div>`;

    try {
        const response = await fetch(
            `/tyrefinder/ajax/getsuggestedsize?width=${width}&height=${height}&rim=${rim}`, {
                method: "GET",
                headers: {
                    "X-Requested-With": "XMLHttpRequest",
                    "Content-Type": "application/json"
                }
            }
        );

        const jsonResponse = await response.json();
        const payload = jsonResponse.data;

        if (!payload || payload.status !== "success" || !Array.isArray(payload.data) || payload.data.length === 0) {
            document.getElementById("specifications-content").innerHTML =
                "<p class='text-red-500'>No suggested sizes found.</p>";
            return;
        }

        // Split OEM and Non-OEM
        const oemMap = new Map();
        const nonOemMap = new Map();

        payload.data.forEach(item => {
            const frontSize = `${item.front_width}/${item.front_height} R${item.front_rim}`;
            const rearSize = `${item.rear_width}/${item.rear_height} R${item.rear_rim}`;
            const key = frontSize + "_" + rearSize;

            const record = {
                frontSize,
                rearSize,
                make: item.make_name,
                make_slug: item.make_slug,
                model: item.model_name,
                years: JSON.parse(item.year_ranges || "[]"), // array of year ranges
                engine: item.engine_code || "",

                // raw values for search URL
                front_width: item.front_width,
                front_height: item.front_height,
                front_rim: item.front_rim,
                rear_width: item.rear_width,
                rear_height: item.rear_height,
                rear_rim: item.rear_rim
            };

            if (item.is_stock === 1) {
                if (!oemMap.has(key)) oemMap.set(key, []);
                oemMap.get(key).push(record);
            } else {
                if (!nonOemMap.has(key)) nonOemMap.set(key, []);
                nonOemMap.get(key).push(record);
            }
        });

        let html = "";
        const mediaURL = `<?php echo $makeImageURL; ?>`; // ✅ base media URL
        const transOemSizes = '<?= $escaper->escapeJs(__('OEM Sizes')) ?>';
        const transNonOemSizes = '<?= $escaper->escapeJs(__('Non-OEM Sizes')) ?>';
        const transFront = '<?= $escaper->escapeJs(__('Front:')) ?>';
        const transRear = '<?= $escaper->escapeJs(__('Rear:')) ?>';
        const transViewTyres = '<?= $escaper->escapeJs(__('View Tyres')) ?>';

        // 🔹 Helper function: render section
        function renderSection(map, isOem = true) {
            if (map.size === 0) return "";

            let sectionHtml = `<h3 class="font-bold text-lg ${isOem ? "mb-2 text-theme-blue" : "mt-2 mb-2"}">${isOem ? transOemSizes : transNonOemSizes}</h3>`;

            map.forEach((records) => {
                const { frontSize, rearSize } = records[0];
                const searchUrl = `/tyres?width=${records[0].front_width}&height=${records[0].front_height}&rim=${records[0].front_rim}&width_rear=${records[0].rear_width}&height_rear=${records[0].rear_height}&rim_rear=${records[0].rear_rim}&product_list_limit=5000`;

                // Group models under makes
                const makeMap = new Map();
                records.forEach(r => {
                    if (!makeMap.has(r.make)) {
                        makeMap.set(r.make, { slug: r.make_slug, models: new Map() });
                    }
                    const modelMap = makeMap.get(r.make).models;
                    if (!modelMap.has(r.model)) {
                        modelMap.set(r.model, []);
                    }
                    modelMap.get(r.model).push(...r.years);
                });

                sectionHtml += `
                    <div class="border rounded mb-2 hover:border-blue-200">
                        <button class="w-full flex justify-between items-center p-2 text-left toggle-dropdown">
                            <div class="text-base">
                                <span class="font-semibold">${transFront}</span> <span dir="ltr" class="inline-block">${frontSize}</span>
                                <span class="ml-3 font-semibold">${transRear}</span> <span dir="ltr" class="inline-block">${rearSize}</span>
                            </div>
                            <span class="arrow">+</span>
                        </button>
                        <div class="hidden px-4 pb-3 text-sm text-gray-600 dropdown-content">
                `;

                // Print hierarchy (with image before make)
                makeMap.forEach((data, make) => {
                    sectionHtml += `<div class="flex justify-between items-center mb-3 pb-3 border-b border-dashed border-theme-blue gap-3">
                                      <div class="" style="flex:0 0 auto;">
                                         <div class="left-content">
                                           <div class="brand-image flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 rounded-[6px] px-3 py-1 border border-blue-200 group-hover:border-blue-300 transition-colors">
                                             <img src="${mediaURL}/${data.slug}.png" alt="${make}" class="w-8 h-auto"/>
                                             <p class="ml-2 text-xs font-semibold uppercase text-gray-800 tracking-wide">${make}</p>
                                           </div>
                                          </div>
                                       </div>
                                       <div class="right-content">
                                            <div class="brand-info-content flex gap-2 flex-wrap justify-end">

                                       `;

                    data.models.forEach((years, model) => {
                        // make years unique
                        const uniqYears = [...new Set(years)];
                        sectionHtml += `  
                                               <div class="model-year font-semibold text-gray-900 text-sm hover:text-theme-blue transition-colors text-center">
                                                  <span>${model}</span>
                                                  <span class="text-xs text-gray-500 block">${uniqYears.join(",")}</span>
                                               </div>
                                             `;
                        // years.forEach(y => {
                        //     sectionHtml += `<div class="ml-8">${y}</div>`;
                        // });
                    });

                    sectionHtml += `</div></div></div>`;
                });

                sectionHtml += `
                            <div class="mt-2">
                                <a href="${searchUrl}" class="text-base text-theme-blue font-semibold cursor-pointer hover:text-theme-dark transition-all duration-300 ease-in-out">${transViewTyres}</a>
                            </div>
                        </div>
                    </div>`;
            });

            return sectionHtml;
        }

        html += renderSection(oemMap, true);
        html += renderSection(nonOemMap, false);

        document.getElementById("specifications-content").innerHTML = html;

        // Toggle dropdowns
        document.querySelectorAll(".toggle-dropdown").forEach(btn => {
            btn.addEventListener("click", function () {
                const content = this.nextElementSibling;
                const arrow = this.querySelector(".arrow");
                if (content.classList.contains("open")) {
                    content.classList.remove("open");
                    setTimeout(() => content.classList.add("hidden"), 300);
                    arrow.textContent = "+";
                } else {
                    content.classList.remove("hidden");
                    // Force reflow for transition
                    void content.offsetWidth;
                    content.classList.add("open");
                    arrow.textContent = "−";
                }
            });
        });

    } catch (err) {
        console.error("API fetch error:", err);
        document.getElementById("specifications-content").innerHTML =
            "<p class='text-red-500'>Error loading suggested sizes.</p>";
    }
}

