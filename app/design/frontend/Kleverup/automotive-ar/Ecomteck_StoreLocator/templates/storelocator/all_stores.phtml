<?php
$objectManager =   \Magento\Framework\App\ObjectManager::getInstance();
$params = $this->getRequest()->getParams();
$hideInstallerSelection = '';
if ($params && isset($params['ref']) && isset($params['fitment_type']) && $params['fitment_type']) {
    if ($params['fitment_type'] == 'mobile_van') {
        $installerList = $objectManager->get('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
            ->addFieldToFilter('status', ['eq' => '1'])
            ->addFieldToFilter('ismobilevan', ['eq' => '1']);
    }
    if ($params['fitment_type'] == 'fitment_center') {
        $installerList = $objectManager->get('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
            ->addFieldToFilter('status', ['eq' => '1'])
            ->addFieldToFilter('ismobilevan', ['neq' => '1']);
    }
    $hideInstallerSelection = '';
} else {
    $installerList = $objectManager->get('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection');
    $installerList
                ->addFieldToFilter(
                    ['status', 'stores_id'],                // fields to OR
                    [ ['eq' => 1], ['eq' => 8] ]           // conditions for each field
                )
                ->addFieldToFilter('ismobilevan', ['neq' => 1])
                ->setOrder('installer_sort_order', 'ASC');
     $mobileVanInstaller = $objectManager->create('Ecomteck\StoreLocator\Model\ResourceModel\Stores\Collection')
        ->addFieldToFilter('stores_id', ['eq' => 3]);
    // Merge the two collections
    foreach ($mobileVanInstaller as $item) {
        $installerList->addItem($item);
    }
    $hideInstallerSelection = 'hidden';
}
$allStoreOpeningHours = [];
$storeGoogleMaps = [];
foreach ($installerList as $key => $store) {
    $opening_hours = $store->getOpeningHoursFormated();
    $allStoreOpeningHours[$store->getStoresId()] = $opening_hours;
    $storeGoogleMaps[$store->getStoresId()] = $store->getGoogleMap() ?: '';
}
$objDate = $objectManager->create('Magento\Framework\Stdlib\DateTime\TimezoneInterface');
$todaydate = $objDate->date()->format('d/m/Y');
$gmapApiKey = $objectManager->get('Magento\Framework\App\Config\ScopeConfigInterface')->getValue('ecomteck_storelocator/map/api_key');
$mediaUrl = $objectManager->get('Magento\Store\Model\StoreManagerInterface')->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);

// Build unique cities + JSON stores array for Alpine.js
$uniqueCities = [];
$cityArMap = []; // Map English city => Arabic city for display
$storesJsonArray = [];
foreach ($installerList as $installer) {
    // Skip mobile van stores on the storelocator page
    if ($installer->getIsmobilevan()) continue;
    // Skip coming soon stores
    if ($installer->getCommingSoon()) continue;
    $city = trim($installer->getCity());
    $cityAr = trim($installer->getCityAr() ?: '');
    if ($city && !in_array($city, $uniqueCities)) {
        $uniqueCities[] = $city;
        $cityArMap[$city] = $cityAr ?: $city;
    }
    $storeImage = $installer->getImage();
    $imageUrl = ($storeImage) ? $mediaUrl . 'ecomteck_storelocator/stores/image/' . $storeImage : '';
    $storesJsonArray[] = [
        'id'        => (string)$installer->getStoresId(),
        'name'      => $installer->getNameAr() ?: $installer->getName(),
        'city'      => $city,
        'cityDisplay' => $cityAr ?: $city,
        'address'   => $installer->getAddressAr() ?: $installer->getAddress(),
        'lat'       => (float)$installer->getLatitude(),
        'lng'       => (float)$installer->getLongitude(),
        'phone'     => $installer->getPhone() ?: '',
        'image'     => $imageUrl,
        'openOne'   => $installer->getOpeningHoursOne() ?: '',
        'openTwo'   => $installer->getOpeningHoursTwo() ?: '',
        'comingSoon' => (bool)$installer->getCommingSoon(),
        'isMobileVan' => (bool)$installer->getIsmobilevan(),
        'hasMap'    => !empty($installer->getGoogleMap()),
        'distance'  => null,
    ];
}
sort($uniqueCities);
?>

