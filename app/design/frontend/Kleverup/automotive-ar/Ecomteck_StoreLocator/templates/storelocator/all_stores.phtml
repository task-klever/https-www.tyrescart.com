<script>
var allStoreOpeningHours = <?php echo json_encode($allStoreOpeningHours) ?>;
var allStoreGoogleMaps = <?php echo json_encode($storeGoogleMaps) ?>;
var todaydate = '<?php echo $todaydate ?>';

function storeLocatorApp() {
    return {
        stores: <?php echo json_encode($storesJsonArray) ?>,
        filterCity: 'all',
        searchQuery: '',
        showClear: false,
        searchLat: null,
        searchLng: null,
        selectedStore: null,
        map: null,
        markers: [],
        infoWindow: null,
        autocomplete: null,

        get filteredStores() {
            var self = this;
            var filtered = this.stores.slice();
            if (this.filterCity !== 'all') {
                filtered = filtered.filter(function(s) {
                    return s.city === self.filterCity;
                });
            }
            if (this.searchLat !== null) {
                filtered = filtered.slice().sort(function(a, b) {
                    return (a.distance || 99999) - (b.distance || 99999);
                });
            }
            return filtered;
        },

        initComponent() {
            var self = this;
            var tryInit = function() {
                if (typeof google === 'undefined' || !google.maps) {
                    setTimeout(tryInit, 300);
                    return;
                }
                self.initMap();
                self.initAutocomplete();
            };
            tryInit();
        },

        initMap() {
            this.map = new google.maps.Map(document.getElementById('store-locator-map'), {
                center: { lat: 24.4539, lng: 54.3773 },
                zoom: 7,
                mapTypeControl: true,
                streetViewControl: false,
                fullscreenControl: true,
                zoomControl: true,
            });
            this.infoWindow = new google.maps.InfoWindow();
            this.renderMarkers();
        },

        initAutocomplete() {
            var self = this;
            var input = document.getElementById('tykinstaller');
            if (!input) return;
            this.autocomplete = new google.maps.places.Autocomplete(input, {
                componentRestrictions: { country: 'ae' }
            });
            this.autocomplete.addListener('place_changed', function() {
                var place = self.autocomplete.getPlace();
                if (place && place.geometry) {
                    self.searchLat = place.geometry.location.lat();
                    self.searchLng = place.geometry.location.lng();
                    self.showClear = true;
                    self.searchQuery = input.value;
                    self._doDistanceCalc();
                }
            });
        },

        renderMarkers() {
            var self = this;
            // Clear existing
            this.markers.forEach(function(m) { m.setMap(null); });
            this.markers = [];

            if (!this.map) return;

            var bounds = new google.maps.LatLngBounds();
            var visible = this.filteredStores;

            visible.forEach(function(store) {
                if (!store.lat || !store.lng) return;
                var marker = new google.maps.Marker({
                    position: { lat: store.lat, lng: store.lng },
                    map: self.map,
                    title: store.name,
                });
                marker.storeId = store.id;
                marker.addListener('click', function() {
                    self.infoWindow.setContent(
                        '<div style="max-width:220px">' +
                        '<strong style="color:#003320">' + store.name + '</strong><br>' +
                        '<span style="font-size:12px;color:#666">' + store.address + '</span>' +
                        '</div>'
                    );
                    self.infoWindow.open(self.map, marker);
                    self.selectedStore = store;
                    // Scroll card into view
                    var cardEl = document.querySelector('.installerDiv[data-lat="' + store.lat + '"]');
                    if (cardEl) cardEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                });
                self.markers.push(marker);
                bounds.extend(marker.getPosition());
            });

            if (this.markers.length > 0) {
                this.map.fitBounds(bounds);
                if (this.markers.length === 1) {
                    this.map.setZoom(14);
                }
            }
        },

        selectStore(store) {
            this.selectedStore = store;
            this.panToStore(store);
        },

        panToStore(store) {
            if (!this.map || !store.lat || !store.lng) return;
            this.map.panTo({ lat: store.lat, lng: store.lng });
            this.map.setZoom(14);
            var self = this;
            var marker = this.markers.find(function(m) {
                return m.storeId === store.id;
            });
            if (marker) {
                this.infoWindow.setContent(
                    '<div style="max-width:220px">' +
                    '<strong style="color:#003320">' + store.name + '</strong><br>' +
                    '<span style="font-size:12px;color:#666">' + store.address + '</span>' +
                    '</div>'
                );
                this.infoWindow.open(this.map, marker);
            }
        },

        performSearch() {
            var self = this;
            var inputVal = document.getElementById('tykinstaller').value.trim();

            // If we already have coords from autocomplete, use them directly
            if (this.searchLat !== null && this.searchLng !== null) {
                this._doDistanceCalc();
                return;
            }

            // Otherwise geocode the text input
            if (!inputVal) return;
            var geocoder = new google.maps.Geocoder();
            geocoder.geocode({ address: inputVal + ', UAE' }, function(results, status) {
                if (status === 'OK' && results[0] && results[0].geometry) {
                    self.searchLat = results[0].geometry.location.lat();
                    self.searchLng = results[0].geometry.location.lng();
                    self.showClear = true;
                    self._doDistanceCalc();
                }
            });
        },

        _doDistanceCalc() {
            var self = this;
            var origin = new google.maps.LatLng(this.searchLat, this.searchLng);

            // Create new array to trigger Alpine reactivity
            this.stores = this.stores.map(function(store) {
                var s = Object.assign({}, store);
                if (!s.lat || !s.lng) { s.distance = null; return s; }
                var dest = new google.maps.LatLng(s.lat, s.lng);
                s.distance = parseFloat(
                    (google.maps.geometry.spherical.computeDistanceBetween(origin, dest) / 1000).toFixed(2)
                );
                return s;
            });

            this.renderMarkers();

            if (this.map) {
                this.map.panTo({ lat: this.searchLat, lng: this.searchLng });
                this.map.setZoom(10);
            }
        },

        useMyLocation() {
            if (!navigator.geolocation) {
                alert('Geolocation is not supported by your browser.');
                return;
            }
            var self = this;
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    self.searchLat = pos.coords.latitude;
                    self.searchLng = pos.coords.longitude;
                    // Reverse geocode
                    var geocoder = new google.maps.Geocoder();
                    geocoder.geocode(
                        { location: { lat: self.searchLat, lng: self.searchLng } },
                        function(results, status) {
                            if (status === 'OK' && results[0]) {
                                self.searchQuery = results[0].formatted_address;
                                document.getElementById('tykinstaller').value = self.searchQuery;
                            }
                            self.performSearch();
                        }
                    );
                },
                function(err) {
                    alert('Could not get your location. Please enable location access and try again.');
                }
            );
        },

        clearSearch() {
            this.searchQuery = '';
            this.showClear = false;
            this.searchLat = null;
            this.searchLng = null;
            document.getElementById('tykinstaller').value = '';
            this.stores = this.stores.map(function(s) {
                return Object.assign({}, s, { distance: null });
            });
            this.renderMarkers();
        }
    };
}
</script>

