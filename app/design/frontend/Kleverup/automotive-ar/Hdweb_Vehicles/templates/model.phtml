<script>
    // Store selections for back navigation
    var vehicleSelection = {
        year: '',
        yearName: '',
        make: '',
        model: '',
        engineName: ''
    };
    function getVehicleModifications(year, yearName, make, model) {
        vehicleSelection.year = year;
        vehicleSelection.yearName = yearName;
        vehicleSelection.make = make;
        vehicleSelection.model = model;
        // Update breadcrumb
        var breadcrumbYear = document.getElementById('breadcrumb-year');
        if (breadcrumbYear) breadcrumbYear.textContent = yearName;
        fetch('<?php echo $this->getBaseUrl() . 'vehicles/ajax/getvehiclemodifications'; ?>', {
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            },
            body: new URLSearchParams({
                form_key: hyva.getFormKey(),
                make: make,
                model: model,
                year: year,
                uenc: btoa(window.location.href)
            }),
            method: 'POST',
            mode: 'cors',
            credentials: 'include',
        })
        .then(response => response.json())
        .then(data => {
            const yearsElement = document.getElementById('hdweb_vehicles_years');
            const modificationsElement = document.getElementById('hdweb_vehicles_modifications');
            const modificationsDataElement = document.getElementById('hdweb-vehicles-modifications-data');
            if (yearsElement) yearsElement.style.display = 'none';
            if (modificationsElement) modificationsElement.classList.remove('hidden');
            if (modificationsDataElement) modificationsDataElement.innerHTML = data.response;
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }
    function getVehicleTyreSizes(value, label, make, model, year) {
        vehicleSelection.engineName = label;
        // Update breadcrumbs
        var breadcrumbYearRest = document.getElementById('breadcrumb-year-rest');
        if (breadcrumbYearRest) breadcrumbYearRest.textContent = vehicleSelection.yearName;
        var breadcrumbEngineRest = document.getElementById('breadcrumb-engine-rest');
        if (breadcrumbEngineRest) breadcrumbEngineRest.textContent = label;
        const modification = value;
        fetch('<?php echo $this->getBaseUrl() . 'vehicles/ajax/getsearchbymodel'; ?>', {
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            },
            body: new URLSearchParams({
                form_key: hyva.getFormKey(),
                make: make,
                model: model,
                year: year,
                modification: modification,
                uenc: btoa(window.location.href)
            }),
            method: 'POST',
            mode: 'cors',
            credentials: 'include',
        })
        .then(response => response.json())
        .then(data => {
            var enginesTyre = data.enginesTyre.join("");
            const modificationsElement = document.getElementById('hdweb_vehicles_modifications');
            const restElement = document.getElementById('hdweb_vehicles_rest');
            const restDataElement = document.getElementById('hdweb-vehicles-rest-data');
            if (modificationsElement) modificationsElement.classList.add('hidden');
            if (restElement) restElement.classList.remove('hidden');
            if (restDataElement) restDataElement.innerHTML = enginesTyre;
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }
    function goBackToYears() {
        const yearsElement = document.getElementById('hdweb_vehicles_years');
        const modificationsElement = document.getElementById('hdweb_vehicles_modifications');
        if (modificationsElement) modificationsElement.classList.add('hidden');
        if (yearsElement) yearsElement.style.display = '';
    }
    function goBackToModifications() {
        const modificationsElement = document.getElementById('hdweb_vehicles_modifications');
        const restElement = document.getElementById('hdweb_vehicles_rest');
        if (restElement) restElement.classList.add('hidden');
        if (modificationsElement) modificationsElement.classList.remove('hidden');
    }
    function vehiclesShowProduct(width, height, rim, rear_width, rear_height, rear_rim) {
        const frontWidth = document.getElementById('vehicles_front_width');
        const frontHeight = document.getElementById('vehicles_front_height');
        const frontRim = document.getElementById('vehicles_front_rim');
        const rearWidth = document.getElementById('vehicles_rear_width');
        const rearHeight = document.getElementById('vehicles_rear_height');
        const rearRim = document.getElementById('vehicles_rear_rim');
        if (frontWidth) frontWidth.value = width;
        if (frontHeight) frontHeight.value = height;
        if (frontRim) frontRim.value = rim;
        if (typeof rear_width !== 'undefined' && rear_width !== null && rear_width !== '' && rearWidth) {
            rearWidth.value = rear_width;
        }
        if (typeof rear_height !== 'undefined' && rear_height !== null && rear_height !== '' && rearHeight) {
            rearHeight.value = rear_height;
        }
        if (typeof rear_rim !== 'undefined' && rear_rim !== null && rear_rim !== '' && rearRim) {
            rearRim.value = rear_rim;
        }
        let selectedVehicleFinderUrl;
        if ((typeof rear_width !== 'undefined' && rear_width !== null && rear_width !== '') &&
            (typeof rear_height !== 'undefined' && rear_height !== null && rear_height !== '') &&
            (typeof rear_rim !== 'undefined' && rear_rim !== null && rear_rim !== '')) {
            selectedVehicleFinderUrl = '<?php echo $vehiclesSearchbyFormActionUrl; ?>' + 
                'width=' + width + 
                '&height=' + height + 
                '&rim=' + rim + 
                '&width_rear=' + rear_width + 
                '&height_rear=' + rear_height + 
                '&rim_rear=' + rear_rim +
                '&product_list_limit=5000';
        } else {
            selectedVehicleFinderUrl = '<?php echo $vehiclesSearchbyFormActionUrl; ?>' + 
                'width=' + width + 
                '&height=' + height + 
                '&rim=' + rim + 
                '&width_rear=&height_rear=&rim_rear=';
        }
        window.location.href = selectedVehicleFinderUrl;
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>