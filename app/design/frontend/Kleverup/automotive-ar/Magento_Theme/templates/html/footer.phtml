<script>
    function openProductEnquiryModal(productName) {
        document.getElementById('enquiry-product-name').textContent = productName;
        document.getElementById('enquiry-product-hidden').value = productName;
        document.getElementById('product-enquiry-modal').classList.remove('-translate-x-full');
        document.getElementById('product-enquiry-overlay').classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
        // Reset to form view
        document.getElementById('product-enquiry-success').classList.add('hidden');
        document.getElementById('product-enquiry-error').classList.add('hidden');
        document.getElementById('product-enquiry-buttons').classList.remove('hidden');
        document.querySelectorAll('#productEnquiryForm .enquiry-field-wrap').forEach(function(f){ f.classList.remove('hidden'); });
    }
    function closeProductEnquiryModal() {
        document.getElementById('product-enquiry-modal').classList.add('-translate-x-full');
        document.getElementById('product-enquiry-overlay').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
        document.getElementById('productEnquiryForm').reset();
        // Reset visibility
        document.getElementById('product-enquiry-success').classList.add('hidden');
        document.getElementById('product-enquiry-error').classList.add('hidden');
        document.getElementById('product-enquiry-buttons').classList.remove('hidden');
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            if (!document.getElementById('product-enquiry-modal').classList.contains('-translate-x-full')) {
                closeProductEnquiryModal();
            }
        }
    });
    // AJAX form submission for Product Enquiry
    document.getElementById('productEnquiryForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var form = this;
        var submitBtn = document.getElementById('product-enquiry-submit-btn');
        var errorDiv = document.getElementById('product-enquiry-error');

        // Basic validation
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        // Disable button and show loading
        submitBtn.disabled = true;
        submitBtn.textContent = '<?php echo __("Submitting...") ?>';
        errorDiv.style.display = 'none';

        var formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.status === 'success') {
                // Hide form fields and buttons, show success
                var formFields = form.querySelectorAll('.enquiry-field-wrap');
                formFields.forEach(function(f){ f.style.display = 'none'; });
                document.getElementById('product-enquiry-buttons').style.display = 'none';
                document.getElementById('product-enquiry-error').style.display = 'none';
                document.getElementById('product-enquiry-success-msg').textContent = data.message;
                document.getElementById('product-enquiry-success').style.display = 'block';
                // Auto close after 3 seconds
                setTimeout(function() {
                    closeProductEnquiryModal();
                }, 3000);
            } else {
                errorDiv.textContent = data.message || '<?php echo __("Something went wrong. Please try again.") ?>';
                errorDiv.style.display = 'block';
            }
        })
        .catch(function() {
            errorDiv.textContent = '<?php echo __("Something went wrong. Please try again.") ?>';
            errorDiv.style.display = 'block';
        })
        .finally(function() {
            submitBtn.disabled = false;
            submitBtn.textContent = '<?php echo __("Submit") ?>';
        });
    });
</script>
