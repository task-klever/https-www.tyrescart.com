<script>
   document.addEventListener('alpine:init', () => {
       Alpine.data('initSocialButtons', () => ({
           showSocial: false
       }));
   });
   
   function RequestOpenModal() {
       document.getElementById("request-call-modal").classList.remove("-translate-x-full");
       document.getElementById("request-call-modal-overlay").classList.remove("hidden");
       document.body.classList.add("overflow-hidden");
   }
   function RequestModalClose() {
       document.getElementById("request-call-modal").classList.add("-translate-x-full");
       document.getElementById("request-call-modal-overlay").classList.add("hidden");
       document.body.classList.remove("overflow-hidden");
   }
   // Close modal on ESC key
   document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
         RequestModalClose();
      }
   });
</script>
