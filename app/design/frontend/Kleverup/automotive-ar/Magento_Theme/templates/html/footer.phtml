<script>
   document.addEventListener('alpine:init', () => {
       Alpine.data('initCallBackFormWithValidation', function () {
           const formValidation = hyva.formValidation(this.$el);
           return Object.assign(formValidation, {
               submitCallBackForm() {
                   this.validate()
                       .then(() => {
                           const $callbackForm = document.querySelector('#<?= $escaper->escapeJs("callbackForm") ?>');
                           document.getElementById('klever-loader').classList.remove('hidden');
                           $callbackForm.submit();
                       })
                       .catch((invalid) => {
                           if (invalid.length > 0) {
                               invalid[0].focus();
                           }
                       });
               }
           });
       });
   });
</script>
